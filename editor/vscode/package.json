{
    "name": "eatlang",
    "displayName": "EATLang",
    "description": "Syntax highlighting and language server for the EAT language (EATLang)",
    "version": "0.1.1",
    "publisher": "eatlang",
    "license": "MIT",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "main": "./extension.js",
    "contributes": {
        "languages": [
            {
                "id": "eat",
                "aliases": [
                    "EATLang",
                    "EAT"
                ],
                "extensions": [
                    ".eat"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/eat.svg",
                    "dark": "./icons/eat.svg"
                }
            }
        ],
        "grammars": [
            {
                "language": "eat",
                "scopeName": "source.eat",
                "path": "./syntaxes/eat.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "EATLang",
            "properties": {
                "eatlang.server.command": {
                    "type": "string",
                    "default": "bash",
                    "description": "Команда запуска LSP-сервера (по умолчанию bash editor/lsp/serve.sh)."
                },
                "eatlang.server.args": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "editor/lsp/serve.sh"
                    ],
                    "description": "Аргументы запуска сервера. По умолчанию editor/lsp/serve.sh: линкует фазы плоской склейкой и пересобирает build/JsonFlat.eat в корне репозитория EATLang."
                },
                "eatlang.optimize": {
                    "type": "boolean",
                    "default": false,
                    "description": "Ось -O для inlay-хинтов верификатора: свёртка вызовов перед verify (как eatc ir -O) — доказанных проверок (✓) больше."
                }
            }
        }
    },
    "dependencies": {
        "vscode-languageclient": "^8.1.0"
    }
}
