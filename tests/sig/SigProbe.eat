# Проба sig-снапшота (MODULES_PLAN §6, этап 2): импортирует и трогает
# по одному имени из каждого модуля lib/ — поток драйвера от этого
# файла накрывает весь интерфейс библиотеки, а `make verify_sig`
# diff'ает его сигнатуры со снапшотом tests/sig/lib.sig.
# Неиспользуемый импорт — ошибка, поэтому каждый вызов «потрачен».

import {
    is_digit,
} from "lib/Ascii.eat"

import {
    get,
} from "lib/Args.eat"

import {
    same,
} from "lib/Buf.eat"

import {
    NONE,
    U32_MAX,
} from "lib/Const.eat"

import {
    Dec,
    fmt_u32,
} from "lib/Fmt.eat"

import {
    hex_digit,
} from "lib/Hex.eat"

import {
    read_line,
} from "lib/Io.eat"

import {
    JDoc,
    json_doc,
} from "lib/Json.eat"

import {
    min,
} from "lib/Num.eat"

import {
    parse_i32,
} from "lib/Parse.eat"

func main() {
    let d: Dec = fmt_u32(min(42, 99))
    let w: [u8; 16] = [0; 16]
    let s: bool = same(w, 0, "")
    let g: bool = is_digit(u8(48))
    let h: char = hex_digit(10)
    let x: bool = NONE == U32_MAX
    var jd: JDoc = json_doc()
    jd.load("[]")
    let jn: u32 = jd.kind_of(0)
    let a: bool = false
    match get(0) {
        Ok(_) { a = true }
        Err(_) { a = false }
    }
    print("digit={g} hex={h} ln={d.ln} same={s} x={x} j={jn} a={a}")
    match read_line() {
        Ok(line) {
            match parse_i32(line) {
                Ok(n) { print("n={n}") }
                Err(_) { print("bad") }
            }
        }
        Err(_) { print("eof") }
    }
}
