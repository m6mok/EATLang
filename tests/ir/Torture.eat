# Стресс-кейс фазы 4: все конструкции кодогена в одном файле.

constexpr LIM: i32 = 7
constexpr NEG: i32 = -3

enum Cmd {
    Set(u8),
    Clear,
    Nop
}

enum Sign {
    Plus,
    Minus
}

struct Pair {
    a: i32
    b: str<8>

    func sum(self, d: i32) -> i32
        requires true
        ensures true
    {
        return self.a + d
    }

    func bump(let self, d: i32)
        requires true
        ensures true
    {
        self.a = self.a + d
    }
}

func pick(z: u8, c: Cmd) -> u32
    requires true
    ensures true
{
    let acc: u32 = u32(z)
    match c {
        Set(x) {
            acc = acc + u32(x)
        }
        Clear {
            acc = acc + 2
        }
        Nop {
            return acc
        }
    }
    return acc
}

func mk(n: i32) -> Pair
    requires n > -100 and n < 100
    ensures true
{
    return Pair { a: n, b: "p{n}" }
}

func flags(x: i32, y: i32) -> bool
    requires true
    ensures true
{
    return x > 0 and y > 0 or not (x == y)
}

func bit_torture(total: u32, b0: u8, b1: u8, q: i32)
    requires true
    ensures true
{
    const sub: u8 = b1 - b0
    const mul: u8 = sub * 2
    const dv: u8 = mul / 2
    const md: i32 = q % 3
    const dvi: i32 = q / (md + 1)
    print("end {total} {sub} {mul} {dv} {md} {dvi}")
    const bw1: u32 = (total & 255) | 64
    const bw2: u32 = bw1 ^ 129
    const bw3: u32 = bw2 << 3
    const bw4: u32 = bw3 >> 2
    let sh: u32 = 0
    for i in 0..3 {
        sh = sh | (bw1 << u32(i))
    }
    const bb: u8 = (b0 & 15) << 2
    const bc: u8 = bb | 1 ^ 3
    print("bits {bw1} {bw2} {bw3} {bw4} {sh} {bb} {bc}")
}

# 64-битный кодоген: литералы, арифметика, сдвиги, ~, касты в обе
# стороны, u64-индекс, широкий for-диапазон, печать u64/i64.
func wide_torture(seed: u8) -> u64
    requires true
    ensures true
{
    const w: u64 = 0xFFFFFFFFFFFFFFFF
    const base: u64 = u64(seed) + 4294967296
    const prod: u64 = base * 3
    const q64: u64 = w / base
    const r64: u64 = w % base
    const sh1: u64 = base << 16
    const sh2: u64 = w >> 33
    const inv: u64 = ~base
    const neg: i64 = 0 - i64(base)
    const dv: i64 = neg / -255
    const lo: i64 = -9223372036854775808
    const back: u64 = u64(dv)
    const nar1: u32 = u32(r64 % 4294967296)
    const nar2: u16 = u16(sh2 & 0xFFFF)
    const nar3: u8 = u8(inv & 255)
    const nar4: i32 = i32(dv % 1000)
    const wide1: u64 = u64(nar1)
    const wide2: i64 = i64(nar2)
    const cells: [u64; 4] = [1, 2, 3, prod]
    const idx: u64 = base % 4
    let acc: u64 = cells[idx] + wide1 + u64(wide2)
    for k in 4294967296..4294967300 {
        acc = acc + (k & 1023)
    }
    print("wide {q64} {r64} {sh1} {inv} {neg} {dv} {lo}")
    print("narrow {nar1} {nar2} {nar3} {nar4} {back}")
    return acc
}

# Конструкторы Result/Option (этап 2 модулей): локальные замены
# бывших встроенных read_line/parse_i32 — файл остаётся
# самодостаточным стрессом дампов и кроет Ok/Err/Some/None и
# вложенный payload во всех фазах.
func t_line(eof: bool) -> Result<str<256>, IoError>
    requires true
    ensures true
{
    if eof {
        return Err(IoError.Eof)
    }
    return Ok("line")
}

func t_parse(s: str<256>) -> Result<i32, ParseError>
    requires true
    ensures true
{
    if len(s) == 0 {
        return Err(ParseError.Empty)
    }
    return Ok(42)
}

func t_nest(k: u32) -> Result<Option<u32>, ParseError>
    requires true
    ensures true
{
    if k > 100 {
        return Err(ParseError.Overflow)
    }
    if k == 0 {
        return Ok(None)
    }
    return Ok(Some(k))
}

func main() {
    const s: Sign = Sign.Minus
    let t: u32 = 0
    if s == Sign.Plus {
        t = 1
    } elif s == Sign.Minus {
        t = 2
    } else {
        t = 3
    }
    const bytes: [u8; 4] = [1, 2, 3, 255]
    let total: u32 = 0
    for b in bytes {
        total = total + u32(b)
    }
    for i in NEG..LIM {
        if i % 2 == 0 {
            total = total + 1
        }
    }
    const hello: str<16> = "hi"
    for ch in hello {
        if ch == 'h' {
            total = total + 1
        }
    }
    let p: Pair = mk(5)
    p.bump(2)
    const q: i32 = p.sum(1)
    discard pick(u8(3), Cmd.Set(u8(9)))
    const d: u32 = pick(u8(0), Cmd.Clear)
    const arr: [i32; 3] = [0; 3]
    let big: [u32; 100] = [7; 100]
    big[0] = big[1] + 1
    const neg: i32 = -q
    const cast1: u32 = u32(q)
    const cast2: u8 = u8(cast1)
    const cast3: i32 = i32(t)
    const c2: char = char(cast2)
    const cc: u8 = u8(c2)
    assert cc == cast2
    const sm: u32 = u32(len(hello)) + u32(len(arr)) - u32(len(bytes))
    const wt: u64 = wide_torture(bytes[2])
    print("wide acc {wt}")
    if flags(q, neg) and hello == "hi" {
        total = total + 1
    }
    print("t={t} total={total} q={q} d={d} neg={neg} sm={sm}")
    print("c={cast1} {cast2} {cast3} {c2} b={flags(1, 2)} arr={arr[0]}")
    loop {
        match read_byte() {
            Ok(v) {
                if v == 10 {
                    break
                }
                total = total + u32(v)
            }
            Err(e) {
                match e {
                    Eof {
                        break
                    }
                    Fail {
                        break
                    }
                }
            }
        }
    }
    match t_line(false) {
        Ok(line) {
            write(line)
        }
        Err(_) {
            write("eof\n")
        }
    }
    const ov: Option<u32> = None
    match ov {
        Some(v3) {
            total = total + v3
        }
        None {
            total = total + 1
        }
    }
    match t_nest(7) {
        Ok(o2) {
            match o2 {
                Some(v4) {
                    total = total + v4
                }
                None {
                    total = total + 1
                }
            }
        }
        Err(_) {
            total = total + 2
        }
    }
    match t_parse("42") {
        Ok(v2) {
            total = total + u32(v2)
        }
        Err(pe) {
            match pe {
                Empty {
                    total = total + 1
                }
                BadChar {
                    total = total + 2
                }
                Overflow {
                    total = total + 3
                }
            }
        }
    }
    bit_torture(total, bytes[0], bytes[1], q)
}
