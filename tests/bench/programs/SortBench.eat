# Нагрузочный тест: сортировка вставками [u32; 32] — data-dependent
# ветвления и свопы с доказуемыми границами (j-1 под охраной j > 0,
# break ≤ 1 на цикл — сдвиг через флаг). Результат потребляется
# ВЗВЕШЕННОЙ свёрткой по всем 32 позициям: сумма перестановочно-
# инвариантна, а взвешенная — нет, иначе LLVM выкидывает сдвиги
# как мёртвые и оставляет min/max (замерено: 3117M оп/с вместо
# честной сортировки). Базовая порция — 500 сортировок
# (~250 000 сравнений/сдвигов); REPEAT масштабирует.

const REPEAT: u32 = 1

func fill(seed: u32, k: u32) -> u32
    requires seed < 65536
    ensures result < 65536
{
    return (seed * 31 + k + 1) % 65536
}

func main() {
    var a: [u32; 32] = [0; 32]
    var acc: u32 = 7
    for _ in 0..REPEAT {
        for _ in 0..500 {
            for i in 0..32 {
                acc = fill(acc, i)
                a[i] = acc
            }
            for i in 1..32 {
                let v: u32 = a[i]
                var j: u32 = i
                for _ in 0..32 {
                    var move: bool = false
                    if j > 0 {
                        if a[j - 1] > v {
                            move = true
                        }
                    }
                    if move {
                        a[j] = a[j - 1]
                        j = j - 1
                    } else {
                        break
                    }
                }
                a[j] = v
            }
            for i in 0..32 {
                acc = (acc * 3 + a[i]) % 65536
            }
        }
    }
    print("checksum {acc}")
}
