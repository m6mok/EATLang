# Нагрузочный тест: путь ввода — аксиома read_byte через Result.
# Половина профиля selfhost-компилятора: лексер читает исходник
# побайтно этим же путём. Реактивная модель: единственный loop в main,
# останов — Err (EOF). Нагрузку задаёт размер stdin (раннер генерирует
# файл); REPEAT не используется, но маркер оставлен для единообразия.

constexpr REPEAT: u32 = 1

func main() {
    let acc: u32 = 0
    let n: u32 = 0
    loop {
        match read_byte() {
            Ok(b) {
                acc = (acc * 31 + u32(b) + 1) % 65536
                n = (n + 1) % 1000000000
            }
            Err(_) {
                break
            }
        }
    }
    print("bytes {n} checksum {acc}")
}
