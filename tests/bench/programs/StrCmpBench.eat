# Нагрузочный тест: сборка строки интерполяцией + сравнение ==.
# Rt.eq сканирует до расхождения: общий префикс 40 байт заставляет
# читать большую часть строки (кандидат break-развёртки/векторизации
# eq в Rt.eat). Правый операнд собирается из loop-carried acc — LLVM
# не может ни сфолдить, ни вынести сравнение из цикла. Базовая
# порция — 20 000 сборок+сравнений; REPEAT масштабирует.

const REPEAT: u32 = 1

func main() {
    let t: str<256> = "common-prefix-the-quick-brown-fox-jumps-tail-00000"
    var acc: u32 = 0
    for _ in 0..REPEAT {
        for k in 0..20 {
            for i in 0..1000 {
                acc = (acc * 31 + i + k) % 65536
                var s: str<256> = "common-prefix-the-quick-brown-fox-jumps-tail-{acc}"
                if s == t {
                    acc = acc + 7
                }
            }
        }
    }
    print("checksum {acc}")
}
