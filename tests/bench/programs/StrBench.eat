# Нагрузочный тест: строковая машинерия (интерполяция, len).
# Базовая порция — 20 000 сборок строки из 64 дописываний
# (1 280 000 интерполяций); REPEAT масштабирует.

const REPEAT: u32 = 1

func main() {
    var acc: u32 = 0
    for _ in 0..REPEAT {
        for _ in 0..20000 {
            var s: str<256> = ""
            for _ in 0..64 {
                s = "{s}ab"
            }
            acc = (acc + len(s)) % 65536
        }
    }
    print("checksum {acc}")
}
