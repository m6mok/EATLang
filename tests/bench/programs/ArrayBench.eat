# Нагрузочный тест: чтение/запись массива по индексу с проверкой границ.
# Базовая порция — 127 проходов по [u32; 4096] (520 192 операции);
# REPEAT масштабирует. 127, а не 128: m^128 ≡ 1 (mod 2^16) обнуляет пул.

constexpr REPEAT: u32 = 1

func main() {
    let pool: [u32; 4096] = [0; 4096]
    for _ in 0..REPEAT {
        for _ in 0..127 {
            for i in 0..4096 {
                pool[i] = (pool[i] * 7 + i + 1) % 65536
            }
        }
    }
    let acc: u32 = 0
    for x in pool {
        acc = (acc * 3 + x) % 65536
    }
    print("checksum {acc}")
}
