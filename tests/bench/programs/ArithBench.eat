# Нагрузочный тест: целочисленная арифметика в горячем цикле.
# Базовая порция — 1 000 000 итераций; REPEAT масштабирует нагрузку
# (раннер tests/bench/bench.py подменяет константу для нативного замера).

constexpr REPEAT: u32 = 1

func work(seed: u32) -> u32
    requires seed < 65536
    ensures true
{
    let acc: u32 = seed
    for _ in 0..1000 {
        for i in 0..1000 {
            acc = (acc * 31 + i) % 65536
        }
    }
    return acc
}

func main() {
    let acc: u32 = 7
    for _ in 0..REPEAT {
        acc = work(acc) % 65536
    }
    print("checksum {acc}")
}
