# Нагрузочный тест: накладные расходы вызова функции.
# Базовая порция — 500 000 вызовов листовой функции; REPEAT масштабирует.

const REPEAT: u32 = 1

func leaf(x: u32, i: u32) -> u32
    requires true
    ensures true
{
    return (x * 31 + i) % 65536
}

func main() {
    var acc: u32 = 0
    for _ in 0..REPEAT {
        for _ in 0..500 {
            for i in 0..1000 {
                acc = leaf(acc, i)
            }
        }
    }
    print("checksum {acc}")
}
