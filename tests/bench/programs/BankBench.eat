# Нагрузочный тест: банкованный пул — адресация p[a/4096][a%4096].
# Главная идиома памяти selfhost-компилятора (nss[n/65536][n%65536]):
# деление/остаток в адресе + непоследовательный доступ по 128 КБ.
# Адрес зависит от loop-carried acc — LLVM не сворачивает. Метрика
# для аффинной по-банковой формы (трек 4, lb_tp). Базовая порция —
# 200 000 итераций (запись + чтение); REPEAT масштабирует.

constexpr REPEAT: u32 = 1

func work(seed: u32) -> u32
    requires seed < 65536
    ensures true
{
    let pool: [[u32; 4096]; 8] = [[0; 4096]; 8]
    let acc: u32 = seed
    for _ in 0..200 {
        for i in 0..1000 {
            const a: u32 = (acc + i * 37) % 32768
            pool[a / 4096][a % 4096] = (acc + i) % 65536
            const b: u32 = (a * 17 + 5) % 32768
            acc = (acc + pool[b / 4096][b % 4096]) % 65536
        }
    }
    return acc
}

func main() {
    let acc: u32 = 7
    for _ in 0..REPEAT {
        acc = work(acc)
    }
    print("checksum {acc}")
}
