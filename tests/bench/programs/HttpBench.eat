# Нагрузочный тест HTTP-парсера (lib/Http.eat, docs/plans/HTTP_PLAN.md):
# разбор request-line + заголовков, мини-роутер (точный путь, префикс,
# параметр), решение keep-alive. Четыре профиля запроса: типовой GET с
# параметром пути, POST с trace-заголовком и close, кривая request-line
# (400) и HTTP/1.0-миссинг (404 + close). Пути и значения зависят от
# счётчика (интерполяция) — LLVM не может ни сфолдить разбор, ни
# вынести его из цикла. Кадр Req создаётся один раз и переиспользуется
# через Req.reset() (OPTIMIZATIONS_PLAN §8.2: без обнуления raw[8192]
# на каждый запрос); `var` разрешён только у self — носитель кадра
# Bench, профили — его методы. Базовая порция — 2 500 запросов
# (5 × 500, профиль E — parse+store); REPEAT масштабирует. Драйвер (--lib):
# lib/Http.eat импортирует lib/Fmt.eat.

import {
    Req,
    req_new,
    HTTP_NONE,
} from "lib/Http.eat"

const REPEAT: u32 = 1

# Мини-роутер: / -> 200, /greet/* -> 201, иначе 404.
func route_code(r: Req) -> u32
    requires true
    ensures true
{
    if r.path_is("/") {
        return 200
    }
    if r.path_starts("/greet/") {
        return 201
    }
    return 404
}

# Носитель переиспользуемого кадра разбора + пул слотов store
# (профиль E: разбор PUT /todos/{id} + запись в bounded-пул —
# связка parse -> store, TODO_REST_PLAN этап 4).
struct Bench {
    r: Req
    slots: [u32; 64]

    # Типовой GET: параметр пути, четыре заголовка, keep-alive.
    func profile_a(var self, k: u32) -> u32
        requires true
        ensures true
    {
        self.r.reset()
        discard self.r.feed_line("GET /greet/user{k} HTTP/1.1")
        discard self.r.feed_line("Host: bench.local")
        discard self.r.feed_line("User-Agent: eat-bench/1.0")
        discard self.r.feed_line("Accept: */*")
        discard self.r.feed_line("Connection: keep-alive")
        let st: u32 = self.r.feed_line("")
        var acc: u32 = st * 7 + self.r.nh
        if self.r.method_is("GET") {
            acc = acc + route_code(self.r)
        }
        match self.r.path_param(7) {
            Some(name) {
                acc = acc + len(name)
            }
            None {}
        }
        if not self.r.wants_close() {
            acc = acc + 1
        }
        let c: u32 = self.r.find_header("connection")
        if c != HTTP_NONE {
            acc = acc + c
        }
        return acc
    }

    # POST с trace-заголовком и явным close.
    func profile_b(var self, k: u32) -> u32
        requires true
        ensures true
    {
        self.r.reset()
        discard self.r.feed_line("POST /api/items HTTP/1.1")
        discard self.r.feed_line("Content-Type: application/json")
        discard self.r.feed_line("X-Trace-Id: t-{k}")
        discard self.r.feed_line("Connection: close")
        let st: u32 = self.r.feed_line("")
        var acc: u32 = st * 7 + self.r.nh + route_code(self.r)
        if self.r.wants_close() {
            acc = acc + 2
        }
        let t: u32 = self.r.find_header("x-trace-id")
        if t != HTTP_NONE and t < 64 {
            acc = acc + self.r.hdr[t].vl
        }
        return acc
    }

    # Кривая request-line (без пробелов) — 400 от парсера.
    func profile_c(var self, k: u32) -> u32
        requires true
        ensures true
    {
        self.r.reset()
        return self.r.feed_line("BROKEN-{k}")
    }

    # HTTP/1.0 мимо маршрутов: 404 + wants_close по версии.
    func profile_d(var self) -> u32
        requires true
        ensures true
    {
        self.r.reset()
        discard self.r.feed_line("GET /nope HTTP/1.0")
        let st: u32 = self.r.feed_line("")
        var acc: u32 = st * 7 + route_code(self.r)
        if self.r.wants_close() {
            acc = acc + 3
        }
        return acc
    }

    # Профиль E (store): PUT /todos/{id} — разбор пути + запись id в
    # bounded-пул слотов (пул переживает итерации, копит состояние).
    func profile_e(var self, k: u32) -> u32
        requires true
        ensures true
    {
        self.r.reset()
        discard self.r.feed_line("PUT /todos/{k} HTTP/1.1")
        discard self.r.feed_line("Host: bench.local")
        discard self.r.feed_line("Connection: close")
        let st: u32 = self.r.feed_line("")
        var acc: u32 = st * 7 + self.r.nh + route_code(self.r)
        let slot: u32 = k % 64
        self.slots[slot] = (self.slots[slot] + acc + 1) % 65536
        return acc + self.slots[slot]
    }
}

func main() {
    var acc: u32 = 0
    var b: Bench = Bench { r: req_new(), slots: [0; 64] }
    for _ in 0..REPEAT {
        for k in 0..500 {
            acc = (acc * 31 + b.profile_a(k)) % 65536
            acc = (acc * 31 + b.profile_b(k)) % 65536
            acc = (acc * 31 + b.profile_c(k)) % 65536
            acc = (acc * 31 + b.profile_d()) % 65536
            acc = (acc * 31 + b.profile_e(k)) % 65536
        }
    }
    print("checksum {acc}")
}
