# Нагрузочный тест: цена НЕдоказанных рантайм-проверок (трек 3).
# Индексы, делители и кастуемые значения приходят из пулов (массивов) —
# верификатор сегодня не отслеживает интервалы элементов пулов
# (класс «интервалы значений из пулов → bounds», крупнейший остаток
# каталога VERIFICATION_PLAN), поэтому каждая итерация платит за
# trap-ветки: границы массива, переполнение, деление, сужающий каст.
# Пулы мутируют от loop-carried acc, а индексы внутреннего цикла
# зависят от acc — иначе LLVM сворачивает константные пулы (882M оп/с)
# или CSE-ит периодические загрузки не зависящей от acc нагрузки
# (931M оп/с); оба замера — 2026-07-14.
# Когда трек 3 научится интервалам пулов — бенч должен ускориться
# без правок кодогена. Базовая порция — 200 000 итераций.

const REPEAT: u32 = 1

func work(seed: u32) -> u32
    requires seed < 65536
    ensures true
{
    var tbl: [u32; 64] = [0; 64]
    var idx: [u32; 64] = [0; 64]
    for k in 0..64 {
        tbl[k] = (k * 40503) % 251
        idx[k] = (k * 7 + 3) % 64
    }
    var acc: u32 = seed
    for _ in 0..200 {
        for i in 0..1000 {
            let j: u32 = idx[(i + acc) & 63]
            acc = acc + tbl[j]
            let d: u32 = idx[j & 63] + 1
            acc = acc + tbl[(i + acc) & 63] / d
            acc = acc + u32(u8(idx[(i + j) & 63]))
        }
        idx[acc & 63] = (acc * 7 + 3) % 64
        tbl[acc & 63] = acc % 251
    }
    return acc % 65536
}

func main() {
    var acc: u32 = 7
    for _ in 0..REPEAT {
        acc = work(acc)
    }
    print("checksum {acc}")
}
