# Стресс-тест парсера: краевые случаи грамматики. Файл обязан
# парситься (сверка дампа AST), типы не проверяются.

const BIG: u32 = 4294967295
const NEG: i32 = -2147483648
const CALC: u32 = (2 + 3) * 4 - 1 / 5 % 6

enum Node {
    Leaf,
    Num(i32),
    Pair([u32; 4]),
}

struct Deep {
    grid: [[u32; 4]; 4]
    label: str<16>
    res: Result<u32, str<8>>
    opt: Option<[i32; 2]>

    func get(self, i: u32, j: u32) -> u32
        requires i < 4 and j < 4
        ensures result >= 0
    {
        return self.grid[i][j]
    }

    func put(var self, i: u32)
        requires i < 4
    {
        self.grid[i][i] = i * 2
    }
}

struct Wrap {
    oo: Option<Option<u8>>
    ro: Result<Option<u8>, str<4>>
}

func bit_exprs(a: u32, b: u32) -> u32
    requires a & 128 != 0 or a | b >= 1
    ensures true
{
    let m1: u32 = a & b | 3 ^ b & 1
    let m2: u32 = 1 << 4 + 1
    let m3: u32 = a << 2 >> 1
    let m4: bool = a & 15 == b >> 2
    let m5: u32 = (a | b) & (a ^ b)
    var acc: u32 = m1 | m2 ^ m3
    if m4 {
        acc = acc & 4095
    }
    return acc & (m5 | 1)
}

func edge_exprs(a: i32, b: i32) -> i32
    requires not (a < 0) and (b > 1 or a == 0)
    ensures true
{
    let m1: i32 = - -5
    let m2: i32 = -(-7)
    let m3: i32 = -a * b
    let m4: i32 = a + -b
    let m5: i32 = -a.abs() - -b
    let chain: i32 = a - b - 1 - 2
    let logic: bool = not a < b and b <= a or a != 0
    var acc: i32 = 0
    acc = m1 + m2 * m3 - m4 / (m5 % 3) + chain
    if logic {
        acc = acc + 1
    }
    return acc
}

func literals() {
    let s1: str<64> = "escape: \n\t\\\"\'\0 и {BIG} рядом {1 + 2 * 3}"
    let s2: str<32> = "{{не интерполяция}} {CALC}"
    let s3: str<8> = ""
    let arr1: [u32; 3] = [1, 2, 3]
    let arr2: [u32; 5] = [0; 5]
    let arr3: [i32; 2] = [-1, -2]
    let nested: [[u32; 2]; 2] = [[1, 2], [3, 4]]
    let trail: [u32; 2] = [7, 8]
    let ch1: char = '\''
    let ch2: char = '\\'
    let d: Deep = Deep { grid: [[0; 4]; 4], label: "имя", res: Ok(5), opt: None }
    let multi: Deep = Deep {
        grid: [[9; 4]; 4],
        label: "поля с переводами строк"
        res: Err("x"),
        opt: None,
    }
    discard d.get(0, len(s1) % 4)
    print("{arr1[0]} {arr2[4]} {arr3[1]} {nested[1][0]} {trail[1]} {ch1}{ch2} {s2}{s3} {multi.label}")
}

func postfix_chains(d: Deep) -> u32
    requires true
    ensures true
{
    let v1: u32 = d.grid[1][2] + d.get(1, 2)
    let v2: u32 = d.get(0, 0).abs().wrapping()
    let v3: u32 = f(g(h(1), 2), [3, 4][0], "arg {v1}")
    return v1 + v2 + v3
}

func main() {
    var total: u32 = 0
    for i in 0..4 {
        for x in [10, 20, 30] {
            total = total + x + i
        }
    }
    for _ in CALC..BIG {
        break
    }
    loop {
        match parse_i32("42") {
            Ok(v) {
                total = total + u32(v)
            }
            Err(_) {
                break
            }
        }
        if total > 100 {
            break
        } elif total > 50 {
            total = total + 1
        } elif total > 25 {
            total = total + 2
        } else {
            total = total + 3
        }
    }
    print("итого {total}")
}

test выражения_и_границы {
    assert edge_exprs(1, 2) >= -100
    assert (1 < 2) == true
    assert not false
}
