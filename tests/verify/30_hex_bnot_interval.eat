#! expect: assert=2/3 requires=1/1
# Битовое NOT: интервал точный (~x = маска - x, монотонно убывает),
# поэтому границы из requires доказываются; парный недоказуемый
# случай — нижняя граница на 1 выше достижимого минимума ~n.

func inv_high(x: u32) -> u32
    requires x <= 0xFF
    ensures true
{
    const m: u32 = ~x
    assert m >= 0xFFFFFF00
    assert m <= 0xFFFFFFFF
    return m
}

func main() {
    let n: u32 = 0
    match read_byte() {
        Ok(v) {
            n = u32(v)
        }
        Err(_) {
            n = 0
        }
    }
    const r: u32 = inv_high(n & 0xFF)
    const full: u32 = ~n
    assert full >= 0xFFFFFF01
    print("{r} {full}")
}
