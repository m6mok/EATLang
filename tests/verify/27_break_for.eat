#! expect: bounds=2/2 overflow=0/1
# break в for: ранний выход не ломает пофакторные доказательства тела
# (границы a[i] доказаны диапазоном цикла), но пост-состояние цикла
# консервативно: значение, менявшееся в теле, после break-цикла
# неизвестно, и его переполнение остаётся runtime-trap'ом.

func scan(a: [u32; 8], x: u32) -> u32
    requires true
    ensures true
{
    let s: u32 = 0
    for i in 0..8 {
        if a[i] > x {
            break
        }
        s = a[i]
    }
    return s + 1
}

func main() {
    const a: [u32; 8] = [3, 1, 4, 1, 5, 9, 2, 6]
    print("{scan(a, 4)}")
}
