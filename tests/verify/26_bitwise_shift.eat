#! expect: shift=3/4 overflow=1/2 cast=1/1
# Битовые операции: сдвиг на константу доказывается (и вынос битов при
# << с узким интервалом), сдвиг на величину из полного диапазона байта
# остаётся runtime-trap'ом. & | ^ тотальны — проверок не порождают.

func main() {
    const a: u32 = 100
    const b: u32 = a << 4
    const c: u32 = (a >> 2) | (b & 255) ^ 3
    let n: u32 = 0
    match read_byte() {
        Ok(v) {
            n = u32(v)
        }
        Err(_) {
            n = 0
        }
    }
    const d: u32 = a << n
    const m: u8 = 200
    const e: u8 = (m >> 1) & 127
    print("{b} {c} {d} {e}")
}
