#! expect: overflow=1/1
# Позитив §9 шаг 2: насыщение/min выражено ОДНИМ клэмп-присваиванием
# через функцию с ограничивающим `ensures result <= 255`. Кандидат C
# общий интервал-эвалюатор берёт из контракта вызова: `sat255(_)` ⊆
# [0,255] независимо от аргумента ⇒ C ⊊ диапазона типа. Обе ноги:
# предцикл 0 ⊆ [0,255] И тело при sum=C даёт `sat255(sum+j)` ⊆ C. Значит
# sum ∈ [0,255] на входе витка, и аргумент `sum + j` доказан без
# переполнения (индукция без фикспойнта). Показывает, что механизм не
# привязан к синтаксису `%`/`&`: любой клэмп, чей выход ограничен
# независимо от входа (min, насыщение через ensures), несёт инвариант.
# Парный негатив — кейс 61 (тот же каркас, но `ensures true`: выход не
# ограничен ⇒ ⊤ ⇒ не несётся).

func sat255(x: u32) -> u32
    requires true
    ensures result <= 255
{
    if x > 255 {
        return 255
    }
    return x
}

func main() {
    let sum: u32 = 0
    for _ in 0..8 {
        for j in 0..1000 {
            sum = sat255(sum + j)
        }
    }
    print("{sum}")
}
