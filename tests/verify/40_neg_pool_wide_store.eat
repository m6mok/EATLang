#! expect: bounds=2/3
# Негатив: одна немаскированная запись (полный диапазон u32)
# расширяет инвариант пула до диапазона типа — чтение не даёт
# интервала, границы tbl[j] обязаны остаться в рантайме.
# Доказанной остаётся только запись idx[i & 63] в цикле заражения.

func work(seed: u32) -> u32
    requires true
    ensures true
{
    let tbl: [u32; 64] = [0; 64]
    let idx: [u32; 64] = [0; 64]
    for i in 0..64 {
        idx[i & 63] = seed
    }
    let acc: u32 = 0
    for i in 0..100 {
        const j: u32 = idx[i & 63]
        if j < 4294967295 {
            acc = (acc + tbl[j]) % 65536
        }
    }
    return acc
}

func main() {
    print("checksum {work(7)}")
}
