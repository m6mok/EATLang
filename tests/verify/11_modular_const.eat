#! expect: ensures=0/1 assert=1/1 overflow=1/1 requires=1/1
# Модульный контракт: ensures статически НЕ доказан (цикл теряет
# связь с параметром), но рантайм гарантирует его после вызова —
# вызывающий вправе предполагать result >= x.

func bump(x: i32) -> i32
    requires x >= 0 and x <= 1000
    ensures result >= x
{
    let acc: i32 = x
    for _ in 0..3 {
        acc = acc + 1
    }
    return acc
}

func main() {
    const y: i32 = bump(5)
    assert y >= 5
    print("{y}")
}
