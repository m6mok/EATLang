#! expect: bounds=1/2 overflow=1/1
# ОТРИЦАТЕЛЬНЫЙ: запись pool[i] без охраны (i дорастает до 4 при
# размере 3) НЕ должна доказываться — 1/2 это чтение pool[0].

func main() {
    var pool: [i32; 3] = [0, 0, 0]
    var i: u32 = 0
    for _ in 0..5 {
        pool[i] = 1
        i = i + 1
    }
    print("{pool[0]}")
}
