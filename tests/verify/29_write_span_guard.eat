#! expect: bounds=2/3
# write_span с длиной из ввода. Под guard'ом n <= 16 интервал
# уточняется веткой — доказано; маска & 31 шире N=16 — НЕ доказано
# (защита от ложных доказательств): рантайм-проверка остаётся.

func main() {
    var a: [u8; 16] = [46; 16]
    a[15] = 10
    var n: u32 = 0
    match read_byte() {
        Ok(b) {
            n = u32(b)
        }
        Err(_) {
            n = 0
        }
    }
    if n <= 16 {
        write_span(a, 0, n)
    }
    write_span(a, 0, n & 31)
}
