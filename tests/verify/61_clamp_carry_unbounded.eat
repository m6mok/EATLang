#! expect: overflow=0/1
# Негатив §9 шаг 2 (парный к кейсу 60). Тот же каркас, но обёртка НЕ
# ограничивает выход (`ensures true`, тело `return x`): кандидат
# `wrap(sum+j)` при p=⊤ = диапазон типа = ⊤ ⇒ клэмп не распознан, sum на
# входе витка остаётся полным диапазоном, и проверка переполнения
# аргумента `sum + j` ОБЯЗАНА выжить (0/1). Сторожит ногу «кандидат ⊊
# диапазона типа»: без ограничивающего контракта нести нечего, снятие
# проверки было бы ложным доказательством.

func wrap(x: u32) -> u32
    requires true
    ensures true
{
    return x
}

func main() {
    var sum: u32 = 0
    for _ in 0..8 {
        for j in 0..1000 {
            sum = wrap(sum + j)
        }
    }
    print("{sum}")
}
