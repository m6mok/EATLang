#! expect: overflow=0/1
# Негатив §9 шаг 2 (парный к кейсу 58, сторожит ногу «обратной дуги»).
# Та же маска `(sum + j) & m`, но предел `m` ИЗМЕНЯЕТСЯ по витку
# (`m = m ^ 1`) ⇒ m ∈ tracked ⇒ в пробном окружении обнулён до диапазона
# типа: кандидат `_ & m` = [0, u32max] = ⊤ ⇒ клэмп не распознан, sum на
# входе витка остаётся полным диапазоном, и проверка переполнения
# `sum + j` ОБЯЗАНА выжить (0/1). Снять её здесь = снятая настоящая
# trap-проверка (маска по изменяемому пределу не ограничивает результат
# заранее известным потолком). Именно это отличает нелитеральный, но
# loop-инвариантный предел (кейс 58, несётся) от изменяемого по витку
# (здесь, не несётся) — без монотонного фикспойнта.

func main() {
    var m: u32 = 255
    var sum: u32 = 0
    for _ in 0..8 {
        for j in 0..1000 {
            sum = (sum + j) & m
            m = m ^ 1
        }
    }
    print("{sum}")
}
