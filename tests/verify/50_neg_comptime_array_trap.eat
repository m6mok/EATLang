#! expect: error=comptime: trap: переполнение u8
# Негатив A2: trap при вычислении элемента массива-константы (u8
# переполняется) — ошибка компиляции (строгая по-операционная
# семантика = семантика бинарника, §9.1).

constexpr BAD: [u8; 4] = fill_bad()

func fill_bad() -> [u8; 4]
    requires true
    ensures true
{
    let t: [u8; 4] = [0; 4]
    let x: u8 = 200
    t[0] = x + 100
    return t
}

func main() {
    print("{BAD[0]}")
}
