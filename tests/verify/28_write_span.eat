#! expect: bounds=1/1
# write_span: батч-вывод диапазона a[off..off+len) одним вызовом ОС.
# Собственная граница вызова (off + len <= N) — рантайм-проверка:
# верификатор вызовы write_span пока не разбирает (кандидат на
# доказательство интервалами, как индексация).

func main() {
    var a: [u8; 16] = [46; 16]
    a[15] = 10
    write_span(a, 0, 16)
    write_span(a, 15, 1)
}
