#! expect: bounds=3/3
# write_span: батч-вывод диапазона a[off..off+len) одним вызовом ОС.
# Граница вызова (off + len <= N) — обязательство bounds: интервалы
# констант доказывают оба вызова, рантайм-проверки снимаются.

func main() {
    let a: [u8; 16] = [46; 16]
    a[15] = 10
    write_span(a, 0, 16)
    write_span(a, 15, 1)
}
