#! expect: overflow=1/1
# Позитив §9 (модульный инвариант накопителя, OPTIMIZATIONS_PLAN).
# sum пишется во ВЛОЖЕННОМ цикле ⇒ исключён из observed внешнего цикла:
# существующий loop_exit (линейные индукции) его не несёт, на входе
# витка он расширялся бы до полного диапазона типа. Все определения
# sum — вида `_ % K` (K — литерал ≥ 1, интервал [0,K-1] не зависит от
# входного sum), а предцикл 0 ⊆ [0,K-1] ⇒ минимальная звуковая форма
# несёт [0,K-1] на входе витка (индукция без фикспойнта: клэмп %
# безусловен). Поэтому `sum + j` доказано. Парный негатив — кейс 57
# (тот же каркас без %, проверка обязана выжить).

func main() {
    let sum: u32 = 0
    for _ in 0..8 {
        for j in 0..1000 {
            sum = (sum + j) % 65536
        }
    }
    print("{sum}")
}
