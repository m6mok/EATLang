#! expect: error=comptime: trap: переполнение u32
# Негатив: trap при comptime-вычислении — ошибка компиляции
# (строгая по-операционная семантика = семантика бинарника, §9.1).

constexpr BIG: u32 = 2657392035
constexpr X: u32 = doubler(BIG)

func doubler(x: u32) -> u32
    requires true
    ensures true
{
    return x + x
}

func main() {}
