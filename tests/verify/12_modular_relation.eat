#! expect: ensures=0/1 assert=1/1 overflow=1/1 requires=1/1
# Модульный контракт с отношением к переменной вызывающего.

func addk(x: i32, k: i32) -> i32
    requires k >= 0 and k <= 1000 and x >= -1000 and x <= 1000
    ensures result >= x
{
    return x + k
}

func main() {
    let base: i32 = 10
    let y: i32 = addk(base, 3)
    assert y >= base
    print("{y}")
}
