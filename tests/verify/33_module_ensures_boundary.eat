#! expect: bounds=2/2 ensures=1/1 requires=1/1
# SPARK-граница модулей (MODULES_PLAN §6): клиент доказывает bounds
# только по объявленному ensures экспортированной функции — и через
# const-связывание, и в позиции выражения (индекс). Парный негатив —
# 34_neg_module_mask_hidden.eat.
#module "m.eat"
export { mask }

func mask(x: u32) -> u32
    requires true
    ensures result <= 15
{
    return x & 15
}
#module "main.eat"
import { mask } from "m.eat"

func main() {
    const a: [u8; 16] = [0; 16]
    const i: u32 = mask(4070)
    const b: u8 = a[i]
    const c: u8 = a[mask(7)]
    print("{b} {c}")
}
