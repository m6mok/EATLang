#! expect: overflow=1/1
# Позитив §9 шаг 2 (индуктивная проверка кандидат-интервала,
# OPTIMIZATIONS_PLAN): накопитель `sum` во ВЛОЖЕННОМ цикле клэмпируется
# НЕлитеральной маской `& m` (m — локаль ≥ 0, loop-инвариантна). Шаг 1
# нёс только литеральную %K-форму, `& m` не распознавал; шаг 2 вычисляет
# кандидат C общим интервал-эвалюатором: при p=⊤ выход `_ & m` ограничен
# [0,m] независимо от входа ⇒ C=[0,255] ⊊ диапазона типа. Обе ноги
# держатся: предцикл 0 ⊆ [0,255] И тело при sum=C даёт `(sum+j)&m` ⊆ C.
# Значит sum ∈ [0,255] на входе витка, и `sum + j` доказано без
# фикспойнта. Парный негатив — кейс 59 (та же маска, но предел m
# изменяется по витку ⇒ в пробе ⊤ ⇒ клэмп не несётся).

func main() {
    const m: u32 = 255
    let sum: u32 = 0
    for _ in 0..8 {
        for j in 0..1000 {
            sum = (sum + j) & m
        }
    }
    print("{sum}")
}
