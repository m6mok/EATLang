#! expect: overflow=0/1
# Негатив §9 (парный к кейсу 56). Тот же каркас, но накопитель НЕ
# ре-ограничивается: определение `sum = sum + j` — не вида `_ % K`,
# поэтому модульный инвариант НЕ несётся, sum на входе витка остаётся
# полным диапазоном типа, и проверка переполнения `sum + j` ОБЯЗАНА
# выжить (0/1). Снять её здесь = снятая настоящая trap-проверка = дыра
# (при достаточно длинном цикле сумма реально переполнит u32). Этот
# кейс сторожит обе ноги индукции: пропуск проверки «все определения —
# `_ % K`» ложно доказал бы отсутствие переполнения.

func main() {
    var sum: u32 = 0
    for _ in 0..8 {
        for j in 0..1000 {
            sum = sum + j
        }
    }
    print("{sum}")
}
