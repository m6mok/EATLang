#! expect: error=Ok допустим только там, где ожидается Result: в return и в let с аннотацией
# Негатив компиляции: конструктор вне контекста (аргумент вызова) —
# ожидаемый тип там не «известен точно» (решение 2026-07-14).

func f(x: u32) -> u32
    requires true
    ensures true
{
    return x
}

func main() {
    let y: u32 = f(Ok(1))
    print("{y}")
}
