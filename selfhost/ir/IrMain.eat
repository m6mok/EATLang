# Self-hosted эмиттер LLVM IR (фаза 4): точка входа. Фильтр stdin →
# stdout: текстовый модуль LLVM, байт-в-байт совпадающий с эталоном
# `eatc ir` (сверка в make verify_selfhost).

func main() {
    let lex: Lexer = lexer_new()
    let eof: bool = false
    loop {
        match read_byte() {
            Ok(b) {
                lex.step(b)
            }
            Err(_) {
                eof = true
            }
        }
        if eof or lex.failed {
            break
        }
    }
    lex.finish()
    if not lex.failed {
        lex.sublex_pass()
    }
    let bad: bool = lex.failed
    if not bad {
        let p: Parser = parser_new(lex)
        p.parse()
        if not p.failed {
            let c: Check = check_new(p)
            c.run_typed()
            if not c.failed {
                let ir: Ir = ir_new(c)
                ir.emit()
                if ir.failed {
                    bad = true
                }
            } else {
                bad = true
            }
        } else {
            bad = true
        }
    }
    if bad {
        exit(1)
    }
}
