# Self-hosted проверки, фаза 3a: декларации и сигнатуры.
# Таблицы имён (const/func/struct/enum), разрешение типов, константные
# выражения, циклы типов, правила 4 (≤60 statements) и 5 (контракты),
# наличие и сигнатура main. Дамп совпадает с эталоном `eatc sig`.
#
# Типы — интернированный пул: равные типы имеют равный индекс.
# Виды: 0 i32, 1 u32, 2 u8, 3 bool, 4 char, 5 void,
# 6 str (ya: ёмкость | NONE), 7 массив (ya: элемент, yb: размер),
# 8 struct (ys/yl: имя), 9 enum (ys/yl), 10 Result (ya, yb),
# 11 Option (ya), 12 u16, 13 u64, 14 i64 (добавлены позже — коды не
# перенумеровываются). Все обходы деревьев — явные стеки (рекурсии нет).
#
# Знаковые константы — пары (sign, mag): sign 1 — отрицательное.

struct Check {
    p: Parser
    failed: bool
    # пул типов
    yk: [u32; 512]
    ya: [u32; 512]
    yb: [u32; 512]
    ys: [u32; 512]
    yl: [u32; 512]
    ntype: u32
    # константы: имя, тип, значение (sign, mag)
    cn_s: [u32; 128]
    cn_l: [u32; 128]
    cty: [u32; 128]
    cvs: [u32; 128]
    cvm: [u64; 128]
    ncon: u32
    # функции и методы: owner — индекс struct | NONE
    fn_s: [u32; 1024]
    fn_l: [u32; 1024]
    fown: [u32; 1024]
    fps: [u32; 1024]
    fpc: [u32; 1024]
    fret: [u32; 1024]
    fvs: [u32; 1024]
    fnd: [u32; 1024]
    nfun: u32
    # параметры (без self)
    # 4096: самоприменение — 1074 параметра (без self) на 705 функций;
    # 1024 не хватало
    pn_s: [u32; 4096]
    pn_l: [u32; 4096]
    pty: [u32; 4096]
    npar: u32
    # struct'ы и их поля
    sn_s: [u32; 128]
    sn_l: [u32; 128]
    sgs: [u32; 128]
    sgc: [u32; 128]
    snd: [u32; 128]
    nstr: u32
    # 1024: самоприменение верификатора — struct Verify + Check +
    # Parser + Lexer + St дают 659+ полей суммарно; 512 не хватало
    gn_s: [u32; 1024]
    gn_l: [u32; 1024]
    gty: [u32; 1024]
    ngld: u32
    # enum'ы и варианты (wpl — тип нагрузки | NONE)
    en_s: [u32; 64]
    en_l: [u32; 64]
    evs: [u32; 64]
    evc: [u32; 64]
    nenu: u32
    wn_s: [u32; 256]
    wn_l: [u32; 256]
    wpl: [u32; 256]
    nvar: u32
    # результат const_eval
    ces: u32
    cem: u64
    # поиск k-й зависимости типа (циклы типов)
    dep_k: u32
    dep_cnt: u32
    dep_found: u32
    # статистика (правило 4)
    total_stmts: u32
    # --- модули (docs/MODULES_PLAN.md §3) --------------------------------
    # mnd — узел #module-директивы модуля 1..nmod (0 — безымянный сегмент);
    # exports/imports — пулы связок; fmod — модуль функции (атрибуция trap)
    mnd: [u32; 64]
    nmod: u32
    exp_s: [u32; 256]
    exp_l: [u32; 256]
    exi_s: [u32; 256]
    exi_l: [u32; 256]
    exm: [u32; 256]
    nexp: u32
    iml_s: [u32; 512]
    iml_l: [u32; 512]
    imt_s: [u32; 512]
    imt_l: [u32; 512]
    imm: [u32; 512]
    nimp: u32
    fmod: [u32; 1024]
    cmod: u32
    # --- фаза 3b: тайпчекер тел -----------------------------------------
    # аннотации узлов: тип выражения и «возвращает» (достижимость)
    nty: [[u32; 65536]; 2]
    nrt: [[u32; 65536]; 2]
    # границы for-диапазонов: узел, старт (sign, mag), конец (sign, mag)
    rb_n: [u32; 512]
    rb_ss: [u32; 512]
    rb_sm: [u64; 512]
    rb_es: [u32; 512]
    rb_em: [u64; 512]
    nrb: u32
    # узлы параметров (позиции для правила 10)
    pnd: [u32; 4096]
    # переменные областей видимости (sv_s = NONE — это self)
    sv_s: [u32; 256]
    sv_l: [u32; 256]
    sv_t: [u32; 256]
    sv_m: [u32; 256]
    sv_u: [u32; 256]
    sv_ln: [u32; 256]
    sv_cl: [u32; 256]
    nsv: u32
    scp: [u32; 64]
    nsc: u32
    # текущий контекст: fi | 2048+тест; main; self; result; loop
    cur_key: u32
    main_fi: u32
    self_ty2: u32
    self_mu: u32
    res_ty2: u32
    loopd: u32
    # узел, где разрешён конструктор Ok/Err/Some/None: значение let
    # с аннотацией, выражение return, payload вложенного конструктора
    cr: u32
    # break'ов у каждого активного цикла (не более одного, правило 1)
    brkc: [u32; 8]
    # exit: не более одного на программу
    nexit: u32
    # рёбра графа вызовов (код вызывающего, fi вызываемого)
    eg_c: [u32; 4096]
    eg_d: [u32; 4096]
    neg: u32
    # тесты
    tt_s: [u32; 64]
    tt_l: [u32; 64]
    ttn: u32
    # ранги ключей сортировки рёбер: erk[код] — номер в порядке имён
    erk: [u32; 4096]
    # хеш-индекс таблицы функций: open addressing по ключу
    # (владелец, имя), слот — индекс функции или NONE
    fhx: [u32; 2048]
    # машина выражений: кадры (узел, фаза, ожидаемый тип, aux)
    xn: [u32; 64]
    xp: [u32; 64]
    xe: [u32; 64]
    xa: [u32; 64]
    xb: [u32; 64]
    nxq: u32
    tres: u32
    xvoid: u32
    # машина инструкций: кадры (вид, узел, курсор, aux, последняя инструкция)
    qk2: [u32; 128]
    qn: [u32; 128]
    qp: [u32; 128]
    qx: [u32; 128]
    qy: [u32; 128]
    nq: u32
    # встроенные типы и имена (дописаны в sbuf при инициализации)
    ty_sq: u32
    ty_rl: u32
    ty_rb: u32
    ty_pi: u32
    bn_io: u32
    bn_pe: u32
    # глубина стека (правило 1)
    sdep: u32
    # --- фаза 3.5: comptime-константы (COMPTIME_PLAN §9) -----------------
    # cnd — узел декларации отложенной const (NONE — обычная);
    # crs2 — cycle-guard резолюции; ndef — отложенных; bdone — run_bodies
    # уже выполнен (sig-путь догоняет тела при ndef > 0)
    cnd: [u32; 128]
    crs2: [u32; 128]
    ndef: u32
    bdone: u32
    # годность (DFS по подграфу, приоритет impure > nonscalar)
    cseen: [u32; 1024]
    cgen: u32
    cimp: u32
    cnsc: u32
    # машина вычислителя: work-стек задач (тип, узел/индекс, фаза, extra)
    cw_t: [u32; 4096]
    cw_n: [u32; 4096]
    cw_p: [u32; 4096]
    cw_x: [u64; 4096]
    ncw: u32
    # стек значений: kind (yk-код) + беззнаковое + знаковое представление
    cv_k: [u32; 2048]
    cv_u: [u64; 2048]
    cv_i: [i64; 2048]
    ncv: u32
    # кадры вызовов: функция, базы (локали/значения/work/for), результат
    cg_f: [u32; 64]
    cg_lb: [u32; 64]
    cg_vb: [u32; 64]
    cg_wb: [u32; 64]
    cg_qb: [u32; 64]
    cg_rk: [u32; 64]
    cg_ru: [u64; 64]
    cg_ri: [i64; 64]
    ncg: u32
    # локали кадров: спан имени (s == NONE — маркер скоупа), kind, значение
    cl_s: [u32; 4480]
    cl_l: [u32; 4480]
    cl_k: [u32; 4480]
    cl_u: [u64; 4480]
    cl_i: [i64; 4480]
    ncl: u32
    # for-стек: текущее/конец (знаковые), слот переменной (NONE — «_»),
    # база локалей витка
    cq_c: [i64; 512]
    cq_e: [i64; 512]
    cq_v: [u32; 512]
    cq_b: [u32; 512]
    ncq: u32
    # счётчик шагов (бюджет), индекс верхней const (координаты ошибок —
    # узел cnd[ct_ci]), спан имени result в sbuf (для ensures)
    csteps: u32
    ct_ci: u32
    bn_res: u32
    # ярус A2: транзитивная куча массивов вычислителя (сбрасывается на
    # каждую const): заголовки (kind элемента, длина, база в элементах)
    # и хранилище элементов (u/i как на v-стеке). Значение-массив на
    # v-стеке: cv_k = 7, cv_u = id массива (индекс заголовка).
    ca_ek: [u32; 512]
    ca_ln: [u32; 512]
    ca_bs: [u32; 512]
    ca_eu: [u64; 4096]
    ca_ei: [i64; 4096]
    nca: u32
    ncae: u32
    # постоянное хранилище итоговых массивов-констант (для Ir): база в
    # элементах на const ci (длина/тип — из cty[ci]); NONE — не массив
    cca_bs: [u32; 128]
    cca_u: [u64; 4096]
    cca_i: [i64; 4096]
    ncca: u32

    # --- инфраструктура ---------------------------------------------------

    func fail_at(var self, ln: u32, cl: u32, m: str<128>)
        requires true
        ensures true
    {
        if not self.failed {
            eprint("err: {ln}:{cl}: {m}")
        }
        self.failed = true
    }

    # Тип содержит сам себя по значению (цикл размера): текст вынесен,
    # чтобы глубоко вложенный вызов помещался в потолок строки.
    func fail_size_cycle(var self)
        requires true
        ensures true
    {
        self.fail_at(
            1, 1,
            "тип содержит сам себя по значению — бесконечный размер (указателей нет)"
        )
    }

    func fail_node(var self, n: u32, m: str<128>)
        requires n < 131072
        ensures true
    {
        self.fail_at(self.p.nl[n / 65536][n % 65536], self.p.nc[n / 65536][n % 65536], m)
    }

    func span_eq(var self, a1: u32, l1: u32, a2: u32, l2: u32) -> bool
        requires true
        ensures true
    {
        if l1 != l2 {
            return false
        }
        var ok: bool = true
        for i in 0..256 {
            if i >= l1 or not ok {
                break
            }
            if self.p.lex.sb_at(a1 + i) != self.p.lex.sb_at(a2 + i) {
                ok = false
            }
        }
        return ok
    }

    func span_is(var self, a: u32, l: u32, kw: str<16>) -> bool
        requires true
        ensures true
    {
        if l > 16 {
            return false
        }
        return same(pool16(self.p.lex.sbuf, a, l), l, kw)
    }

    func write_span2(var self, a: u32, l: u32)
        requires true
        ensures true
    {
        self.p.lex.w_span(a, l)
    }

    # Имя узла (nss/nsl).
    func nspan_is(var self, n: u32, kw: str<16>) -> bool
        requires n < 131072
        ensures true
    {
        return self.span_is(self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536], kw)
    }

    # --- пул типов --------------------------------------------------------

    func init_types(var self)
        requires true
        ensures true
    {
        for k in 0..6 {
            self.yk[k] = k
            self.ya[k] = NONE
            self.yb[k] = NONE
            self.ys[k] = NONE
            self.yl[k] = 0
        }
        self.ntype = 6
    }

    # Индекс типа u16 (вид 12 интернируется по требованию).
    func u16_ty(var self) -> u32
        requires true
        ensures result < 512
    {
        return self.intern(12, NONE, NONE, NONE, 0)
    }

    # Индекс типа u64 (вид 13 интернируется по требованию).
    func u64_ty(var self) -> u32
        requires true
        ensures result < 512
    {
        return self.intern(13, NONE, NONE, NONE, 0)
    }

    # Индекс типа i64 (вид 14 интернируется по требованию).
    func i64_ty(var self) -> u32
        requires true
        ensures result < 512
    {
        return self.intern(14, NONE, NONE, NONE, 0)
    }

    func intern(var self, k: u32, a: u32, b: u32, s: u32, l: u32) -> u32
        requires k <= 14
        ensures result < 512
    {
        var found: u32 = NONE
        for t in 0..512 {
            if t >= self.ntype or found != NONE {
                break
            }
            if self.yk[t] == k and self.ya[t] == a and self.yb[t] == b {
                if k == 8 or k == 9 {
                    if self.span_eq(self.ys[t], self.yl[t], s, l) {
                        found = t
                    }
                } else {
                    found = t
                }
            }
        }
        if found != NONE {
            return found
        }
        if self.ntype >= 512 {
            self.fail_at(1, 1, "слишком много типов (предел 512)")
            return 0
        }
        let t2: u32 = self.ntype
        self.yk[t2] = k
        self.ya[t2] = a
        self.yb[t2] = b
        self.ys[t2] = s
        self.yl[t2] = l
        self.ntype = t2 + 1
        return t2
    }

    # Индекс struct по имени; NONE если нет.
    func find_struct(var self, a: u32, l: u32) -> u32
        requires true
        ensures true
    {
        var found: u32 = NONE
        for i in 0..128 {
            if i >= self.nstr or found != NONE {
                break
            }
            if self.span_eq(self.sn_s[i], self.sn_l[i], a, l) {
                found = i
            }
        }
        return found
    }

    func find_enum(var self, a: u32, l: u32) -> u32
        requires true
        ensures true
    {
        var found: u32 = NONE
        for i in 0..64 {
            if i >= self.nenu or found != NONE {
                break
            }
            if self.span_eq(self.en_s[i], self.en_l[i], a, l) {
                found = i
            }
        }
        return found
    }

    func find_const(var self, a: u32, l: u32) -> u32
        requires true
        ensures true
    {
        var found: u32 = NONE
        for i in 0..128 {
            if i >= self.ncon or found != NONE {
                break
            }
            if self.span_eq(self.cn_s[i], self.cn_l[i], a, l) {
                found = i
            }
        }
        return found
    }

    func fh_hash(var self, own: u32, a: u32, l: u32) -> u32
        requires true
        ensures true
    {
        var h: u32 = own % 8191 + 1
        for i in 0..256 {
            if i >= l {
                break
            }
            h = (h % 131072) * 31 + u32(self.p.lex.sb_at(a + i))
        }
        return h
    }

    # Поиск в хеш-индексе функций: линейное пробирование до пустого
    # слота; при дубликатах имён (ошибочные программы) порядок вставки
    # растёт по индексу — находится тот же первый, что у скана.
    func fh_find(var self, own: u32, a: u32, l: u32) -> u32
        requires true
        ensures true
    {
        var f: u32 = NONE
        var slot: u32 = self.fh_hash(own, a, l) & 2047
        var stop: bool = false
        for _ in 0..2048 {
            if stop {
                break
            }
            let fi: u32 = self.fhx[slot]
            if fi == NONE {
                stop = true
            } elif (self.fown[fi & 1023] == own
                    and self.span_eq(self.fn_s[fi & 1023], self.fn_l[fi & 1023], a, l)) {
                f = fi
                stop = true
            } else {
                slot = (slot + 1) & 2047
            }
        }
        return f
    }

    func fh_insert(var self, i: u32)
        requires i < 1024
        ensures true
    {
        var slot: u32 = self.fh_hash(self.fown[i], self.fn_s[i], self.fn_l[i]) & 2047
        for _ in 0..2048 {
            if self.fhx[slot] == NONE {
                break
            }
            slot = (slot + 1) & 2047
        }
        self.fhx[slot] = i
    }

    # Функция верхнего уровня (owner NONE) по имени.
    func find_func(var self, a: u32, l: u32) -> u32
        requires true
        ensures true
    {
        return self.fh_find(NONE, a, l)
    }

    # Запись таблицы функций по узлу AST.
    func func_by_node(var self, n: u32) -> u32
        requires true
        ensures true
    {
        var found: u32 = NONE
        for i in 0..1024 {
            if i >= self.nfun or found != NONE {
                break
            }
            if self.fnd[i] == n {
                found = i
            }
        }
        return found
    }

    # --- разрешение типов (итеративно) ------------------------------------

    # Имя простого типа: индекс в пуле; struct/enum — интернируются.
    func resolve_name(var self, n: u32) -> u32
        requires n < 131072
        ensures result < 512
    {
        let a: u32 = self.p.nss[n / 65536][n % 65536]
        let l: u32 = self.p.nsl[n / 65536][n % 65536]
        if self.span_is(a, l, "i32") {
            return 0
        }
        if self.span_is(a, l, "u32") {
            return 1
        }
        if self.span_is(a, l, "u8") {
            return 2
        }
        if self.span_is(a, l, "u16") {
            return self.u16_ty()
        }
        if self.span_is(a, l, "u64") {
            return self.u64_ty()
        }
        if self.span_is(a, l, "i64") {
            return self.i64_ty()
        }
        if self.span_is(a, l, "bool") {
            return 3
        }
        if self.span_is(a, l, "char") {
            return 4
        }
        if self.find_struct(a, l) != NONE {
            return self.intern(8, NONE, NONE, a, l)
        }
        if self.find_enum(a, l) != NONE {
            return self.intern(9, NONE, NONE, a, l)
        }
        if self.span_is(a, l, "IoError") or self.span_is(a, l, "ParseError") {
            return self.intern(9, NONE, NONE, a, l)
        }
        self.fail_node(n, "неизвестный тип")
        return 0
    }

    # Разрешить узел типа AST → индекс типа. Явный стек кадров:
    # (узел, фаза, результат первого ребёнка).
    func resolve(var self, root: u32) -> u32
        requires root < 131072
        ensures result < 512
    {
        var s1: [u32; 32] = [0; 32]
        var s2: [u32; 32] = [0; 32]
        var s3: [u32; 32] = [0; 32]
        var sp: u32 = 1
        s1[0] = root
        s2[0] = 0
        var ret: u32 = 0
        for _ in 0..256 {
            if sp == 0 or self.failed {
                break
            }
            let f: u32 = sp - 1
            let n: u32 = s1[f]
            let ph: u32 = s2[f]
            let k: u32 = self.p.nk[n / 65536][n % 65536]
            if k == 27 {
                ret = self.resolve_name(n)
                sp = f
            } elif k == 28 {
                if ph == 0 {
                    s2[f] = 1
                    if sp >= 32 {
                        self.fail_node(n, "слишком глубокий тип")
                    } else {
                        s1[sp] = self.p.nfc[n / 65536][n % 65536]
                        s2[sp] = 0
                        sp = sp + 1
                    }
                } else {
                    s3[f] = ret
                    self.const_eval(
                        self.p.nns[self.p.nfc[n / 65536][n % 65536] / 65536][
                            self.p.nfc[n / 65536][n % 65536] % 65536
                        ]
                    )
                    let sz: u32 = self.cem_dim(65536)
                    if sz == 0 {
                        self.fail_node(n, "размер массива вне (0, 65536]")
                    }
                    ret = self.intern(7, s3[f], sz, NONE, 0)
                    sp = f
                }
            } elif k == 29 {
                self.const_eval(self.p.nfc[n / 65536][n % 65536])
                let cap: u32 = self.cem_dim(256)
                if cap == 0 {
                    self.fail_node(n, "ёмкость строки вне (0, 256]")
                }
                ret = self.intern(6, cap, NONE, NONE, 0)
                sp = f
            } elif k == 30 {
                if ph == 0 {
                    s2[f] = 1
                    s1[sp] = self.p.nfc[n / 65536][n % 65536]
                    s2[sp] = 0
                    sp = sp + 1
                } elif ph == 1 {
                    s3[f] = ret
                    s2[f] = 2
                    s1[sp] = self.p.nns[self.p.nfc[n / 65536][n % 65536] / 65536][
                        self.p.nfc[n / 65536][n % 65536] % 65536
                    ]
                    s2[sp] = 0
                    sp = sp + 1
                } else {
                    ret = self.intern(10, s3[f], ret, NONE, 0)
                    sp = f
                }
            } elif k == 31 {
                if ph == 0 {
                    s2[f] = 1
                    s1[sp] = self.p.nfc[n / 65536][n % 65536]
                    s2[sp] = 0
                    sp = sp + 1
                } else {
                    ret = self.intern(11, ret, NONE, NONE, 0)
                    sp = f
                }
            } else {
                self.fail_node(n, "некорректный тип")
                sp = f
            }
        }
        return ret
    }

    # Результат const_eval как размер в (0, lim]: 0 — вне диапазона
    # (маска lim — доказательство каста u64 → u32).
    func cem_dim(var self, lim: u32) -> u32
        requires lim <= 65536
        ensures result <= 65536
    {
        if self.ces == 0 and self.cem >= 1 and self.cem <= u64(lim) {
            return u32(self.cem)
        }
        return 0
    }

    # --- константные выражения (итеративно) ---------------------------------
    # Результат — в self.ces (знак) / self.cem (величина).

    func const_eval(var self, root: u32)
        requires root < 131072
        ensures true
    {
        var s1: [u32; 32] = [0; 32]
        var s2: [u32; 32] = [0; 32]
        var sp: u32 = 1
        s1[0] = root
        s2[0] = 0
        # стек значений
        var vs: [u32; 32] = [0; 32]
        var vm: [u64; 32] = [0; 32]
        var nv: u32 = 0
        for _ in 0..256 {
            if sp == 0 or self.failed {
                break
            }
            let f: u32 = sp - 1
            let n: u32 = s1[f]
            let ph: u32 = s2[f]
            let k: u32 = self.p.nk[n / 65536][n % 65536]
            if k == 32 {
                vs[nv] = self.p.ny[n / 65536][n % 65536]
                vm[nv] = self.p.mag(n)
                nv = nv + 1
                sp = f
            } elif k == 37 {
                let ci: u32 = self.find_const(
                    self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
                )
                if ci == NONE {
                    self.fail_node(n, "не константа времени компиляции (правило 2)")
                } else {
                    vs[nv] = self.cvs[ci]
                    vm[nv] = self.cvm[ci]
                    nv = nv + 1
                }
                sp = f
            } elif k == 40 and self.p.nx[n / 65536][n % 65536] == 15 {
                if ph == 0 {
                    s2[f] = 1
                    s1[sp] = self.p.nfc[n / 65536][n % 65536]
                    s2[sp] = 0
                    sp = sp + 1
                } else {
                    if vm[nv - 1] != 0 {
                        vs[nv - 1] = 1 - vs[nv - 1]
                    }
                    sp = f
                }
            } elif (k == 39
                    and self.p.nx[n / 65536][n % 65536] >= 10
                    and self.p.nx[n / 65536][n % 65536] <= 14) {
                if ph == 0 {
                    s2[f] = 1
                    s1[sp] = self.p.nfc[n / 65536][n % 65536]
                    s2[sp] = 0
                    sp = sp + 1
                } elif ph == 1 {
                    s2[f] = 2
                    s1[sp] = self.p.nns[self.p.nfc[n / 65536][n % 65536] / 65536][
                        self.p.nfc[n / 65536][n % 65536] % 65536
                    ]
                    s2[sp] = 0
                    sp = sp + 1
                } else {
                    nv = nv - 1
                    self.const_binop(n, vs[nv - 1], vm[nv - 1], vs[nv], vm[nv])
                    vs[nv - 1] = self.ces
                    vm[nv - 1] = self.cem
                    sp = f
                }
            } else {
                self.fail_node(n, "ожидалась константа времени компиляции (правило 2)")
                sp = f
            }
        }
        if nv > 0 {
            self.ces = vs[nv - 1]
            self.cem = vm[nv - 1]
        }
    }

    # Знаковая арифметика (sign, mag); / и % — семантика floor (эталон
    # считает константы средствами Python). Результат в ces/cem.
    func const_binop(var self, n: u32, s1: u32, m1: u64, s2: u32, m2: u64)
        requires n < 131072
        ensures true
    {
        let op: u32 = self.p.nx[n / 65536][n % 65536]
        if op == 10 {
            self.sadd(n, s1, m1, s2, m2)
        } elif op == 11 {
            if m2 == 0 {
                self.sadd(n, s1, m1, 0, 0)
            } else {
                self.sadd(n, s1, m1, 1 - s2, m2)
            }
        } elif op == 12 {
            if m1 != 0 and m2 > 18446744073709551615 / m1 {
                self.fail_node(n, "константа вне диапазона self-host (2^64)")
                return
            }
            let m: u64 = m1 * m2
            self.cem = m
            if m == 0 or s1 == s2 {
                self.ces = 0
            } else {
                self.ces = 1
            }
        } elif m2 == 0 {
            self.fail_node(n, "деление на ноль в константе")
        } elif op == 13 {
            var q: u64 = m1 / m2
            if s1 != s2 and m1 % m2 != 0 {
                q = q + 1
            }
            self.cem = q
            if q == 0 or s1 == s2 {
                self.ces = 0
            } else {
                self.ces = 1
            }
        } else {
            let r: u64 = m1 % m2
            if r == 0 {
                self.ces = 0
                self.cem = 0
            } elif s1 == s2 {
                self.ces = s2
                self.cem = r
            } else {
                self.ces = s2
                self.cem = m2 - r
            }
        }
    }

    func sadd(var self, n: u32, s1: u32, m1: u64, s2: u32, m2: u64)
        requires n < 131072
        ensures true
    {
        if s1 == s2 {
            if m1 > 18446744073709551615 - m2 {
                self.fail_node(n, "константа вне диапазона self-host (2^64)")
                return
            }
            self.ces = s1
            self.cem = m1 + m2
            if self.cem == 0 {
                self.ces = 0
            }
            return
        }
        if m1 >= m2 {
            self.ces = s1
            self.cem = m1 - m2
        } else {
            self.ces = s2
            self.cem = m2 - m1
        }
        if self.cem == 0 {
            self.ces = 0
        }
    }

    # Значение (sign, mag) помещается в целевой целочисленный тип?
    func int_fits(var self, ty: u32, s: u32, m: u64) -> bool
        requires ty < 512
        ensures true
    {
        let k: u32 = self.yk[ty]
        if k == 0 {
            if s == 1 {
                return m <= 2147483648
            }
            return m <= 2147483647
        }
        if k == 1 {
            return (s == 0 or m == 0) and m <= 4294967295
        }
        if k == 2 {
            return (s == 0 or m == 0) and m <= 255
        }
        if k == 12 {
            return (s == 0 or m == 0) and m <= 65535
        }
        if k == 13 {
            return s == 0 or m == 0
        }
        if k == 14 {
            if s == 1 {
                return m <= 9223372036854775808
            }
            return m <= 9223372036854775807
        }
        return true
    }

    # ==== фаза 3.5: comptime-константы (COMPTIME_PLAN §9) ================
    # Значения const-из-вызовов вычисляются после типизации тел (nty и
    # граф вызовов готовы). Ошибки — с координатами узла const-декларации
    # (cnd[ct_ci]), тексты «comptime: …» зеркалят классы эталона.

    func ct_fail(var self, m: str<128>)
        requires true
        ensures true
    {
        self.fail_node(self.cnd[self.ct_ci] & 131071, m)
    }

    # Спан — имя нечистого встроенного (аксиомы ОС и обёртки вывода)?
    func ct_axiom_span(var self, a: u32, l: u32) -> bool
        requires true
        ensures true
    {
        if self.span_is(a, l, "read_byte") or self.span_is(a, l, "write_byte") {
            return true
        }
        if self.span_is(a, l, "write_span") or self.span_is(a, l, "write_err_byte") {
            return true
        }
        if (self.span_is(a, l, "exit")
                or self.span_is(a, l, "print") or self.span_is(a, l, "write")) {
            return true
        }
        return self.span_is(a, l, "arg_count") or self.span_is(a, l, "arg_len") or self.span_is(
            a, l, "arg_byte"
        )
    }

    # Спан — имя целочисленного каста?
    func ct_cast_span(var self, a: u32, l: u32) -> bool
        requires true
        ensures true
    {
        if self.span_is(a, l, "i32") or self.span_is(a, l, "u32") or self.span_is(a, l, "u8") {
            return true
        }
        return self.span_is(a, l, "u16") or self.span_is(a, l, "u64") or self.span_is(a, l, "i64")
    }

    # Вид узла разрешён в скалярном подмножестве A1 (§9.3)?
    func ct_scalar_nk(var self, n: u32) -> bool
        requires n < 131072
        ensures true
    {
        let k: u32 = self.p.nk[n / 65536][n % 65536]
        if k >= 12 and k <= 18 and k != 13 {
            return true
        }
        if k == 13 or k == 22 or k == 23 or k == 24 or k == 25 or k == 26 {
            return true
        }
        if k == 32 or k == 33 or k == 37 or k == 39 or k == 40 or k == 41 or k == 49 {
            return true
        }
        # A2: индексация (44), массив-литерал (47), array-fill (48)
        if k == 44 or k == 47 or k == 48 {
            return true
        }
        if k == 6 or k == 7 or k == 8 or k == 9 or k == 10 {
            return true
        }
        if k == 27 {
            # имя типа: только скаляры (int и bool)
            if self.ct_cast_span(
                self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
            ) {
                return true
            }
            return self.span_is(
                self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536], "bool"
            )
        }
        if k == 28 {
            # A2: тип-массив [скаляр; N] — элемент обязан быть скалярным
            # именем типа (вложенные массивы 2D — вне яруса A)
            let e: u32 = self.p.nfc[n / 65536][n % 65536]
            if self.p.nk[e / 65536][e % 65536] != 27 {
                return false
            }
            if self.ct_cast_span(
                self.p.nss[e / 65536][e % 65536], self.p.nsl[e / 65536][e % 65536]
            ) {
                return true
            }
            return self.span_is(
                self.p.nss[e / 65536][e % 65536], self.p.nsl[e / 65536][e % 65536], "bool"
            )
        }
        return false
    }

    # Прямые свойства функции fi: нечистые вызовы (cimp) и нескалярные
    # конструкции (cnsc) — обход всего func-узла (параметры, контракты,
    # тело). extern и методы — негодны сразу.
    func ct_scan_func(var self, fi: u32)
        requires fi < 1024
        ensures true
    {
        let d: u32 = self.fnd[fi]
        if self.p.nk[d / 65536][d % 65536] == 50 {
            self.cimp = 1
            return
        }
        if self.fown[fi] != NONE {
            self.cnsc = 1
            return
        }
        var st: [u32; 128] = [0; 128]
        var sp: u32 = 1
        st[0] = d
        for _ in 0..131072 {
            if sp == 0 {
                break
            }
            sp = sp - 1
            let n: u32 = st[sp]
            let k: u32 = self.p.nk[n / 65536][n % 65536]
            if k != 6 and not self.ct_scalar_nk(n) {
                self.cnsc = 1
            } elif k == 41 and self.ct_axiom_span(
                self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
            ) {
                self.cimp = 1
            } else {
                var c: u32 = self.p.nfc[n / 65536][n % 65536]
                for _ in 0..131072 {
                    if c == NONE or sp >= 128 {
                        break
                    }
                    st[sp] = c
                    sp = sp + 1
                    c = self.p.nns[c / 65536][c % 65536]
                }
            }
        }
    }

    # Причина негодности подграфа вызовов от fi: DFS по рёбрам eg_*,
    # агрегация в cimp/cnsc (приоритет impure > nonscalar — независим
    # от порядка обхода, §9.3). cgen — поколение пометок cseen.
    func ct_reason(var self, fi: u32)
        requires fi < 1024
        ensures true
    {
        var st: [u32; 1024] = [0; 1024]
        var sp: u32 = 1
        st[0] = fi
        for _ in 0..1048576 {
            if sp == 0 {
                break
            }
            sp = sp - 1
            let f: u32 = st[sp]
            if self.cseen[f] != self.cgen {
                self.cseen[f] = self.cgen
                self.ct_scan_func(f)
                for i in 0..4096 {
                    if i >= self.neg {
                        break
                    }
                    if self.eg_c[i] == f and sp < 1024 {
                        st[sp] = self.eg_d[i]
                        sp = sp + 1
                    }
                }
            }
        }
    }

    # Годность значения const ci: каждое имя-вызов в значении обязано
    # быть годным (касты и неизвестные имена пропускаются — их судьбу
    # решает вычислитель теми же ошибками, что эталон).
    func ct_check_elig(var self, ci: u32)
        requires ci < 128
        ensures true
    {
        var st: [u32; 64] = [0; 64]
        var sp: u32 = 1
        let d: u32 = self.cnd[ci]
        st[0] = self.p.nns[self.p.nfc[d / 65536][d % 65536] / 65536][
            self.p.nfc[d / 65536][d % 65536] % 65536
        ]
        for _ in 0..131072 {
            if sp == 0 or self.failed {
                break
            }
            sp = sp - 1
            let n: u32 = st[sp]
            let k: u32 = self.p.nk[n / 65536][n % 65536]
            if k == 41 and not self.ct_cast_span(
                self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
            ) {
                let fi: u32 = self.find_func(
                    self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
                )
                if fi != NONE {
                    self.cgen = self.cgen + 1
                    self.cimp = 0
                    self.cnsc = 0
                    self.ct_reason(fi)
                    if self.cimp == 1 {
                        self.ct_fail(
                            "не comptime-годна: транзитивно вызывает аксиому ОС или extern (§5)"
                        )
                    } elif self.cnsc == 1 {
                        self.ct_fail("не comptime-годна: тело вне скалярного подмножества (ярус A)")
                    }
                }
            }
            var c: u32 = self.p.nfc[n / 65536][n % 65536]
            for _ in 0..64 {
                if c == NONE or sp >= 64 {
                    break
                }
                st[sp] = c
                sp = sp + 1
                c = self.p.nns[c / 65536][c % 65536]
            }
        }
    }

    # Драйвер фазы 3.5: годность всех отложенных (в порядке таблицы),
    # затем вычисление каждой (ленивые зависимости — инлайн машиной).
    func comptime_pass(var self)
        requires true
        ensures true
    {
        for ci in 0..128 {
            if ci >= self.ncon or self.failed {
                break
            }
            if self.cnd[ci] != NONE {
                self.ct_ci = ci
                self.ct_check_elig(ci)
            }
        }
        for ci in 0..128 {
            if ci >= self.ncon or self.failed {
                break
            }
            if self.cnd[ci] != NONE {
                self.ct_ci = ci
                self.ct_eval_const(ci)
            }
        }
    }

    # --- машина вычислителя (§9.6): задачи work-стека ---------------------
    # Типы задач: 0 CEXPR (const-выражение, без шагов, значения (s,m)),
    # 1 EXPR (+1 шаг, kind-значения), 2 STMT (+1 шаг), 3 BLOCK,
    # 4 CALLX (финиш кадра/ensures), 5 CRES (запись const), 6 REQX.

    func ct_wpush(var self, t: u32, n: u32, x: u64)
        requires true
        ensures true
    {
        if self.ncw >= 4096 {
            self.ct_fail("comptime: превышен предел шагов (предел 1000000)")
            return
        }
        self.cw_t[self.ncw] = t
        self.cw_n[self.ncw] = n
        self.cw_p[self.ncw] = 0
        self.cw_x[self.ncw] = x
        self.ncw = self.ncw + 1
    }

    func ct_vpush(var self, k: u32, u: u64, v: i64)
        requires true
        ensures true
    {
        if self.ncv >= 2048 {
            self.ct_fail("comptime: превышен предел шагов (предел 1000000)")
            return
        }
        self.cv_k[self.ncv] = k
        self.cv_u[self.ncv] = u
        self.cv_i[self.ncv] = v
        self.ncv = self.ncv + 1
    }

    # +1 шаг вычисления; за пределом бюджета — ошибка (§9.2).
    func ct_step_tick(var self)
        requires true
        ensures true
    {
        self.csteps = self.csteps + 1
        if self.csteps > 1000000 {
            self.ct_fail("comptime: превышен предел шагов (предел 1000000)")
        }
    }

    # Магнитуда минимума знакового вида (для edge-проверок MIN/(-1)).
    func ct_magmin(var self, ky: u32) -> u64
        requires true
        ensures true
    {
        if ky == 0 {
            return 2147483648
        }
        if ky == 14 {
            return 9223372036854775808
        }
        return 0
    }

    # Максимум беззнакового вида.
    func ct_maxu(var self, ky: u32) -> u64
        requires true
        ensures true
    {
        if ky == 2 {
            return 255
        }
        if ky == 12 {
            return 65535
        }
        if ky == 1 {
            return 4294967295
        }
        return 18446744073709551615
    }

    # trap «переполнение {kind}» (тексты кодогена, §9.1).
    func ct_tovf(var self, ky: u32)
        requires true
        ensures true
    {
        if ky == 0 {
            self.ct_fail("comptime: trap: переполнение i32")
        } elif ky == 1 {
            self.ct_fail("comptime: trap: переполнение u32")
        } elif ky == 2 {
            self.ct_fail("comptime: trap: переполнение u8")
        } elif ky == 12 {
            self.ct_fail("comptime: trap: переполнение u16")
        } elif ky == 13 {
            self.ct_fail("comptime: trap: переполнение u64")
        } else {
            self.ct_fail("comptime: trap: переполнение i64")
        }
    }

    # trap «сдвиг ≥ ширины {kind}» (только беззнаковые).
    func ct_tshf(var self, ky: u32)
        requires true
        ensures true
    {
        if ky == 2 {
            self.ct_fail("comptime: trap: сдвиг ≥ ширины u8")
        } elif ky == 12 {
            self.ct_fail("comptime: trap: сдвиг ≥ ширины u16")
        } elif ky == 1 {
            self.ct_fail("comptime: trap: сдвиг ≥ ширины u32")
        } else {
            self.ct_fail("comptime: trap: сдвиг ≥ ширины u64")
        }
    }

    # trap «переполнение при {target}()» (касты).
    func ct_tcast(var self, ky: u32)
        requires true
        ensures true
    {
        if ky == 0 {
            self.ct_fail("comptime: trap: переполнение при i32()")
        } elif ky == 1 {
            self.ct_fail("comptime: trap: переполнение при u32()")
        } elif ky == 2 {
            self.ct_fail("comptime: trap: переполнение при u8()")
        } elif ky == 12 {
            self.ct_fail("comptime: trap: переполнение при u16()")
        } elif ky == 13 {
            self.ct_fail("comptime: trap: переполнение при u64()")
        } else {
            self.ct_fail("comptime: trap: переполнение при i64()")
        }
    }

    # trap точки связывания «переполнение: {v} вне {kind} [{lo}, {hi}]»
    # (интерп-текст эталона: параметры вызова и запись const).
    func ct_tfit(var self, s: u32, m: u64, ky: u32)
        requires true
        ensures true
    {
        if ky == 2 {
            if s == 1 {
                self.ct_fail("comptime: trap: переполнение: -{m} вне u8 [0, 255]")
            } else {
                self.ct_fail("comptime: trap: переполнение: {m} вне u8 [0, 255]")
            }
        } elif ky == 12 {
            if s == 1 {
                self.ct_fail("comptime: trap: переполнение: -{m} вне u16 [0, 65535]")
            } else {
                self.ct_fail("comptime: trap: переполнение: {m} вне u16 [0, 65535]")
            }
        } elif ky == 1 {
            if s == 1 {
                self.ct_fail("comptime: trap: переполнение: -{m} вне u32 [0, 4294967295]")
            } else {
                self.ct_fail("comptime: trap: переполнение: {m} вне u32 [0, 4294967295]")
            }
        } elif ky == 13 {
            self.ct_fail("comptime: trap: переполнение: -{m} вне u64 [0, 18446744073709551615]")
        } elif ky == 0 {
            if s == 1 {
                self.ct_fail("comptime: trap: переполнение: -{m} вне i32 [-2147483648, 2147483647]")
            } else {
                self.ct_fail("comptime: trap: переполнение: {m} вне i32 [-2147483648, 2147483647]")
            }
        } else {
            let lo: i64 = -9223372036854775808
            let hi: i64 = 9223372036854775807
            if s == 1 {
                self.ct_fail("comptime: trap: переполнение: -{m} вне i64 [{lo}, {hi}]")
            } else {
                self.ct_fail("comptime: trap: переполнение: {m} вне i64 [{lo}, {hi}]")
            }
        }
    }

    # Запуск машины для const ci: CRES снизу, CEXPR значения сверху.
    # Драйвер — один ограниченный цикл; бюджет шагов срабатывает раньше
    # границы (машинных переходов ≤ 16 на шаг).
    func ct_eval_const(var self, ci: u32)
        requires ci < 128
        ensures true
    {
        self.ncw = 0
        self.ncv = 0
        self.ncg = 0
        self.ncl = 0
        self.ncq = 0
        self.csteps = 0
        self.nca = 0
        self.ncae = 0
        let d: u32 = self.cnd[ci] & 131071
        self.crs2[ci] = 1
        self.ct_wpush(5, ci, 0)
        let v: u32 = self.p.nns[self.p.nfc[d / 65536][d % 65536] / 65536][
            self.p.nfc[d / 65536][d % 65536] % 65536
        ]
        self.ct_wpush(0, v, u64(self.yk[self.cty[ci]]))
        for _ in 0..16000000 {
            if self.ncw == 0 or self.failed {
                break
            }
            self.ct_step()
        }
        if self.ncw != 0 and not self.failed {
            self.ct_fail("comptime: превышен предел шагов (предел 1000000)")
        }
    }

    func ct_step(var self)
        requires true
        ensures true
    {
        let i: u32 = (self.ncw - 1) & 4095
        let t: u32 = self.cw_t[i]
        if t == 0 {
            self.ct_cexpr(i)
        } elif t == 1 {
            self.ct_expr(i)
        } elif t == 2 {
            self.ct_stmt(i)
        } elif t == 3 {
            self.ct_block(i)
        } elif t == 4 {
            self.ct_callx(i)
        } elif t == 5 {
            self.ct_cres(i)
        } else {
            self.ct_reqx(i)
        }
    }

    # CEXPR: const-выражение (Python _const_eval_ct): значения в виде
    # (sign, mag) [cv_k = 99], операции фитятся к типу константы (ky в
    # cw_x), деление trunc, шаги не считаются.
    func ct_cexpr(var self, i: u32)
        requires i < 4096
        ensures true
    {
        let n: u32 = self.cw_n[i] & 131071
        let ph: u32 = self.cw_p[i]
        let ky: u32 = u32(self.cw_x[i] % 4294967296)
        let k: u32 = self.p.nk[n / 65536][n % 65536]
        if k == 32 {
            self.ct_vpush(99, self.p.mag(n), i64(self.p.ny[n / 65536][n % 65536]))
            self.ncw = i
        } elif k == 37 {
            self.ct_cx_name(i, n, ph)
        } elif k == 40 {
            self.ct_cx_un(i, n, ph, ky)
        } elif k == 39 {
            self.ct_cx_bin(i, n, ph, ky)
        } elif k == 41 {
            self.ct_cx_call(i, n, ph, ky)
        } else {
            self.ct_fail("comptime: trap: не константа")
        }
    }

    func ct_cx_name(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        let ci: u32 = self.find_const(
            self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
        )
        if ci == NONE {
            self.ct_fail("comptime: trap: не константа")
            return
        }
        if self.cnd[ci] != NONE {
            if ph == 1 or self.crs2[ci] == 1 {
                self.ct_fail("comptime: trap: цикл в comptime-константе")
                return
            }
            # ленивая резолюция: CRES + CEXPR значения, повтор фазой 1
            self.cw_p[i] = 1
            self.crs2[ci] = 1
            let d: u32 = self.cnd[ci] & 131071
            self.ct_wpush(5, ci, 0)
            let v: u32 = self.p.nns[self.p.nfc[d / 65536][d % 65536] / 65536][
                self.p.nfc[d / 65536][d % 65536] % 65536
            ]
            self.ct_wpush(0, v, u64(self.yk[self.cty[ci]]))
            return
        }
        self.ct_vpush(99, self.cvm[ci], i64(self.cvs[ci]))
        self.ncw = i
    }

    func ct_cx_un(var self, i: u32, n: u32, ph: u32, ky: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        if self.p.nx[n / 65536][n % 65536] != 15 {
            self.ct_fail("comptime: trap: не константа")
            return
        }
        if ph == 0 {
            self.cw_p[i] = 1
            self.ct_wpush(0, self.p.nfc[n / 65536][n % 65536], u64(ky))
            return
        }
        let j: u32 = (self.ncv - 1) & 2047
        if self.cv_u[j] != 0 {
            self.cv_i[j] = 1 - self.cv_i[j]
        }
        if not self.int_fits(self.cty[self.ct_ci & 127], u32(self.cv_i[j]), self.cv_u[j]) {
            self.ct_tovf(ky)
            return
        }
        self.ncw = i
    }

    func ct_cx_bin(var self, i: u32, n: u32, ph: u32, ky: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        let op: u32 = self.p.nx[n / 65536][n % 65536]
        if op < 10 or op > 14 {
            self.ct_fail("comptime: trap: не константа")
            return
        }
        if ph == 0 {
            self.cw_p[i] = 1
            self.ct_wpush(0, self.p.nfc[n / 65536][n % 65536], u64(ky))
            return
        }
        if ph == 1 {
            self.cw_p[i] = 2
            let c: u32 = self.p.nfc[n / 65536][n % 65536]
            self.ct_wpush(0, self.p.nns[c / 65536][c % 65536], u64(ky))
            return
        }
        self.ncv = self.ncv - 1
        let j: u32 = (self.ncv - 1) & 2047
        let s1: u32 = u32(self.cv_i[j])
        let m1: u64 = self.cv_u[j]
        let s2: u32 = u32(self.cv_i[self.ncv & 2047])
        let m2: u64 = self.cv_u[self.ncv & 2047]
        self.ct_cx_arith(op, s1, m1, s2, m2)
        if not self.failed {
            self.cv_i[j] = i64(self.ces)
            self.cv_u[j] = self.cem
            self.ncw = i
        }
    }

    # Арифметика const-выражений в (sign, mag): +,-,* фитятся к типу
    # константы (ярус A, §9.2), /,% — trunc без фита (финал — CRES);
    # результат в ces/cem. ky берётся из типа текущей const.
    func ct_cx_arith(var self, op: u32, s1: u32, m1: u64, s2: u32, m2: u64)
        requires op >= 10 and op <= 14
        ensures true
    {
        let ky: u32 = self.yk[self.cty[self.ct_ci & 127]]
        if op == 10 or op == 11 {
            var t2: u32 = s2
            if op == 11 and m2 != 0 {
                t2 = 1 - s2
            }
            self.ct_cx_add(ky, s1, m1, t2, m2)
        } elif op == 12 {
            if m1 != 0 and m2 > 18446744073709551615 / m1 {
                self.ct_tovf(ky)
                return
            }
            self.cem = m1 * m2
            self.ces = 0
            if self.cem != 0 and s1 != s2 {
                self.ces = 1
            }
            if not self.int_fits(self.cty[self.ct_ci & 127], self.ces, self.cem) {
                self.ct_tovf(ky)
            }
        } elif m2 == 0 {
            self.ct_fail("comptime: trap: деление на ноль")
        } elif ((ky == 0 or ky == 14)
                and s1 == 1 and m1 == self.ct_magmin(ky) and s2 == 1 and m2 == 1) {
            self.ct_tovf(ky)
        } elif op == 13 {
            let q: u64 = m1 / m2
            self.cem = q
            self.ces = 0
            if q != 0 and s1 != s2 {
                self.ces = 1
            }
        } else {
            let r: u64 = m1 % m2
            self.cem = r
            self.ces = 0
            if r != 0 {
                self.ces = s1
            }
        }
    }

    func ct_cx_add(var self, ky: u32, s1: u32, m1: u64, s2: u32, m2: u64)
        requires true
        ensures true
    {
        if s1 == s2 {
            if m1 > 18446744073709551615 - m2 {
                self.ct_tovf(ky)
                return
            }
            self.ces = s1
            self.cem = m1 + m2
        } elif m1 >= m2 {
            self.ces = s1
            self.cem = m1 - m2
        } else {
            self.ces = s2
            self.cem = m2 - m1
        }
        if self.cem == 0 {
            self.ces = 0
        }
        if not self.int_fits(self.cty[self.ct_ci & 127], self.ces, self.cem) {
            self.ct_tovf(ky)
        }
    }

    # CEXPR-вызов: каст (фаза 10) или пользовательская функция —
    # аргументы CEXPR'ами, кадр, конверсия результата в (s, m) (фаза 90).
    func ct_cx_call(var self, i: u32, n: u32, ph: u32, ky: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        let a: u32 = self.p.nss[n / 65536][n % 65536]
        let l: u32 = self.p.nsl[n / 65536][n % 65536]
        if ph == 0 {
            if self.ct_cast_span(a, l) {
                self.cw_p[i] = 10
                self.ct_wpush(0, self.p.nfc[n / 65536][n % 65536], u64(ky))
                return
            }
            if self.find_func(a, l) == NONE {
                self.ct_fail("comptime: trap: неизвестная функция")
                return
            }
            self.cw_p[i] = 1
            self.cw_x[i] = (u64(ky) * 4294967296) + u64(self.p.nfc[n / 65536][n % 65536])
            return
        }
        if ph == 1 {
            let cur: u32 = u32(self.cw_x[i] % 4294967296)
            if cur != NONE {
                self.cw_x[i] = (u64(ky) * 4294967296) + u64(self.p.nns[cur / 65536][cur % 65536])
                self.ct_wpush(0, cur, u64(ky))
                return
            }
            self.cw_p[i] = 90
            self.ct_enter_frame(self.find_func(a, l), 1)
            return
        }
        if ph == 10 {
            # каст: значение (s, m) сверяется с диапазоном типа-имени
            let j: u32 = (self.ncv - 1) & 2047
            let tk: u32 = self.ct_span_kind(a, l)
            if not self.int_fits(
                self.intern(tk, NONE, NONE, NONE, 0), u32(self.cv_i[j]), self.cv_u[j]
            ) {
                self.ct_tcast(tk)
                return
            }
            self.ncw = i
            return
        }
        # фаза 90: результат кадра (kind-вид) -> (sign, mag)
        let j2: u32 = (self.ncv - 1) & 2047
        self.ct_k2sm(j2)
        self.ncw = i
    }

    # yk-код по спану имени скалярного типа.
    func ct_span_kind(var self, a: u32, l: u32) -> u32
        requires true
        ensures true
    {
        if self.span_is(a, l, "i32") {
            return 0
        }
        if self.span_is(a, l, "u32") {
            return 1
        }
        if self.span_is(a, l, "u8") {
            return 2
        }
        if self.span_is(a, l, "u16") {
            return 12
        }
        if self.span_is(a, l, "u64") {
            return 13
        }
        return 14
    }

    # kind-значение слота j -> (sign, mag) [cv_k 99].
    func ct_k2sm(var self, j: u32)
        requires j < 2048
        ensures true
    {
        let k: u32 = self.cv_k[j]
        if k == 0 or k == 14 {
            if self.cv_i[j] < 0 {
                # магнитуда MIN без переполнения: -(v + 1) + 1
                let t: i64 = 0 - (self.cv_i[j] + 1)
                self.cv_u[j] = u64(t) + 1
                self.cv_i[j] = 1
            } else {
                self.cv_u[j] = u64(self.cv_i[j])
                self.cv_i[j] = 0
            }
        } else {
            self.cv_i[j] = 0
        }
        self.cv_k[j] = 99
    }

    # (sign, mag) слота j -> kind-вид ky с фитом точки связывания
    # (интерп-текст) — параметры вызова из const-выражений.
    func ct_sm2k(var self, j: u32, ky: u32)
        requires j < 2048
        ensures true
    {
        if self.cv_k[j] != 99 {
            return
        }
        let s: u32 = u32(self.cv_i[j])
        let m: u64 = self.cv_u[j]
        if not self.int_fits(self.intern(ky, NONE, NONE, NONE, 0), s, m) {
            self.ct_tfit(s, m, ky)
            return
        }
        self.cv_k[j] = ky
        if ky == 0 or ky == 14 {
            if s == 1 {
                let t: i64 = 0 - i64(m - 1)
                self.cv_i[j] = t - 1
            } else {
                self.cv_i[j] = i64(m)
            }
        }
    }

    # Вход в кадр вызова fi: биндинг аргументов в локали, requires,
    # тело; fresh-бюджет на верхнеуровневом вызове (§9.2).
    func ct_enter_frame(var self, fi: u32, from_cx: u32)
        requires fi < 1024
        ensures true
    {
        if self.ncg >= 64 {
            self.ct_fail("comptime: превышена глубина вызовов (предел 64)")
            return
        }
        if self.fret[fi] == NONE and from_cx == 1 {
            self.ct_fail("comptime: trap: функция ничего не возвращает — это не значение")
            return
        }
        if self.ncg == 0 {
            self.csteps = 0
        }
        let argc: u32 = self.fpc[fi]
        let g: u32 = self.ncg
        self.cg_f[g] = fi
        self.cg_vb[g] = self.ncv - argc
        self.cg_lb[g] = self.ncl
        self.cg_qb[g] = self.ncq
        self.cg_rk[g] = NONE
        # параметры: значения аргументов (v-стек) -> локали кадра
        for j in 0..64 {
            if j >= argc or self.failed {
                break
            }
            let pj: u32 = (self.fps[fi] + j) & 1023
            let vj: u32 = (self.cg_vb[g] + j) & 2047
            self.ct_sm2k(vj, self.yk[self.pty[pj]])
            if not self.failed {
                self.ct_lpush(self.pn_s[pj], self.pn_l[pj], vj)
            }
        }
        if self.failed {
            return
        }
        self.ncv = self.cg_vb[g]
        self.ncg = g + 1
        let d: u32 = self.fnd[fi] & 131071
        self.cg_wb[g] = self.ncw
        self.ct_wpush(4, fi, 0)
        var c: u32 = self.p.nfc[d / 65536][d % 65536]
        var req: u32 = NONE
        var body: u32 = NONE
        for _ in 0..64 {
            if c == NONE {
                break
            }
            let ck: u32 = self.p.nk[c / 65536][c % 65536]
            if ck == 9 {
                req = self.p.nfc[c / 65536][c % 65536]
            } elif ck == 12 {
                body = c
            }
            c = self.p.nns[c / 65536][c % 65536]
        }
        if body != NONE {
            self.ct_wpush(3, body, 0)
        }
        if req != NONE and not self.ct_trivial_true(req) {
            self.ct_wpush(6, fi, 0)
            self.ct_wpush(1, req, 0)
        }
    }

    # requires true / ensures true — тривиальный контракт (0 шагов).
    func ct_trivial_true(var self, n: u32) -> bool
        requires n < 131072
        ensures true
    {
        if self.p.nk[n / 65536][n % 65536] != 33 {
            return false
        }
        return self.p.nx[n / 65536][n % 65536] == 1
    }

    # Локаль кадра из значения-слота vj.
    func ct_lpush(var self, a: u32, l: u32, vj: u32)
        requires vj < 2048
        ensures true
    {
        if self.ncl >= 4480 {
            self.ct_fail("comptime: превышена глубина вызовов (предел 64)")
            return
        }
        var uu: u64 = self.cv_u[vj]
        if self.cv_k[vj] == 7 {
            # значение-массив на связывании (let/параметр) — глубокая копия
            let nid: u32 = self.ct_arr_copy(u32(uu))
            if self.failed {
                return
            }
            uu = u64(nid)
        }
        self.cl_s[self.ncl] = a
        self.cl_l[self.ncl] = l
        self.cl_k[self.ncl] = self.cv_k[vj]
        self.cl_u[self.ncl] = uu
        self.cl_i[self.ncl] = self.cv_i[vj]
        self.ncl = self.ncl + 1
    }

    # REQX: значение requires вычислено — false намертво.
    func ct_reqx(var self, i: u32)
        requires i < 4096
        ensures true
    {
        self.ncv = self.ncv - 1
        if self.cv_u[self.ncv & 2047] == 0 {
            self.ct_fail("comptime: trap: нарушен requires функции")
            return
        }
        self.ncw = i
    }

    # CALLX: финиш кадра — ensures (с локалью result), результат на
    # v-стек вызывающего, снятие кадра.
    func ct_callx(var self, i: u32)
        requires i < 4096
        ensures true
    {
        let fi: u32 = self.cw_n[i] & 1023
        let g: u32 = (self.ncg - 1) & 63
        if self.cw_p[i] == 0 {
            let d: u32 = self.fnd[fi] & 131071
            var ens: u32 = NONE
            var c: u32 = self.p.nfc[d / 65536][d % 65536]
            for _ in 0..64 {
                if c == NONE {
                    break
                }
                if self.p.nk[c / 65536][c % 65536] == 10 {
                    ens = self.p.nfc[c / 65536][c % 65536]
                }
                c = self.p.nns[c / 65536][c % 65536]
            }
            if ens != NONE and not self.ct_trivial_true(ens) {
                if self.fret[fi] != NONE and self.cg_rk[g] != NONE {
                    # локаль result для ensures
                    if self.ncl < 4480 {
                        self.cl_s[self.ncl] = self.bn_res
                        self.cl_l[self.ncl] = 6
                        self.cl_k[self.ncl] = self.cg_rk[g]
                        self.cl_u[self.ncl] = self.cg_ru[g]
                        self.cl_i[self.ncl] = self.cg_ri[g]
                        self.ncl = self.ncl + 1
                    }
                }
                self.cw_p[i] = 1
                self.ct_wpush(1, ens, 0)
                return
            }
        } else {
            self.ncv = self.ncv - 1
            if self.cv_u[self.ncv & 2047] == 0 {
                self.ct_fail("comptime: trap: нарушен ensures функции")
                return
            }
        }
        self.ncl = self.cg_lb[g]
        self.ncq = self.cg_qb[g]
        self.ncv = self.cg_vb[g]
        if self.fret[fi] != NONE {
            self.ct_vpush(self.cg_rk[g], self.cg_ru[g], self.cg_ri[g])
        }
        self.ncg = g
        self.ncw = i
    }

    # CRES: запись вычисленного значения в const ci (финальный фит —
    # интерп-текст точки связывания).
    func ct_cres(var self, i: u32)
        requires i < 4096
        ensures true
    {
        let ci: u32 = self.cw_n[i] & 127
        self.ncv = self.ncv - 1
        let j: u32 = self.ncv & 2047
        if self.yk[self.cty[ci]] == 7 {
            # A2: значение-массив -> постоянное хранилище (для Ir)
            self.ct_store_arr_const(ci, u32(self.cv_u[j]))
            self.cnd[ci] = NONE
            self.crs2[ci] = 0
            self.ncw = i
            return
        }
        let s: u32 = u32(self.cv_i[j])
        let m: u64 = self.cv_u[j]
        if not self.int_fits(self.cty[ci], s, m) {
            self.ct_tfit(s, m, self.yk[self.cty[ci]])
            return
        }
        self.cvs[ci] = s
        self.cvm[ci] = m
        self.cnd[ci] = NONE
        self.crs2[ci] = 0
        self.ncw = i
    }

    # A2: скопировать итоговый массив aid из транзитивной кучи в
    # постоянное хранилище констант (cca), база -> cca_bs[ci].
    func ct_store_arr_const(var self, ci: u32, aid: u32)
        requires ci < 128
        ensures true
    {
        let ln: u32 = self.ca_ln[aid & 511]
        if self.ncca + ln > 4096 {
            self.ct_fail("comptime: превышен предел шагов (предел 1000000)")
            return
        }
        let sb: u32 = self.ca_bs[aid & 511]
        let db: u32 = self.ncca
        self.cca_bs[ci] = db
        for q in 0..4096 {
            if q >= ln {
                break
            }
            self.cca_u[(db + q) & 4095] = self.ca_eu[(sb + q) & 4095]
            self.cca_i[(db + q) & 4095] = self.ca_ei[(sb + q) & 4095]
        }
        self.ncca = self.ncca + ln
    }

    # BLOCK: последовательность инструкций со своей базой локалей
    # (cw_x: base * 2^32 + курсор-узел).
    func ct_block(var self, i: u32)
        requires i < 4096
        ensures true
    {
        let n: u32 = self.cw_n[i] & 131071
        if self.cw_p[i] == 0 {
            self.cw_p[i] = 1
            self.cw_x[i] = (u64(self.ncl) * 4294967296) + u64(self.p.nfc[n / 65536][n % 65536])
            return
        }
        let cur: u32 = u32(self.cw_x[i] % 4294967296)
        if cur != NONE {
            self.cw_x[i] = (self.cw_x[i] / 4294967296) * 4294967296 + u64(
                self.p.nns[cur / 65536][cur % 65536]
            )
            self.ct_wpush(2, cur, 0)
            return
        }
        self.ncl = u32(self.cw_x[i] / 4294967296)
        self.ncw = i
    }

    # Поиск локали кадра по спану (сверху вниз — шэдоуинг).
    func ct_lfind(var self, a: u32, l: u32) -> u32
        requires true
        ensures true
    {
        let base: u32 = self.cg_lb[(self.ncg - 1) & 63]
        var j: u32 = self.ncl
        var found: u32 = NONE
        for _ in 0..4480 {
            if j == base or found != NONE {
                break
            }
            j = j - 1
            if self.span_eq(self.cl_s[j & 4479], self.cl_l[j & 4479], a, l) {
                found = j
            }
        }
        return found
    }

    # EXPR: выражение в теле (+1 шаг на входе, kind-значения).
    func ct_expr(var self, i: u32)
        requires i < 4096
        ensures true
    {
        let n: u32 = self.cw_n[i] & 131071
        let ph: u32 = self.cw_p[i]
        let k: u32 = self.p.nk[n / 65536][n % 65536]
        if ph == 0 {
            self.ct_step_tick()
            if self.failed {
                return
            }
        }
        if k == 32 {
            let ky: u32 = self.yk[self.nty[n / 65536][n % 65536]]
            let m: u64 = self.p.mag(n)
            if ky == 0 or ky == 14 {
                # знак литерала — в ny (парсер сворачивает минус)
                if self.p.ny[n / 65536][n % 65536] == 1 {
                    if m == 0 {
                        self.ct_vpush(ky, 0, 0)
                    } else {
                        let t: i64 = 0 - i64(m - 1)
                        self.ct_vpush(ky, 0, t - 1)
                    }
                } elif m > 9223372036854775807 {
                    self.ct_fail("comptime: trap: не константа")
                    return
                } else {
                    self.ct_vpush(ky, 0, i64(m))
                }
            } else {
                self.ct_vpush(ky, m, 0)
            }
            self.ncw = i
        } elif k == 33 {
            self.ct_vpush(3, u64(self.p.nx[n / 65536][n % 65536]), 0)
            self.ncw = i
        } elif k == 37 {
            self.ct_e_name(i, n, ph)
        } elif k == 39 {
            self.ct_e_bin(i, n, ph)
        } elif k == 40 {
            self.ct_e_un(i, n, ph)
        } elif k == 41 {
            self.ct_e_call(i, n, ph)
        } elif k == 44 {
            self.ct_e_index(i, n, ph)
        } elif k == 47 {
            self.ct_e_alit(i, n, ph)
        } elif k == 48 {
            self.ct_e_afill(i, n, ph)
        } else {
            self.ct_fail("comptime: trap: не константа")
        }
    }

    func ct_e_name(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        let a: u32 = self.p.nss[n / 65536][n % 65536]
        let l: u32 = self.p.nsl[n / 65536][n % 65536]
        let sl: u32 = self.ct_lfind(a, l)
        if sl != NONE {
            self.ct_vpush(self.cl_k[sl & 4479], self.cl_u[sl & 4479], self.cl_i[sl & 4479])
            self.ncw = i
            return
        }
        let ci: u32 = self.find_const(a, l)
        if ci == NONE {
            self.ct_fail("comptime: trap: не константа")
            return
        }
        if self.cnd[ci] != NONE {
            if ph == 1 or self.crs2[ci] == 1 {
                self.ct_fail("comptime: trap: цикл в comptime-константе")
                return
            }
            self.cw_p[i] = 1
            self.crs2[ci] = 1
            let d: u32 = self.cnd[ci] & 131071
            self.ct_wpush(5, ci, 0)
            let v: u32 = self.p.nns[self.p.nfc[d / 65536][d % 65536] / 65536][
                self.p.nfc[d / 65536][d % 65536] % 65536
            ]
            self.ct_wpush(0, v, u64(self.yk[self.cty[ci]]))
            return
        }
        if self.yk[self.cty[ci]] == 7 {
            # A2: массив-константа -> копия в транзитивную кучу, ref
            let id: u32 = self.ct_arr_from_const(ci)
            if self.failed {
                return
            }
            self.ct_vpush(7, u64(id), i64(self.ca_ek[id & 511]))
            self.ncw = i
            return
        }
        # значение const -> kind-вид (в диапазоне своего типа)
        self.ct_vpush(99, self.cvm[ci], i64(self.cvs[ci]))
        self.ct_sm2k((self.ncv - 1) & 2047, self.yk[self.cty[ci]])
        self.ncw = i
    }

    # A2: развернуть массив-константу ci из постоянного хранилища в
    # транзитивную кучу вычислителя -> id (ссылка на копию).
    func ct_arr_from_const(var self, ci: u32) -> u32
        requires ci < 128
        ensures true
    {
        let ty: u32 = self.cty[ci]
        let ln: u32 = self.yb[ty]
        let id: u32 = self.ct_arr_alloc(self.yk[self.ya[ty]], ln)
        if id == NONE {
            return NONE
        }
        let sb: u32 = self.cca_bs[ci & 127]
        let db: u32 = self.ca_bs[id & 511]
        for q in 0..4096 {
            if q >= ln {
                break
            }
            self.ca_eu[(db + q) & 4095] = self.cca_u[(sb + q) & 4095]
            self.ca_ei[(db + q) & 4095] = self.cca_i[(sb + q) & 4095]
        }
        return id
    }

    func ct_e_bin(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        let op: u32 = self.p.nx[n / 65536][n % 65536]
        let c: u32 = self.p.nfc[n / 65536][n % 65536]
        if op == 1 or op == 2 {
            # ленивые or/and: правый — только при необходимости
            if ph == 0 {
                self.cw_p[i] = 1
                self.ct_wpush(1, c, 0)
                return
            }
            if ph == 1 {
                let b: u64 = self.cv_u[(self.ncv - 1) & 2047]
                if (op == 2 and b == 0) or (op == 1 and b != 0) {
                    self.ncw = i
                    return
                }
                self.ncv = self.ncv - 1
                self.cw_p[i] = 2
                self.ct_wpush(1, self.p.nns[c / 65536][c % 65536], 0)
                return
            }
            self.ncw = i
            return
        }
        if ph == 0 {
            self.cw_p[i] = 1
            self.ct_wpush(1, c, 0)
            return
        }
        if ph == 1 {
            self.cw_p[i] = 2
            self.ct_wpush(1, self.p.nns[c / 65536][c % 65536], 0)
            return
        }
        self.ct_e_arith(op)
        if not self.failed {
            self.ncw = i
        }
    }

    # Бинарная операция тел над kind-значениями: [ncv-2] op [ncv-1] ->
    # [ncv-2]; сравнения дают bool.
    func ct_e_arith(var self, op: u32)
        requires true
        ensures true
    {
        self.ncv = self.ncv - 1
        let j: u32 = (self.ncv - 1) & 2047
        let jr: u32 = self.ncv & 2047
        let ky: u32 = self.cv_k[j]
        if op >= 4 and op <= 9 {
            self.ct_acmp(op, j, jr)
            return
        }
        if op >= 16 and op <= 18 {
            if op == 16 {
                self.cv_u[j] = self.cv_u[j] | self.cv_u[jr]
            } elif op == 17 {
                self.cv_u[j] = self.cv_u[j] ^ self.cv_u[jr]
            } else {
                self.cv_u[j] = self.cv_u[j] & self.cv_u[jr]
            }
            return
        }
        if op == 19 or op == 20 {
            var w: u64 = 32
            if ky == 2 {
                w = 8
            } elif ky == 12 {
                w = 16
            } elif ky == 13 {
                w = 64
            }
            let r: u64 = self.cv_u[jr]
            if r >= w {
                self.ct_tshf(ky)
                return
            }
            if op == 19 {
                # усечение по ширине без выноса из u64 (маска до сдвига)
                self.cv_u[j] = (self.cv_u[j] & (self.ct_maxu(ky) >> r)) << r
            } else {
                self.cv_u[j] = self.cv_u[j] >> r
            }
            return
        }
        if ky == 0 or ky == 14 {
            self.ct_ai(op, ky, j, jr)
        } else {
            self.ct_au(op, ky, j, jr)
        }
    }

    func ct_acmp(var self, op: u32, j: u32, jr: u32)
        requires j < 2048 and jr < 2048
        ensures true
    {
        let ky: u32 = self.cv_k[j]
        var r: bool = false
        if ky == 0 or ky == 14 {
            let a: i64 = self.cv_i[j]
            let b: i64 = self.cv_i[jr]
            if op == 4 { r = a == b
            } elif op == 5 { r = a != b
            } elif op == 6 { r = a < b
            } elif op == 7 { r = a <= b
            } elif op == 8 { r = a > b
            } else { r = a >= b }
        } else {
            let c: u64 = self.cv_u[j]
            let d: u64 = self.cv_u[jr]
            if op == 4 { r = c == d
            } elif op == 5 { r = c != d
            } elif op == 6 { r = c < d
            } elif op == 7 { r = c <= d
            } elif op == 8 { r = c > d
            } else { r = c >= d }
        }
        self.cv_k[j] = 3
        self.cv_u[j] = 0
        if r {
            self.cv_u[j] = 1
        }
        self.cv_i[j] = 0
    }

    # Беззнаковая арифметика с пре-проверками переполнения (§9.1).
    func ct_au(var self, op: u32, ky: u32, j: u32, jr: u32)
        requires j < 2048 and jr < 2048
        ensures true
    {
        let a: u64 = self.cv_u[j]
        let b: u64 = self.cv_u[jr]
        let mx: u64 = self.ct_maxu(ky)
        if op == 10 {
            if a > mx - b {
                self.ct_tovf(ky)
                return
            }
            self.cv_u[j] = a + b
        } elif op == 11 {
            if a < b {
                self.ct_tovf(ky)
                return
            }
            self.cv_u[j] = a - b
        } elif op == 12 {
            if a != 0 and b > mx / a {
                self.ct_tovf(ky)
                return
            }
            self.cv_u[j] = a * b
        } elif b == 0 {
            self.ct_fail("comptime: trap: деление на ноль")
        } elif op == 13 {
            self.cv_u[j] = a / b
        } else {
            self.cv_u[j] = a % b
        }
    }

    # Знаковая арифметика: i32 — вычисление в i64 + проверка диапазона;
    # i64 — классические пре-проверки без выхода из i64.
    func ct_ai(var self, op: u32, ky: u32, j: u32, jr: u32)
        requires j < 2048 and jr < 2048
        ensures true
    {
        let a: i64 = self.cv_i[j]
        let b: i64 = self.cv_i[jr]
        if op == 13 or op == 14 {
            if b == 0 {
                self.ct_fail("comptime: trap: деление на ноль")
                return
            }
            var mn: i64 = -2147483648
            if ky == 14 {
                mn = -9223372036854775808
            }
            if a == mn and b == -1 {
                self.ct_tovf(ky)
                return
            }
            if op == 13 {
                self.cv_i[j] = a / b
            } else {
                self.cv_i[j] = a % b
            }
            return
        }
        if ky == 0 {
            let r: i64 = self.ct_i32op(op, a, b)
            if r > 2147483647 or r < -2147483648 {
                self.ct_tovf(0)
                return
            }
            self.cv_i[j] = r
            return
        }
        self.ct_i64op(op, j, a, b)
    }

    func ct_i32op(var self, op: u32, a: i64, b: i64) -> i64
        requires true
        ensures true
    {
        if op == 10 {
            return a + b
        }
        if op == 11 {
            return a - b
        }
        return a * b
    }

    func ct_i64op(var self, op: u32, j: u32, a: i64, b: i64)
        requires j < 2048
        ensures true
    {
        if op == 10 {
            if (b > 0 and a > 9223372036854775807 - b) or (b < 0 and a < -9223372036854775808 - b) {
                self.ct_tovf(14)
                return
            }
            self.cv_i[j] = a + b
        } elif op == 11 {
            if (b < 0 and a > 9223372036854775807 + b) or (b > 0 and a < -9223372036854775808 + b) {
                self.ct_tovf(14)
                return
            }
            self.cv_i[j] = a - b
        } else {
            if a > 0 and b > 0 and a > 9223372036854775807 / b {
                self.ct_tovf(14)
                return
            }
            if a > 0 and b < 0 and b < -9223372036854775808 / a {
                self.ct_tovf(14)
                return
            }
            if a < 0 and b > 0 and a < -9223372036854775808 / b {
                self.ct_tovf(14)
                return
            }
            if a < 0 and b < 0 and b < 9223372036854775807 / a {
                self.ct_tovf(14)
                return
            }
            self.cv_i[j] = a * b
        }
    }

    func ct_e_un(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        let op: u32 = self.p.nx[n / 65536][n % 65536]
        let c: u32 = self.p.nfc[n / 65536][n % 65536]
        if ph == 0 {
            if op == 15 and self.p.nk[c / 65536][c % 65536] == 32 {
                # слитно «минус-литерал»: +1 шаг за литерал, магнитуда
                # MIN выразима через -(m - 1) - 1
                self.ct_step_tick()
                if self.failed {
                    return
                }
                let ky: u32 = self.yk[self.nty[n / 65536][n % 65536]]
                let m: u64 = self.p.mag(c)
                if m == 0 {
                    self.ct_vpush(ky, 0, 0)
                } else {
                    let t: i64 = 0 - i64(m - 1)
                    self.ct_vpush(ky, 0, t - 1)
                }
                self.ncw = i
                return
            }
            self.cw_p[i] = 1
            self.ct_wpush(1, c, 0)
            return
        }
        let j: u32 = (self.ncv - 1) & 2047
        let ky2: u32 = self.cv_k[j]
        if op == 3 {
            self.cv_u[j] = 1 - self.cv_u[j]
        } elif op == 21 {
            self.cv_u[j] = self.cv_u[j] ^ self.ct_maxu(ky2)
        } elif ky2 == 0 or ky2 == 14 {
            var mn: i64 = -2147483648
            if ky2 == 14 {
                mn = -9223372036854775808
            }
            if self.cv_i[j] == mn {
                self.ct_tovf(ky2)
                return
            }
            let z: i64 = 0 - self.cv_i[j]
            self.cv_i[j] = z
        } elif self.cv_u[j] != 0 {
            self.ct_tovf(ky2)
            return
        }
        self.ncw = i
    }

    func ct_e_call(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        let a: u32 = self.p.nss[n / 65536][n % 65536]
        let l: u32 = self.p.nsl[n / 65536][n % 65536]
        if ph == 0 {
            if self.ct_cast_span(a, l) {
                self.cw_p[i] = 10
                self.ct_wpush(1, self.p.nfc[n / 65536][n % 65536], 0)
                return
            }
            if self.find_func(a, l) == NONE {
                self.ct_fail("comptime: trap: неизвестная функция")
                return
            }
            self.cw_p[i] = 1
            self.cw_x[i] = u64(self.p.nfc[n / 65536][n % 65536])
            return
        }
        if ph == 1 {
            let cur: u32 = u32(self.cw_x[i] % 4294967296)
            if cur != NONE {
                self.cw_x[i] = u64(self.p.nns[cur / 65536][cur % 65536])
                self.ct_wpush(1, cur, 0)
                return
            }
            self.cw_p[i] = 90
            self.ct_enter_frame(self.find_func(a, l), 0)
            return
        }
        if ph == 10 {
            self.ct_e_cast((self.ncv - 1) & 2047, self.ct_span_kind(a, l))
            if not self.failed {
                self.ncw = i
            }
            return
        }
        self.ncw = i
    }

    # Каст kind-значения к целевому виду tk: чек диапазона по
    # математическому значению, тексты кодогена.
    func ct_e_cast(var self, j: u32, tk: u32)
        requires j < 2048
        ensures true
    {
        let sk: u32 = self.cv_k[j]
        if sk == 0 or sk == 14 {
            let v: i64 = self.cv_i[j]
            if v < 0 {
                if tk == 0 {
                    if v < -2147483648 {
                        self.ct_tcast(tk)
                        return
                    }
                } elif tk != 14 {
                    self.ct_tcast(tk)
                    return
                }
                self.cv_k[j] = tk
                return
            }
            self.cv_u[j] = u64(v)
        }
        let u: u64 = self.cv_u[j]
        if tk == 0 {
            if u > 2147483647 {
                self.ct_tcast(tk)
                return
            }
            self.cv_i[j] = i64(u)
        } elif tk == 14 {
            if u > 9223372036854775807 {
                self.ct_tcast(tk)
                return
            }
            self.cv_i[j] = i64(u)
        } elif u > self.ct_maxu(tk) {
            self.ct_tcast(tk)
            return
        }
        self.cv_k[j] = tk
    }

    # --- ярус A2: куча массивов вычислителя --------------------------------

    # Выделить массив (kind элемента ek, длина ln) -> id; переполнение
    # кучи -> ошибка класса «бюджет» (капасити, как SPEC §6).
    func ct_arr_alloc(var self, ek: u32, ln: u32) -> u32
        requires true
        ensures true
    {
        if self.nca >= 512 or self.ncae + ln > 4096 {
            self.ct_fail("comptime: превышен предел шагов (предел 1000000)")
            return NONE
        }
        let id: u32 = self.nca
        self.ca_ek[id] = ek
        self.ca_ln[id] = ln
        self.ca_bs[id] = self.ncae
        self.ncae = self.ncae + ln
        self.nca = self.nca + 1
        return id
    }

    # Глубокая копия массива src -> новый id (значение-семантика на
    # связывании let/параметра/присваивания целого массива).
    func ct_arr_copy(var self, src: u32) -> u32
        requires true
        ensures true
    {
        let id: u32 = self.ct_arr_alloc(self.ca_ek[src & 511], self.ca_ln[src & 511])
        if id == NONE {
            return NONE
        }
        let sb: u32 = self.ca_bs[src & 511]
        let db: u32 = self.ca_bs[id & 511]
        let ln: u32 = self.ca_ln[src & 511]
        for j in 0..4096 {
            if j >= ln {
                break
            }
            self.ca_eu[(db + j) & 4095] = self.ca_eu[(sb + j) & 4095]
            self.ca_ei[(db + j) & 4095] = self.ca_ei[(sb + j) & 4095]
        }
        return id
    }

    # INDEX (44): obj[index]. Python — eval(obj), eval(index), проверка
    # границ, элемент. Значение-массив obj: cv_k = 7, cv_u = id.
    func ct_e_index(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        let c: u32 = self.p.nfc[n / 65536][n % 65536]
        if ph == 0 {
            self.cw_p[i] = 1
            self.ct_wpush(1, c, 0)
            return
        }
        if ph == 1 {
            self.cw_p[i] = 2
            self.ct_wpush(1, self.p.nns[c / 65536][c % 65536], 0)
            return
        }
        let jx: u32 = (self.ncv - 1) & 2047
        let jo: u32 = (self.ncv - 2) & 2047
        let aid: u32 = u32(self.cv_u[jo])
        var idx: i64 = self.cv_i[jx]
        let kk: u32 = self.cv_k[jx]
        if kk != 0 and kk != 14 {
            idx = i64(self.cv_u[jx])
        }
        if idx < 0 or idx >= i64(self.ca_ln[aid & 511]) {
            self.ct_fail("comptime: trap: индекс вне границ")
            return
        }
        let sl: u32 = (self.ca_bs[aid & 511] + u32(idx)) & 4095
        self.ncv = self.ncv - 2
        self.ct_vpush(self.ca_ek[aid & 511], self.ca_eu[sl], self.ca_ei[sl])
        self.ncw = i
    }

    # ARRAYLIT (47): [e0, e1, ...]. Каждый элемент — eval (+1 шаг),
    # затем сборка массива. cw_x = cnt * 2^32 + курсор-ребёнок.
    func ct_e_alit(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        if ph == 0 {
            self.cw_x[i] = u64(self.nchildren(n)) * 4294967296 + u64(
                self.p.nfc[n / 65536][n % 65536]
            )
            self.cw_p[i] = 1
            return
        }
        let cur: u32 = u32(self.cw_x[i] % 4294967296)
        if cur != NONE {
            self.cw_x[i] = (self.cw_x[i] / 4294967296) * 4294967296 + u64(
                self.p.nns[cur / 65536][cur % 65536]
            )
            self.ct_wpush(1, cur, 0)
            return
        }
        let cnt: u32 = u32(self.cw_x[i] / 4294967296)
        let base: u32 = (self.ncv - cnt) & 2047
        let id: u32 = self.ct_arr_alloc(self.cv_k[base], cnt)
        if id == NONE {
            return
        }
        let db: u32 = self.ca_bs[id & 511]
        for j in 0..4096 {
            if j >= cnt {
                break
            }
            let sj: u32 = (base + j) & 2047
            self.ca_eu[(db + j) & 4095] = self.cv_u[sj]
            self.ca_ei[(db + j) & 4095] = self.cv_i[sj]
        }
        self.ncv = base
        self.ct_vpush(7, u64(id), i64(self.ca_ek[id & 511]))
        self.ncw = i
    }

    # ARRAYFILL (48): [value; N]. eval(value) (+1 шаг), затем N копий.
    # Тип/размер/элемент — из типа узла (nty), посчитан тайпчекером.
    func ct_e_afill(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        if ph == 0 {
            self.cw_p[i] = 1
            self.ct_wpush(1, self.p.nfc[n / 65536][n % 65536], 0)
            return
        }
        let t: u32 = self.nty[n / 65536][n % 65536]
        let sz: u32 = self.yb[t]
        let ek: u32 = self.yk[self.ya[t]]
        let j: u32 = (self.ncv - 1) & 2047
        let vu: u64 = self.cv_u[j]
        let vi: i64 = self.cv_i[j]
        let id: u32 = self.ct_arr_alloc(ek, sz)
        if id == NONE {
            return
        }
        let db: u32 = self.ca_bs[id & 511]
        for q in 0..4096 {
            if q >= sz {
                break
            }
            self.ca_eu[(db + q) & 4095] = vu
            self.ca_ei[(db + q) & 4095] = vi
        }
        self.ncv = self.ncv - 1
        self.ct_vpush(7, u64(id), i64(ek))
        self.ncw = i
    }

    # STMT: инструкция тела (+1 шаг на входе).
    func ct_stmt(var self, i: u32)
        requires i < 4096
        ensures true
    {
        let n: u32 = self.cw_n[i] & 131071
        let ph: u32 = self.cw_p[i]
        let k: u32 = self.p.nk[n / 65536][n % 65536]
        if ph == 0 {
            self.ct_step_tick()
            if self.failed {
                return
            }
        }
        if k == 13 {
            self.ct_s_let(i, n, ph)
        } elif k == 14 {
            self.ct_s_assign(i, n, ph)
        } elif k == 15 {
            self.ct_s_if(i, n, ph)
        } elif k == 18 {
            self.ct_s_for(i, n, ph)
        } elif k == 22 {
            self.ct_s_ret(i, n, ph)
        } elif k == 23 {
            self.ct_s_break(i)
        } elif k == 24 or k == 25 or k == 26 {
            self.ct_s_val(i, n, ph, k)
        } else {
            self.ct_fail("comptime: trap: не константа")
        }
    }

    func ct_s_let(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        let t: u32 = self.p.nfc[n / 65536][n % 65536]
        if ph == 0 {
            self.cw_p[i] = 1
            self.ct_wpush(1, self.p.nns[t / 65536][t % 65536], 0)
            return
        }
        self.ncv = self.ncv - 1
        self.ct_lpush(
            self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536], self.ncv & 2047
        )
        self.ncw = i
    }

    func ct_s_assign(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        let t: u32 = self.p.nfc[n / 65536][n % 65536]
        # A2: цель — индексация массива (t[idx] = value)
        if self.p.nk[t / 65536][t % 65536] == 44 {
            self.ct_s_iassign(i, n, ph, t)
            return
        }
        if ph == 0 {
            self.cw_p[i] = 1
            self.ct_wpush(1, self.p.nns[t / 65536][t % 65536], 0)
            return
        }
        self.ncv = self.ncv - 1
        let j: u32 = self.ncv & 2047
        let sl: u32 = self.ct_lfind(
            self.p.nss[t / 65536][t % 65536], self.p.nsl[t / 65536][t % 65536]
        )
        if sl == NONE {
            self.ct_fail("comptime: trap: не константа")
            return
        }
        var uu: u64 = self.cv_u[j]
        if self.cv_k[j] == 7 {
            # присваивание целого массива — глубокая копия (значение-семантика)
            let nid: u32 = self.ct_arr_copy(u32(uu))
            if self.failed {
                return
            }
            uu = u64(nid)
        }
        self.cl_u[sl & 4479] = uu
        self.cl_i[sl & 4479] = self.cv_i[j]
        self.ncw = i
    }

    # A2: t[idx] = value. Python порядок — eval(value), eval(obj),
    # eval(index), проверка границ, запись элемента (те же шаги/трапы).
    func ct_s_iassign(var self, i: u32, n: u32, ph: u32, t: u32)
        requires i < 4096 and n < 131072 and t < 131072
        ensures true
    {
        if ph == 0 {
            self.cw_p[i] = 1
            self.ct_wpush(1, self.p.nns[t / 65536][t % 65536], 0)
            return
        }
        if ph == 1 {
            self.cw_p[i] = 2
            self.ct_wpush(1, self.p.nfc[t / 65536][t % 65536], 0)
            return
        }
        if ph == 2 {
            self.cw_p[i] = 3
            let ob: u32 = self.p.nfc[t / 65536][t % 65536]
            self.ct_wpush(1, self.p.nns[ob / 65536][ob % 65536], 0)
            return
        }
        let jx: u32 = (self.ncv - 1) & 2047
        let jo: u32 = (self.ncv - 2) & 2047
        let jv: u32 = (self.ncv - 3) & 2047
        let aid: u32 = u32(self.cv_u[jo])
        var idx: i64 = self.cv_i[jx]
        let kk: u32 = self.cv_k[jx]
        if kk != 0 and kk != 14 {
            idx = i64(self.cv_u[jx])
        }
        if idx < 0 or idx >= i64(self.ca_ln[aid & 511]) {
            self.ct_fail("comptime: trap: индекс вне границ")
            return
        }
        let sl: u32 = (self.ca_bs[aid & 511] + u32(idx)) & 4095
        self.ca_eu[sl] = self.cv_u[jv]
        self.ca_ei[sl] = self.cv_i[jv]
        self.ncv = self.ncv - 3
        self.ncw = i
    }

    func ct_s_if(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        let c: u32 = self.p.nfc[n / 65536][n % 65536]
        if ph == 0 {
            self.cw_p[i] = 1
            self.cw_x[i] = u64(self.p.nns[c / 65536][c % 65536])
            self.ct_wpush(1, c, 0)
            return
        }
        self.ncv = self.ncv - 1
        let taken: bool = self.cv_u[self.ncv & 2047] != 0
        let cur: u32 = u32(self.cw_x[i] % 4294967296)
        if ph == 1 {
            # cur — then-блок
            if taken {
                self.ncw = i
                self.ct_wpush(3, cur, 0)
                return
            }
            self.ct_if_next(i, self.p.nns[cur / 65536][cur % 65536])
            return
        }
        # ph == 2: cur — elif-узел
        if taken {
            let eb: u32 = self.p.nfc[cur / 65536][cur % 65536]
            self.ncw = i
            self.ct_wpush(3, self.p.nns[eb / 65536][eb % 65536], 0)
            return
        }
        self.ct_if_next(i, self.p.nns[cur / 65536][cur % 65536])
    }

    # Переход к следующей ветке if: elif — вычислить условие, else —
    # исполнить блок, конец — снять задачу.
    func ct_if_next(var self, i: u32, nxt: u32)
        requires i < 4096
        ensures true
    {
        if nxt == NONE {
            self.ncw = i
            return
        }
        let k: u32 = self.p.nk[nxt / 65536][nxt % 65536]
        if k == 16 {
            self.cw_p[i] = 2
            self.cw_x[i] = u64(nxt)
            self.ct_wpush(1, self.p.nfc[nxt / 65536][nxt % 65536], 0)
            return
        }
        # else: единственный ребёнок — блок
        self.ncw = i
        self.ct_wpush(3, self.p.nfc[nxt / 65536][nxt % 65536], 0)
    }

    func ct_s_for(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        if ph == 0 {
            let rb: u32 = self.range_of(n)
            if rb == NONE or self.ncq >= 512 {
                self.ct_fail("comptime: trap: не константа")
                return
            }
            let g: u32 = self.ncq
            self.cq_c[g] = self.ct_rb_i64(self.rb_ss[rb & 511], self.rb_sm[rb & 511])
            self.cq_e[g] = self.ct_rb_i64(self.rb_es[rb & 511], self.rb_em[rb & 511])
            self.cq_b[g] = self.ncl
            self.cq_v[g] = NONE
            if not self.span_is(
                self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536], "_"
            ) {
                if self.ncl < 4480 {
                    self.cl_s[self.ncl] = self.p.nss[n / 65536][n % 65536]
                    self.cl_l[self.ncl] = self.p.nsl[n / 65536][n % 65536]
                    self.cl_k[self.ncl] = self.yk[self.nty[n / 65536][n % 65536]]
                    self.cl_u[self.ncl] = 0
                    self.cl_i[self.ncl] = 0
                    self.cq_v[g] = self.ncl
                    self.ncl = self.ncl + 1
                }
            }
            self.ncq = g + 1
            self.cw_p[i] = 1
            return
        }
        let g2: u32 = (self.ncq - 1) & 511
        if self.cq_c[g2] >= self.cq_e[g2] {
            self.ncl = self.cq_b[g2]
            self.ncq = self.ncq - 1
            self.ncw = i
            return
        }
        self.ct_step_tick()
        if self.failed {
            return
        }
        let v: u32 = self.cq_v[g2]
        if v != NONE {
            let ky: u32 = self.cl_k[v & 4479]
            if ky == 0 or ky == 14 {
                self.cl_i[v & 4479] = self.cq_c[g2]
            } else {
                self.cl_u[v & 4479] = u64(self.cq_c[g2])
            }
        }
        self.cq_c[g2] = self.cq_c[g2] + 1
        # тело — ребёнок-блок (kind 12)
        var c: u32 = self.p.nfc[n / 65536][n % 65536]
        for _ in 0..8 {
            if c == NONE {
                break
            }
            if self.p.nk[c / 65536][c % 65536] == 12 {
                self.ct_wpush(3, c, 0)
                c = NONE
            } else {
                c = self.p.nns[c / 65536][c % 65536]
            }
        }
    }

    # Граница диапазона (sign, mag) -> i64 с насыщением: магнитуды за
    # i64 недостижимы до бюджета (1М витков << 2^63).
    func ct_rb_i64(var self, s: u32, m: u64) -> i64
        requires true
        ensures true
    {
        if s == 1 {
            if m >= 9223372036854775808 {
                return -9223372036854775808
            }
            let z: i64 = 0 - i64(m)
            return z
        }
        if m > 9223372036854775807 {
            return 9223372036854775807
        }
        return i64(m)
    }

    func ct_s_ret(var self, i: u32, n: u32, ph: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        let g: u32 = (self.ncg - 1) & 63
        if ph == 0 {
            let c: u32 = self.p.nfc[n / 65536][n % 65536]
            if c != NONE {
                self.cw_p[i] = 1
                self.ct_wpush(1, c, 0)
                return
            }
            self.cg_rk[g] = NONE
        } else {
            self.ncv = self.ncv - 1
            let j: u32 = self.ncv & 2047
            self.cg_rk[g] = self.cv_k[j]
            self.cg_ru[g] = self.cv_u[j]
            self.cg_ri[g] = self.cv_i[j]
        }
        # раскрутка до CALLX кадра (остаётся вершиной)
        self.ncw = self.cg_wb[g] + 1
        self.ncv = self.cg_vb[g]
        self.ncq = self.cg_qb[g]
    }

    func ct_s_break(var self, i: u32)
        requires i < 4096
        ensures true
    {
        var j: u32 = i
        var found: bool = false
        for _ in 0..4096 {
            if found or j == 0 {
                break
            }
            j = j - 1
            let t: u32 = self.cw_t[j]
            let m: u32 = self.cw_n[j] & 131071
            if t == 2 and self.p.nk[m / 65536][m % 65536] == 18 and self.cw_p[j] == 1 {
                let g: u32 = (self.ncq - 1) & 511
                self.ncl = self.cq_b[g]
                self.ncq = self.ncq - 1
                self.ncw = j
                found = true
            }
        }
        if not found {
            self.ct_fail("comptime: trap: не константа")
        }
    }

    # assert (24) / exprstmt (25) / discard (26): вычислить значение,
    # затем проверить/пропустить/выбросить.
    func ct_s_val(var self, i: u32, n: u32, ph: u32, k: u32)
        requires i < 4096 and n < 131072
        ensures true
    {
        if ph == 0 {
            self.cw_p[i] = 1
            self.ct_wpush(1, self.p.nfc[n / 65536][n % 65536], 0)
            return
        }
        if k == 24 {
            self.ncv = self.ncv - 1
            if self.cv_u[self.ncv & 2047] == 0 {
                self.ct_fail("comptime: trap: assert не выполнен")
                return
            }
        } elif k == 26 {
            self.ncv = self.ncv - 1
        }
        self.ncw = i
    }

    # --- сбор объявлений ---------------------------------------------------

    # Имя занято на верхнем уровне (правило 6 + встроенные имена)?
    func top_taken(var self, a: u32, l: u32) -> bool
        requires true
        ensures true
    {
        if self.find_func(a, l) != NONE {
            return true
        }
        if self.find_struct(a, l) != NONE {
            return true
        }
        if self.find_enum(a, l) != NONE {
            return true
        }
        if self.find_const(a, l) != NONE {
            return true
        }
        return self.builtin_name(a, l)
    }

    func builtin_name(var self, a: u32, l: u32) -> bool
        requires true
        ensures true
    {
        if self.span_is(a, l, "print") or self.span_is(a, l, "write") {
            return true
        }
        # read_line/parse_i32 — библиотечные (lib/Io.eat, lib/Parse.eat)
        if self.span_is(a, l, "read_byte") {
            return true
        }
        if self.span_is(a, l, "write_byte") or self.span_is(a, l, "write_err_byte") {
            return true
        }
        if self.span_is(a, l, "write_span") or self.span_is(a, l, "exit") {
            return true
        }
        # аргументы командной строки (argv без имени программы)
        if self.span_is(a, l, "arg_count") or self.span_is(a, l, "arg_len") {
            return true
        }
        if self.span_is(a, l, "arg_byte") {
            return true
        }
        if self.span_is(a, l, "len") {
            return true
        }
        if self.span_is(a, l, "i32") or self.span_is(a, l, "u32") {
            return true
        }
        if self.span_is(a, l, "u8") or self.span_is(a, l, "str") {
            return true
        }
        if self.span_is(a, l, "u16") {
            return true
        }
        if self.span_is(a, l, "u64") or self.span_is(a, l, "i64") {
            return true
        }
        if self.span_is(a, l, "char") or self.span_is(a, l, "Result") {
            return true
        }
        if self.span_is(a, l, "Option") or self.span_is(a, l, "IoError") {
            return true
        }
        # конструкторы встроенных sum-типов (SPEC §5.3)
        if self.span_is(a, l, "Ok") or self.span_is(a, l, "Err") {
            return true
        }
        if self.span_is(a, l, "Some") or self.span_is(a, l, "None") {
            return true
        }
        return self.span_is(a, l, "ParseError")
    }

    func declare_top(var self, n: u32)
        requires n < 131072
        ensures true
    {
        if self.top_taken(self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]) {
            self.fail_node(n, "имя уже занято")
        }
    }

    # Проход 1: имена struct и enum (нужны resolve в проходе 2).
    # --- модули (docs/MODULES_PLAN.md §3) ----------------------------------
    # Негативные проверки видимости (коллизии, неиспользуемый импорт,
    # замыкание интерфейса) живут в Python-эталоне; self-hosted компилятор
    # повторяет разрешение: строит таблицы, находит источник каждого
    # импорта («модуль раньше по потоку») и канонизирует имена.

    # Модуль по спану канонического пути; NONE — не найден.
    func find_module(var self, a: u32, l: u32) -> u32
        requires true
        ensures result < 64 or result == NONE
    {
        var found: u32 = NONE
        for i in 0..64 {
            if i >= self.nmod or found != NONE {
                break
            }
            let d: u32 = self.mnd[i]
            if self.span_eq(
                a, l, self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536]
            ) {
                found = i
            }
        }
        return found
    }

    # Экспортирована ли функция своим модулем (метод — через
    # структуру-владельца: методы приходят с типом). Модуль 0
    # (Rt, склейка cat) ничего не экспортирует — его функции
    # internal (docs/MODULES_PLAN.md §5).
    func is_exported(var self, fi: u32) -> bool
        requires fi < 1024
        ensures true
    {
        let fm: u32 = self.fmod[fi]
        if fm == 0 {
            return false
        }
        let own: u32 = self.fown[fi]
        var a: u32 = self.fn_s[fi]
        var l: u32 = self.fn_l[fi]
        if own != NONE {
            a = self.sn_s[own]
            l = self.sn_l[own]
        }
        var hit: bool = false
        for j in 0..256 {
            if j >= self.nexp or hit {
                break
            }
            if self.exm[j] == fm {
                if self.span_eq(self.exi_s[j], self.exi_l[j], a, l) {
                    hit = true
                }
            }
        }
        return hit
    }

    # export-блок: публичное имя (alias | имя) -> внутреннее имя.
    # В безымянном сегменте (склейка cat) блок инертен — интерфейс
    # закрепляет драйвер, ставя #module.
    func col_export(var self, d: u32)
        requires d < 131072
        ensures true
    {
        if self.cmod == 0 {
            return
        }
        var b: u32 = self.p.nfc[d / 65536][d % 65536]
        for _ in 0..1024 {
            if b == NONE or self.failed {
                break
            }
            if self.nexp >= 256 {
                self.fail_node(b, "слишком много экспортов (предел 256)")
            } else {
                let i: u32 = self.nexp
                if self.p.ny[b / 65536][b % 65536] > 0 {
                    self.exp_s[i] = self.p.nx[b / 65536][b % 65536]
                    self.exp_l[i] = self.p.ny[b / 65536][b % 65536]
                } else {
                    self.exp_s[i] = self.p.nss[b / 65536][b % 65536]
                    self.exp_l[i] = self.p.nsl[b / 65536][b % 65536]
                }
                self.exi_s[i] = self.p.nss[b / 65536][b % 65536]
                self.exi_l[i] = self.p.nsl[b / 65536][b % 65536]
                self.exm[i] = self.cmod
                self.nexp = i + 1
            }
            b = self.p.nns[b / 65536][b % 65536]
        }
    }

    # import-блок: источник обязан встретиться раньше по потоку
    # (компилятор перепроверяет драйвер), имя — в его экспорте.
    func col_import(var self, d: u32)
        requires d < 131072
        ensures true
    {
        let src: u32 = self.find_module(
            self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536]
        )
        if src == NONE {
            self.fail_node(
                d, "import: модуль не встретился раньше по потоку (порядок собирает драйвер)"
            )
            return
        }
        var b: u32 = self.p.nfc[d / 65536][d % 65536]
        for _ in 0..1024 {
            if b == NONE or self.failed {
                break
            }
            self.col_bind(b, src)
            b = self.p.nns[b / 65536][b % 65536]
        }
    }

    # Одна связка import: поиск публичного имени в экспорте источника.
    func col_bind(var self, b: u32, src: u32)
        requires b < 131072 and src < 64
        ensures true
    {
        var hit: u32 = NONE
        for j in 0..256 {
            if j >= self.nexp or hit != NONE {
                break
            }
            if self.exm[j] == src + 1 {
                if self.span_eq(
                    self.exp_s[j], self.exp_l[j], self.p.nss[b / 65536][b % 65536],
                    self.p.nsl[b / 65536][b % 65536]
                ) {
                    hit = j
                }
            }
        }
        if hit == NONE {
            self.fail_node(b, "модуль не экспортирует это имя")
            return
        }
        if self.nimp >= 512 {
            self.fail_node(b, "слишком много импортов (предел 512)")
            return
        }
        let i: u32 = self.nimp
        if self.p.ny[b / 65536][b % 65536] > 0 {
            self.iml_s[i] = self.p.nx[b / 65536][b % 65536]
            self.iml_l[i] = self.p.ny[b / 65536][b % 65536]
        } else {
            self.iml_s[i] = self.p.nss[b / 65536][b % 65536]
            self.iml_l[i] = self.p.nsl[b / 65536][b % 65536]
        }
        self.imt_s[i] = self.exi_s[hit]
        self.imt_l[i] = self.exi_l[hit]
        self.imm[i] = self.cmod
        self.nimp = i + 1
    }

    # Проход по шапкам: границы модулей, export- и import-блоки.
    func modules_pass(var self)
        requires true
        ensures true
    {
        var d: u32 = self.p.nfc[0 / 65536][0 % 65536]
        for _ in 0..131072 {
            if d == NONE or self.failed {
                break
            }
            let k: u32 = self.p.nk[d / 65536][d % 65536]
            if k == 51 {
                if self.nmod >= 64 {
                    self.fail_node(d, "слишком много модулей (предел 64)")
                } elif self.find_module(
                    self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536]
                ) != NONE {
                    self.fail_node(d, "модуль в потоке дважды")
                } else {
                    self.mnd[self.nmod] = d
                    self.nmod = self.nmod + 1
                    self.cmod = self.nmod
                }
            } elif k == 53 {
                self.col_export(d)
            } elif k == 52 {
                self.col_import(d)
            }
            d = self.p.nns[d / 65536][d % 65536]
        }
        self.cmod = 0
        if not self.failed {
            self.canon_pass()
        }
    }

    # Канонизация: имя-использование, совпавшее с локальным именем
    # импорта своего модуля, перенацеливается на внутреннее имя
    # экспортёра (спан узла -> спан из export-связки). Дальше конвейер
    # видит только внутренние имена — как Python-эталон после vis_name.
    # Узлы идут в порядке разбора: принадлежность модулю — по последней
    # встреченной директиве (вид 51).
    func canon_pass(var self)
        requires true
        ensures true
    {
        var cur: u32 = 0
        for i in 0..131072 {
            if i >= self.p.nnode {
                break
            }
            let k: u32 = self.p.nk[i / 65536][i % 65536]
            if k == 51 {
                cur = cur + 1
            } elif k == 27 or k == 37 or k == 41 or k == 45 {
                if cur > 0 {
                    self.canon_node(i, cur)
                }
            }
        }
    }

    func canon_node(var self, n: u32, cur: u32)
        requires n < 131072
        ensures true
    {
        for j in 0..512 {
            if j >= self.nimp {
                break
            }
            if self.imm[j] == cur {
                if self.span_eq(
                    self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536],
                    self.iml_s[j], self.iml_l[j]
                ) {
                    self.p.nss[n / 65536][n % 65536] = self.imt_s[j]
                    self.p.nsl[n / 65536][n % 65536] = self.imt_l[j]
                }
            }
        }
    }

    func pass1(var self)
        requires true
        ensures true
    {
        var d: u32 = self.p.nfc[0 / 65536][0 % 65536]
        for _ in 0..131072 {
            if d == NONE or self.failed {
                break
            }
            let k: u32 = self.p.nk[d / 65536][d % 65536]
            if k == 4 {
                self.declare_top(d)
                self.reg_struct(d)
            } elif k == 2 {
                self.declare_top(d)
                self.reg_enum(d)
            }
            d = self.p.nns[d / 65536][d % 65536]
        }
    }

    func reg_struct(var self, d: u32)
        requires d < 131072
        ensures true
    {
        if self.nstr >= 128 {
            self.fail_node(d, "слишком много struct (предел 128)")
            return
        }
        let i: u32 = self.nstr
        self.sn_s[i] = self.p.nss[d / 65536][d % 65536]
        self.sn_l[i] = self.p.nsl[d / 65536][d % 65536]
        self.snd[i] = d
        self.sgs[i] = 0
        self.sgc[i] = 0
        self.nstr = i + 1
    }

    func reg_enum(var self, d: u32)
        requires d < 131072
        ensures true
    {
        if self.nenu >= 64 {
            self.fail_node(d, "слишком много enum (предел 64)")
            return
        }
        let i: u32 = self.nenu
        self.en_s[i] = self.p.nss[d / 65536][d % 65536]
        self.en_l[i] = self.p.nsl[d / 65536][d % 65536]
        self.evs[i] = 0
        self.evc[i] = 0
        self.nenu = i + 1
        # повтор варианта — ошибка
        var v: u32 = self.p.nfc[d / 65536][d % 65536]
        for _ in 0..256 {
            if v == NONE {
                break
            }
            var w: u32 = self.p.nns[v / 65536][v % 65536]
            for _ in 0..256 {
                if w == NONE {
                    break
                }
                if self.span_eq(
                    self.p.nss[v / 65536][v % 65536], self.p.nsl[v / 65536][v % 65536],
                    self.p.nss[w / 65536][w % 65536], self.p.nsl[w / 65536][w % 65536]
                ) {
                    self.fail_node(d, "enum: повтор варианта")
                }
                w = self.p.nns[w / 65536][w % 65536]
            }
            v = self.p.nns[v / 65536][v % 65536]
        }
    }

    # Проход 2: сигнатуры, поля, нагрузка enum, константы.
    func pass2(var self)
        requires true
        ensures true
    {
        self.cmod = 0
        var d: u32 = self.p.nfc[0 / 65536][0 % 65536]
        for _ in 0..131072 {
            if d == NONE or self.failed {
                break
            }
            let k: u32 = self.p.nk[d / 65536][d % 65536]
            if k == 51 {
                self.cmod = self.cmod + 1
            } elif k == 1 {
                self.col_const(d)
            } elif k == 6 or k == 50 {
                self.declare_top(d)
                self.add_func(d, NONE)
            } elif k == 2 {
                self.col_enum(d)
            } elif k == 4 {
                self.col_struct(d)
            }
            d = self.p.nns[d / 65536][d % 65536]
        }
    }

    func col_const(var self, d: u32)
        requires d < 131072
        ensures true
    {
        self.declare_top(d)
        if self.ncon >= 128 {
            self.fail_node(d, "слишком много const (предел 128)")
            return
        }
        let ty: u32 = self.resolve(self.p.nfc[d / 65536][d % 65536])
        # comptime-константа (§9.4): значение с вызовом (или именем
        # отложенной) вычисляется фазой 3.5 после типизации тел
        if self.has_call_deep(
            self.p.nns[self.p.nfc[d / 65536][d % 65536] / 65536][
                self.p.nfc[d / 65536][d % 65536] % 65536
            ]
        ) {
            let j: u32 = self.ncon
            self.cn_s[j] = self.p.nss[d / 65536][d % 65536]
            self.cn_l[j] = self.p.nsl[d / 65536][d % 65536]
            self.cty[j] = ty
            self.cvs[j] = 0
            self.cvm[j] = 0
            self.cnd[j] = d
            self.ncon = j + 1
            self.ndef = self.ndef + 1
            return
        }
        self.const_eval(
            self.p.nns[self.p.nfc[d / 65536][d % 65536] / 65536][
                self.p.nfc[d / 65536][d % 65536] % 65536
            ]
        )
        if self.failed {
            return
        }
        if not self.int_fits(ty, self.ces, self.cem) {
            self.fail_node(d, "константа не помещается в свой тип")
            return
        }
        let i: u32 = self.ncon
        self.cn_s[i] = self.p.nss[d / 65536][d % 65536]
        self.cn_l[i] = self.p.nsl[d / 65536][d % 65536]
        self.cty[i] = ty
        self.cvs[i] = self.ces
        self.cvm[i] = self.cem
        self.ncon = i + 1
    }

    # Есть ли в поддереве значения вызов (call/method) или имя уже
    # отложенной константы — признак comptime-константы (§9.4; зеркало
    # _expr_has_call + _Deferred по Name эталона).
    func has_call_deep(var self, root: u32) -> bool
        requires root < 131072
        ensures true
    {
        var st: [u32; 64] = [0; 64]
        var sp: u32 = 1
        st[0] = root
        var found: bool = false
        for _ in 0..131072 {
            if sp == 0 or found {
                break
            }
            sp = sp - 1
            let n: u32 = st[sp]
            let k: u32 = self.p.nk[n / 65536][n % 65536]
            if k == 41 or k == 42 {
                found = true
            } elif k == 37 {
                let ci: u32 = self.find_const(
                    self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
                )
                if ci != NONE {
                    if self.cnd[ci] != NONE {
                        found = true
                    }
                }
            } else {
                # глубина выражений ≤ 32 (SPEC §6) — стек не переполнить
                var c: u32 = self.p.nfc[n / 65536][n % 65536]
                for _ in 0..64 {
                    if c == NONE or sp >= 64 {
                        break
                    }
                    st[sp] = c
                    sp = sp + 1
                    c = self.p.nns[c / 65536][c % 65536]
                }
            }
        }
        return found
    }

    # Сигнатура функции d в таблицу (owner — struct | NONE).
    func add_func(var self, d: u32, owner: u32)
        requires d < 131072
        ensures true
    {
        if self.nfun >= 1024 {
            self.fail_node(d, "слишком много функций (предел 1024)")
            return
        }
        let i: u32 = self.nfun
        self.nfun = i + 1
        self.fn_s[i] = self.p.nss[d / 65536][d % 65536]
        self.fn_l[i] = self.p.nsl[d / 65536][d % 65536]
        self.fmod[i] = self.cmod
        self.fown[i] = owner
        self.fnd[i] = d
        self.fret[i] = NONE
        self.fvs[i] = 0
        self.fps[i] = self.npar
        self.fpc[i] = 0
        self.fh_insert(i)
        var c: u32 = self.p.nfc[d / 65536][d % 65536]
        var first: bool = true
        for _ in 0..64 {
            if c == NONE or self.failed {
                break
            }
            let ck: u32 = self.p.nk[c / 65536][c % 65536]
            if ck == 7 {
                if self.p.nss[c / 65536][c % 65536] == NONE {
                    # self: в параметры не входит, даёт var_self
                    if first {
                        self.fvs[i] = self.p.nx[c / 65536][c % 65536]
                    }
                } else {
                    if self.npar >= 4096 {
                        self.fail_node(c, "слишком много параметров")
                    } else {
                        let pi: u32 = self.npar
                        self.pn_s[pi] = self.p.nss[c / 65536][c % 65536]
                        self.pn_l[pi] = self.p.nsl[c / 65536][c % 65536]
                        self.pty[pi] = self.resolve(self.p.nfc[c / 65536][c % 65536])
                        self.pnd[pi] = c
                        self.npar = pi + 1
                        self.fpc[i] = self.fpc[i] + 1
                    }
                }
                first = false
            } elif ck == 8 {
                self.fret[i] = self.resolve(self.p.nfc[c / 65536][c % 65536])
            }
            c = self.p.nns[c / 65536][c % 65536]
        }
    }

    func col_enum(var self, d: u32)
        requires d < 131072
        ensures true
    {
        let ei: u32 = self.find_enum(
            self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536]
        )
        if ei == NONE {
            return
        }
        self.evs[ei] = self.nvar
        var v: u32 = self.p.nfc[d / 65536][d % 65536]
        for _ in 0..256 {
            if v == NONE or self.failed {
                break
            }
            if self.nvar >= 256 {
                self.fail_node(d, "слишком много вариантов enum")
            } else {
                let wi: u32 = self.nvar
                self.wn_s[wi] = self.p.nss[v / 65536][v % 65536]
                self.wn_l[wi] = self.p.nsl[v / 65536][v % 65536]
                if self.p.nfc[v / 65536][v % 65536] != NONE {
                    self.wpl[wi] = self.resolve(self.p.nfc[v / 65536][v % 65536])
                } else {
                    self.wpl[wi] = NONE
                }
                self.nvar = wi + 1
                self.evc[ei] = self.evc[ei] + 1
            }
            v = self.p.nns[v / 65536][v % 65536]
        }
    }

    func col_struct(var self, d: u32)
        requires d < 131072
        ensures true
    {
        let si: u32 = self.find_struct(
            self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536]
        )
        if si == NONE {
            return
        }
        self.sgs[si] = self.ngld
        var c: u32 = self.p.nfc[d / 65536][d % 65536]
        for _ in 0..1024 {
            if c == NONE or self.failed {
                break
            }
            let ck: u32 = self.p.nk[c / 65536][c % 65536]
            if ck == 5 {
                self.col_field(si, c)
            } elif ck == 6 {
                if self.p.nx[c / 65536][c % 65536] != 1 {
                    self.fail_node(c, "функция внутри struct обязана иметь self первым параметром")
                } else {
                    self.add_func(c, si)
                }
            }
            c = self.p.nns[c / 65536][c % 65536]
        }
    }

    func col_field(var self, si: u32, c: u32)
        requires si < 128 and c < 131072
        ensures true
    {
        # повтор поля — ошибка
        let a: u32 = self.p.nss[c / 65536][c % 65536]
        let l: u32 = self.p.nsl[c / 65536][c % 65536]
        for i in 0..1024 {
            if i >= self.ngld {
                break
            }
            if i >= self.sgs[si] {
                if self.span_eq(self.gn_s[i], self.gn_l[i], a, l) {
                    self.fail_node(c, "поле объявлено дважды")
                }
            }
        }
        if self.ngld >= 1024 {
            self.fail_node(c, "слишком много полей (предел 1024)")
            return
        }
        let gi: u32 = self.ngld
        self.gn_s[gi] = a
        self.gn_l[gi] = l
        self.gty[gi] = self.resolve(self.p.nfc[c / 65536][c % 65536])
        self.ngld = gi + 1
        self.sgc[si] = self.sgc[si] + 1
    }

    # --- циклы типов (значения вкладываются по значению) --------------------

    # Идентификатор узла графа: struct — i, enum — 128 + i.
    # Рёбра: тип поля/нагрузки упоминает struct/enum.
    func type_cycles(var self)
        requires true
        ensures true
    {
        # цвета: 0 белый, 1 серый, 2 чёрный
        var color: [u32; 192] = [0; 192]
        var st: [u32; 64] = [0; 64]
        var stpos: [u32; 64] = [0; 64]
        for r in 0..192 {
            if self.cyc_id_valid(r) and color[r] == 0 and not self.failed {
                var sp: u32 = 1
                st[0] = r
                stpos[0] = 0
                color[r] = 1
                for _ in 0..4096 {
                    if sp == 0 or self.failed {
                        break
                    }
                    let f: u32 = sp - 1
                    let id: u32 = st[f]
                    let nxt: u32 = self.cyc_dep(id, stpos[f])
                    stpos[f] = stpos[f] + 1
                    if nxt == NONE {
                        color[id] = 2
                        sp = f
                    } elif color[nxt] == 1 {
                        self.fail_size_cycle()
                    } elif color[nxt] == 0 {
                        if sp >= 64 {
                            self.fail_at(1, 1, "слишком глубокая вложенность типов")
                        } else {
                            color[nxt] = 1
                            st[sp] = nxt
                            stpos[sp] = 0
                            sp = sp + 1
                        }
                    }
                }
            }
        }
    }

    func cyc_id_valid(var self, id: u32) -> bool
        requires id < 192
        ensures true
    {
        if id < 128 {
            return id < self.nstr
        }
        return id - 128 < self.nenu
    }

    # k-я зависимость узла id (struct/enum, упомянутый в типах его
    # членов); NONE, если зависимостей меньше k+1.
    func cyc_dep(var self, id: u32, k: u32) -> u32
        requires id < 192
        ensures true
    {
        self.dep_k = k
        self.dep_cnt = 0
        self.dep_found = NONE
        var ms: u32 = 0
        var mc: u32 = 0
        if id < 128 {
            ms = self.sgs[id]
            mc = self.sgc[id]
        } else {
            ms = self.evs[id - 128]
            mc = self.evc[id - 128]
        }
        for m in 0..512 {
            if m >= mc or self.dep_found != NONE {
                break
            }
            var ty: u32 = NONE
            if id < 128 {
                ty = self.gty[ms + m]
            } else {
                ty = self.wpl[ms + m]
            }
            if ty != NONE {
                self.cyc_scan(ty)
            }
        }
        return self.dep_found
    }

    # Обход дерева типа: struct/enum-имена считаются зависимостями;
    # dep_k-я попадает в dep_found.
    func cyc_scan(var self, ty: u32)
        requires ty < 512
        ensures true
    {
        var ts: [u32; 16] = [0; 16]
        var tp: u32 = 1
        ts[0] = ty
        for _ in 0..64 {
            if tp == 0 {
                break
            }
            tp = tp - 1
            let t: u32 = ts[tp]
            let tk: u32 = self.yk[t]
            if tk == 8 or tk == 9 {
                self.cyc_hit(tk, self.ys[t], self.yl[t])
            } elif tk == 7 or tk == 11 {
                ts[tp] = self.ya[t]
                tp = tp + 1
            } elif tk == 10 {
                ts[tp] = self.ya[t]
                tp = tp + 1
                ts[tp] = self.yb[t]
                tp = tp + 1
            }
        }
    }

    func cyc_hit(var self, tk: u32, a: u32, l: u32)
        requires true
        ensures true
    {
        let dep: u32 = self.cyc_name_id(tk, a, l)
        if dep == NONE {
            return
        }
        if self.dep_cnt == self.dep_k and self.dep_found == NONE {
            self.dep_found = dep
        }
        self.dep_cnt = self.dep_cnt + 1
    }

    func cyc_name_id(var self, tk: u32, a: u32, l: u32) -> u32
        requires true
        ensures true
    {
        if tk == 8 {
            return self.find_struct(a, l)
        }
        let e: u32 = self.find_enum(a, l)
        if e == NONE {
            return NONE
        }
        return 128 + e
    }

    # --- правила 4 и 5 -------------------------------------------------------

    func rules45(var self)
        requires true
        ensures true
    {
        for i in 0..1024 {
            if i >= self.nfun or self.failed {
                break
            }
            self.rule_func(i)
        }
    }

    func rule_func(var self, i: u32)
        requires i < 1024
        ensures true
    {
        let d: u32 = self.fnd[i]
        let n: u32 = self.count_stmts(d)
        self.total_stmts = self.total_stmts + n
        if n > 60 {
            self.fail_node(d, "функция длиннее 60 statements (правило 4)")
            return
        }
        # правило 5: params (или метод) → requires; возврат → ensures
        var has_req: bool = false
        var has_ens: bool = false
        var has_ret: bool = false
        var has_par: bool = false
        if self.fpc[i] > 0 or self.fown[i] != NONE {
            has_par = true
        }
        var c: u32 = self.p.nfc[d / 65536][d % 65536]
        for _ in 0..64 {
            if c == NONE {
                break
            }
            let ck: u32 = self.p.nk[c / 65536][c % 65536]
            if ck == 8 {
                has_ret = true
            } elif ck == 9 {
                has_req = true
            } elif ck == 10 {
                has_ens = true
            }
            c = self.p.nns[c / 65536][c % 65536]
        }
        if has_par and not has_req {
            self.fail_node(d, "функция с параметрами обязана иметь requires (правило 5)")
            return
        }
        if has_ret and not has_ens {
            self.fail_node(d, "функция с возвращаемым значением обязана иметь ensures (правило 5)")
        }
    }

    # Число statements в поддереве функции (вид узла — инструкция).
    func count_stmts(var self, root: u32) -> u32
        requires root < 131072
        ensures true
    {
        var cnt: u32 = 0
        var cur: u32 = root
        var st: [u32; 64] = [0; 64]
        var sp: u32 = 0
        var done: bool = false
        for _ in 0..131072 {
            if done {
                break
            }
            let k: u32 = self.p.nk[cur / 65536][cur % 65536]
            if is_stmt_kind(k) {
                cnt = cnt + 1
            }
            if self.p.nfc[cur / 65536][cur % 65536] != NONE and sp < 64 {
                st[sp] = cur
                sp = sp + 1
                cur = self.p.nfc[cur / 65536][cur % 65536]
            } else {
                var moved: bool = false
                for _ in 0..64 {
                    if moved {
                        break
                    }
                    if cur == root or sp == 0 {
                        done = true
                        moved = true
                    } elif self.p.nns[cur / 65536][cur % 65536] != NONE {
                        cur = self.p.nns[cur / 65536][cur % 65536]
                        moved = true
                    } else {
                        sp = sp - 1
                        cur = st[sp]
                        if cur == root {
                            done = true
                            moved = true
                        }
                    }
                }
            }
        }
        return cnt
    }

    # --- main ------------------------------------------------------------

    func check_main(var self)
        requires true
        ensures true
    {
        var mi: u32 = NONE
        for i in 0..1024 {
            if i >= self.nfun or mi != NONE {
                break
            }
            if self.fown[i] == NONE {
                if self.span_is(self.fn_s[i], self.fn_l[i], "main") {
                    mi = i
                }
            }
        }
        if mi == NONE {
            self.fail_at(1, 1, "нет функции main — точки входа")
            return
        }
        self.main_fi = mi
        if self.p.nk[self.fnd[mi] / 65536][self.fnd[mi] % 65536] == 50 {
            self.fail_node(self.fnd[mi], "main не может быть extern")
        }
        if self.fpc[mi] != 0 or self.fret[mi] != NONE {
            self.fail_node(self.fnd[mi], "main не принимает параметров и ничего не возвращает")
        }
    }

    # --- запуск -----------------------------------------------------------

    func run(var self)
        requires true
        ensures true
    {
        self.init_types()
        self.modules_pass()
        if self.failed {
            return
        }
        self.pass1()
        if self.failed {
            return
        }
        self.pass2()
        if self.failed {
            return
        }
        self.type_cycles()
        if self.failed {
            return
        }
        self.rules45()
        if self.failed {
            return
        }
        self.check_main()
        if self.failed {
            return
        }
        # comptime-константы (§9.5): значения нужны любому дампу (sig
        # печатает «= значение») — при отложенных догоняем типизацию
        # тел и фазу 3.5 прямо здесь; bdone гасит повтор в run_typed
        if self.ndef > 0 {
            self.init_builtins()
            self.run_bodies()
            self.bdone = 1
            if self.failed {
                return
            }
            self.comptime_pass()
        }
    }

    # --- дамп типа (итеративный принтер) -----------------------------------

    # Имя скалярного вида (правило 4: вынос из write_type).
    func write_scalar_kind(var self, k: u32)
        requires k <= 5 or k >= 12
        ensures true
    {
        if k == 0 {
            write("i32")
        } elif k == 1 {
            write("u32")
        } elif k == 2 {
            write("u8")
        } elif k == 12 {
            write("u16")
        } elif k == 13 {
            write("u64")
        } elif k == 14 {
            write("i64")
        } elif k == 3 {
            write("bool")
        } elif k == 4 {
            write("char")
        } else {
            write("void")
        }
    }

    func write_type(var self, root: u32)
        requires root < 512
        ensures true
    {
        var s1: [u32; 32] = [0; 32]
        var s2: [u32; 32] = [0; 32]
        var sp: u32 = 1
        s1[0] = root
        s2[0] = 0
        for _ in 0..128 {
            if sp == 0 {
                break
            }
            let f: u32 = sp - 1
            let t: u32 = s1[f]
            let ph: u32 = s2[f]
            let k: u32 = self.yk[t]
            if k <= 5 or k >= 12 {
                self.write_scalar_kind(k)
                sp = f
            } elif k == 6 {
                if self.ya[t] == NONE {
                    write("str<?>")
                } else {
                    write("str<{self.ya[t]}>")
                }
                sp = f
            } elif k == 7 {
                if ph == 0 {
                    write("[")
                    s2[f] = 1
                    s1[sp] = self.ya[t]
                    s2[sp] = 0
                    sp = sp + 1
                } else {
                    write("; {self.yb[t]}]")
                    sp = f
                }
            } elif k == 8 or k == 9 {
                self.write_span2(self.ys[t], self.yl[t])
                sp = f
            } elif k == 10 {
                if ph == 0 {
                    write("Result<")
                    s2[f] = 1
                    s1[sp] = self.ya[t]
                    s2[sp] = 0
                    sp = sp + 1
                } elif ph == 1 {
                    write(", ")
                    s2[f] = 2
                    s1[sp] = self.yb[t]
                    s2[sp] = 0
                    sp = sp + 1
                } else {
                    write(">")
                    sp = f
                }
            } else {
                if ph == 0 {
                    write("Option<")
                    s2[f] = 1
                    s1[sp] = self.ya[t]
                    s2[sp] = 0
                    sp = sp + 1
                } else {
                    write(">")
                    sp = f
                }
            }
        }
    }

    # --- дамп сигнатур (формат `eatc sig`) ---------------------------------

    func write_sig(var self, i: u32)
        requires i < 1024
        ensures true
    {
        write("(")
        let ps: u32 = self.fps[i]
        for k in 0..8 {
            if k >= self.fpc[i] {
                break
            }
            if k > 0 {
                write(", ")
            }
            self.write_span2(self.pn_s[ps + k], self.pn_l[ps + k])
            write(": ")
            self.write_type(self.pty[ps + k])
        }
        write(")")
        if self.fvs[i] == 1 {
            write(" var_self")
        }
        if self.fret[i] != NONE {
            write(" -> ")
            self.write_type(self.fret[i])
        }
    }

    func dump_sig(var self)
        requires true
        ensures true
    {
        var d: u32 = self.p.nfc[0 / 65536][0 % 65536]
        for _ in 0..131072 {
            if d == NONE {
                break
            }
            self.dump_decl(d)
            d = self.p.nns[d / 65536][d % 65536]
        }
        write("stats funcs={self.nfun} structs={self.nstr} stmts={self.total_stmts}\n")
    }

    func dump_decl(var self, d: u32)
        requires d < 131072
        ensures true
    {
        let k: u32 = self.p.nk[d / 65536][d % 65536]
        let ln: u32 = self.p.nl[d / 65536][d % 65536]
        let cl: u32 = self.p.nc[d / 65536][d % 65536]
        if k == 1 {
            let ci: u32 = self.find_const(
                self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536]
            )
            write("const ")
            self.write_span2(self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536])
            write(" {ln}:{cl} :: ")
            self.write_type(self.cty[ci])
            write(" = ")
            if self.yk[self.cty[ci]] == 7 {
                self.dump_arr_const(ci)
                write("\n")
            } else {
                if self.cvs[ci] == 1 {
                    write("-")
                }
                write("{self.cvm[ci]}\n")
            }
        } elif k == 6 or k == 50 {
            let fi: u32 = self.func_by_node(d)
            if k == 50 {
                write("extern ")
            } else {
                write("func ")
            }
            self.write_span2(self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536])
            write(" {ln}:{cl} ")
            self.write_sig(fi)
            write("\n")
        } elif k == 4 {
            self.dump_struct(d, ln, cl)
        } elif k == 2 {
            self.dump_enum(d, ln, cl)
        } elif k == 11 {
            write("test ")
            self.write_span2(self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536])
            write(" {ln}:{cl}\n")
        } elif k == 51 {
            write("module ")
            self.write_span2(self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536])
            write(" {ln}:{cl}\n")
        } elif k == 52 {
            self.dump_import(d)
        } elif k == 53 {
            self.dump_export(d)
        }
    }

    # A2: значение массива-константы для дампов — `[v0, v1, ...]`
    # (беззнаковые — магнитуда, знаковые — со знаком, как эталон).
    func dump_arr_const(var self, ci: u32)
        requires ci < 128
        ensures true
    {
        let ty: u32 = self.cty[ci]
        let ln: u32 = self.yb[ty]
        let ek: u32 = self.yk[self.ya[ty]]
        let base: u32 = self.cca_bs[ci & 127]
        write("[")
        for q in 0..4096 {
            if q >= ln {
                break
            }
            if q > 0 {
                write(", ")
            }
            let sl: u32 = (base + q) & 4095
            if ek == 0 or ek == 14 {
                write("{self.cca_i[sl]}")
            } else {
                write("{self.cca_u[sl]}")
            }
        }
        write("]")
    }

    # `import {локальное} {l}:{c} :: {путь} {публичное}` на связку.
    func dump_import(var self, d: u32)
        requires d < 131072
        ensures true
    {
        var b: u32 = self.p.nfc[d / 65536][d % 65536]
        for _ in 0..1024 {
            if b == NONE {
                break
            }
            write("import ")
            if self.p.ny[b / 65536][b % 65536] > 0 {
                self.write_span2(self.p.nx[b / 65536][b % 65536], self.p.ny[b / 65536][b % 65536])
            } else {
                self.write_span2(self.p.nss[b / 65536][b % 65536], self.p.nsl[b / 65536][b % 65536])
            }
            write(" {self.p.nl[b / 65536][b % 65536]}:{self.p.nc[b / 65536][b % 65536]} :: ")
            self.write_span2(self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536])
            write(" ")
            self.write_span2(self.p.nss[b / 65536][b % 65536], self.p.nsl[b / 65536][b % 65536])
            write("\n")
            b = self.p.nns[b / 65536][b % 65536]
        }
    }

    # `export {публичное} {l}:{c} :: {внутреннее}` на связку.
    func dump_export(var self, d: u32)
        requires d < 131072
        ensures true
    {
        var b: u32 = self.p.nfc[d / 65536][d % 65536]
        for _ in 0..1024 {
            if b == NONE {
                break
            }
            write("export ")
            if self.p.ny[b / 65536][b % 65536] > 0 {
                self.write_span2(self.p.nx[b / 65536][b % 65536], self.p.ny[b / 65536][b % 65536])
            } else {
                self.write_span2(self.p.nss[b / 65536][b % 65536], self.p.nsl[b / 65536][b % 65536])
            }
            write(" {self.p.nl[b / 65536][b % 65536]}:{self.p.nc[b / 65536][b % 65536]} :: ")
            self.write_span2(self.p.nss[b / 65536][b % 65536], self.p.nsl[b / 65536][b % 65536])
            write("\n")
            b = self.p.nns[b / 65536][b % 65536]
        }
    }

    func dump_struct(var self, d: u32, ln: u32, cl: u32)
        requires d < 131072
        ensures true
    {
        write("struct ")
        self.write_span2(self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536])
        write(" {ln}:{cl}\n")
        let si: u32 = self.find_struct(
            self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536]
        )
        let gs: u32 = self.sgs[si]
        for g in 0..512 {
            if g >= self.sgc[si] {
                break
            }
            write("  field ")
            self.write_span2(self.gn_s[gs + g], self.gn_l[gs + g])
            write(" :: ")
            self.write_type(self.gty[gs + g])
            write("\n")
        }
        var c: u32 = self.p.nfc[d / 65536][d % 65536]
        for _ in 0..1024 {
            if c == NONE {
                break
            }
            if self.p.nk[c / 65536][c % 65536] == 6 {
                let fi: u32 = self.func_by_node(c)
                write("  method ")
                self.write_span2(self.p.nss[c / 65536][c % 65536], self.p.nsl[c / 65536][c % 65536])
                write(" {self.p.nl[c / 65536][c % 65536]}:{self.p.nc[c / 65536][c % 65536]} ")
                self.write_sig(fi)
                write("\n")
            }
            c = self.p.nns[c / 65536][c % 65536]
        }
    }

    func dump_enum(var self, d: u32, ln: u32, cl: u32)
        requires d < 131072
        ensures true
    {
        write("enum ")
        self.write_span2(self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536])
        write(" {ln}:{cl}\n")
        let ei: u32 = self.find_enum(
            self.p.nss[d / 65536][d % 65536], self.p.nsl[d / 65536][d % 65536]
        )
        let ws: u32 = self.evs[ei]
        for w in 0..256 {
            if w >= self.evc[ei] {
                break
            }
            write("  variant ")
            self.write_span2(self.wn_s[ws + w], self.wn_l[ws + w])
            if self.wpl[ws + w] != NONE {
                write(" :: ")
                self.write_type(self.wpl[ws + w])
            }
            write("\n")
        }
    }

    # ==== фаза 3b: тайпчекер тел =========================================

    # Имена встроенных enum дописываются в пул байтов лексера — спаны
    # нужны интернированным типам (IoError/ParseError) и дампу.
    func init_builtins(var self)
        requires true
        ensures true
    {
        let io: str<16> = "IoError"
        let pe: str<16> = "ParseError"
        self.bn_io = self.p.lex.sblen
        for i in 0..7 {
            self.p.lex.sb_set(self.bn_io + i, u8(io[i]))
        }
        self.bn_pe = self.bn_io + 7
        for i in 0..10 {
            self.p.lex.sb_set(self.bn_pe + i, u8(pe[i]))
        }
        # "result" — имя-локаль ensures в comptime-вычислителе (§9.6)
        let rs: str<8> = "result"
        self.bn_res = self.bn_pe + 10
        for i in 0..6 {
            self.p.lex.sb_set(self.bn_res + i, u8(rs[i]))
        }
        self.p.lex.sblen = self.bn_res + 6
        self.ty_sq = self.intern(6, NONE, NONE, NONE, 0)
        let t_io: u32 = self.intern(9, NONE, NONE, self.bn_io, 7)
        let t_pe: u32 = self.intern(9, NONE, NONE, self.bn_pe, 10)
        let t_s256: u32 = self.intern(6, 256, NONE, NONE, 0)
        self.ty_rl = self.intern(10, t_s256, t_io, NONE, 0)
        self.ty_rb = self.intern(10, 2, t_io, NONE, 0)
        self.ty_pi = self.intern(10, 0, t_pe, NONE, 0)
        self.cur_key = NONE
        self.self_ty2 = NONE
        self.res_ty2 = NONE
        self.cr = NONE
        for n in 0..131072 {
            self.nty[n / 65536][n % 65536] = NONE
        }
    }

    # Совместимость: интернированные типы равны по индексу; строки
    # совместимы при любой ёмкости (проверка — в рантайме).
    func compat(var self, e: u32, a: u32) -> bool
        requires e < 512 and a < 512
        ensures true
    {
        if self.yk[e] == 6 and self.yk[a] == 6 {
            return true
        }
        return e == a
    }

    # --- области видимости (правила 6 и 10) --------------------------------

    func push_scope(var self)
        requires true
        ensures true
    {
        if self.nsc >= 64 {
            self.fail_at(1, 1, "слишком глубокие области видимости")
            return
        }
        self.scp[self.nsc] = self.nsv
        self.nsc = self.nsc + 1
    }

    func pop_scope(var self)
        requires self.nsc >= 1
        ensures true
    {
        let base: u32 = self.scp[self.nsc - 1]
        for i in 0..256 {
            if i >= self.nsv {
                break
            }
            if i >= base and not self.failed {
                if self.sv_u[i] == 0 and self.sv_s[i] != NONE {
                    self.fail_at(
                        self.sv_ln[i], self.sv_cl[i], "переменная не используется (правило 10)"
                    )
                }
            }
        }
        self.nsv = base
        self.nsc = self.nsc - 1
    }

    # Объявить переменную (sv_s = NONE — self). «_» не заносится.
    func declare(var self, nd: u32, a: u32, l: u32, ty: u32, mut: u32)
        requires nd < 131072 and ty < 512
        ensures true
    {
        if self.span_is(a, l, "_") {
            return
        }
        for i in 0..256 {
            if i >= self.nsv {
                break
            }
            if self.sv_s[i] != NONE {
                if self.span_eq(self.sv_s[i], self.sv_l[i], a, l) {
                    self.fail_node(nd, "имя уже объявлено: shadowing запрещён (правило 6)")
                }
            }
        }
        if self.find_const(a, l) != NONE or self.find_func(a, l) != NONE {
            self.fail_node(nd, "имя затеняет объявление верхнего уровня (правило 6)")
        }
        if self.io_builtin(a, l) {
            self.fail_node(nd, "имя затеняет объявление верхнего уровня (правило 6)")
        }
        if self.nsv >= 256 {
            self.fail_node(nd, "слишком много переменных")
            return
        }
        let v: u32 = self.nsv
        self.sv_s[v] = a
        self.sv_l[v] = l
        self.sv_t[v] = ty
        self.sv_m[v] = mut
        self.sv_u[v] = 0
        self.sv_ln[v] = self.p.nl[nd / 65536][nd % 65536]
        self.sv_cl[v] = self.p.nc[nd / 65536][nd % 65536]
        self.nsv = v + 1
    }

    func io_builtin(var self, a: u32, l: u32) -> bool
        requires true
        ensures true
    {
        if self.span_is(a, l, "print") or self.span_is(a, l, "write") {
            return true
        }
        if self.span_is(a, l, "read_byte") {
            return true
        }
        if self.span_is(a, l, "arg_count") or self.span_is(a, l, "arg_len") {
            return true
        }
        if self.span_is(a, l, "arg_byte") {
            return true
        }
        if self.span_is(a, l, "write_byte") or self.span_is(a, l, "write_err_byte") {
            return true
        }
        return self.span_is(a, l, "write_span") or self.span_is(a, l, "exit")
    }

    func decl_self(var self, ty: u32, mut: u32)
        requires ty < 512
        ensures true
    {
        let v: u32 = self.nsv
        self.sv_s[v] = NONE
        self.sv_l[v] = 0
        self.sv_t[v] = ty
        self.sv_m[v] = mut
        self.sv_u[v] = 1
        self.sv_ln[v] = 0
        self.sv_cl[v] = 0
        self.nsv = v + 1
    }

    # Поиск переменной; пометка «использована». NONE — нет.
    func lookup(var self, a: u32, l: u32) -> u32
        requires true
        ensures true
    {
        var found: u32 = NONE
        for i in 0..256 {
            if i >= self.nsv or found != NONE {
                break
            }
            if self.sv_s[i] != NONE {
                if self.span_eq(self.sv_s[i], self.sv_l[i], a, l) {
                    found = i
                }
            }
        }
        if found != NONE {
            self.sv_u[found] = 1
        }
        return found
    }

    func lookup_self(var self) -> u32
        requires true
        ensures true
    {
        var found: u32 = NONE
        for i in 0..256 {
            if i >= self.nsv or found != NONE {
                break
            }
            if self.sv_s[i] == NONE {
                found = i
            }
        }
        return found
    }

    # --- рёбра графа вызовов ------------------------------------------------

    func add_edge(var self, c: u32, d: u32)
        requires true
        ensures true
    {
        var dup: bool = false
        for i in 0..4096 {
            if i >= self.neg or dup {
                break
            }
            if self.eg_c[i] == c and self.eg_d[i] == d {
                dup = true
            }
        }
        if dup {
            return
        }
        if self.neg >= 4096 {
            self.fail_at(1, 1, "слишком много рёбер графа вызовов")
            return
        }
        self.eg_c[self.neg] = c
        self.eg_d[self.neg] = d
        self.neg = self.neg + 1
    }

    # --- машина выражений ---------------------------------------------------
    # Кадр: узел, фаза, ожидаемый тип (NONE — нет), aux xa/xb.
    # Результат кадра — self.tres; аннотация nty ставится при завершении.

    func nth_child(var self, n: u32, i: u32) -> u32
        requires n < 131072
        ensures true
    {
        var c: u32 = self.p.nfc[n / 65536][n % 65536]
        for k in 0..64 {
            if k >= i or c == NONE {
                break
            }
            c = self.p.nns[c / 65536][c % 65536]
        }
        return c
    }

    func nchildren(var self, n: u32) -> u32
        requires n < 131072
        ensures true
    {
        var c: u32 = self.p.nfc[n / 65536][n % 65536]
        var cnt: u32 = 0
        for _ in 0..64 {
            if c == NONE {
                break
            }
            cnt = cnt + 1
            c = self.p.nns[c / 65536][c % 65536]
        }
        return cnt
    }

    func xpush(var self, n: u32, exp: u32)
        requires n < 131072
        ensures true
    {
        if self.nxq >= 64 {
            self.fail_node(n, "слишком глубокое выражение")
            return
        }
        self.xn[self.nxq] = n
        self.xp[self.nxq] = 0
        self.xe[self.nxq] = exp
        self.xa[self.nxq] = 0
        self.xb[self.nxq] = 0
        self.nxq = self.nxq + 1
    }

    # Завершение кадра: аннотация, проверка void, pop.
    func xdone(var self)
        requires self.nxq >= 1
        ensures true
    {
        let f: u32 = self.nxq - 1
        let n: u32 = self.xn[f]
        self.nty[n / 65536][n % 65536] = self.tres
        if self.tres == 5 {
            if f != 0 or self.xvoid == 0 {
                self.fail_node(n, "функция ничего не возвращает — это не значение")
            }
        }
        self.nxq = f
    }

    # Типизировать выражение root; результат в tres (и nty[root]).
    func expr_check(var self, root: u32, exp: u32, voidok: u32)
        requires root < 131072
        ensures true
    {
        self.xvoid = voidok
        self.nxq = 0
        self.xpush(root, exp)
        # 32768: литерал Verify{...} в VerifyMain (~2500 узлов) требует
        # ~7500 шагов машины; 2048 хватало до самоприменения верификатора
        for _ in 0..32768 {
            if self.nxq == 0 or self.failed {
                break
            }
            self.xstep()
        }
        if self.nxq > 0 and not self.failed {
            self.fail_node(root, "выражение слишком велико для self-host")
        }
    }

    func expect_bool(var self, n: u32)
        requires n < 131072
        ensures true
    {
        self.expr_check(n, 3, 0)
        if not self.failed and self.tres != 3 {
            self.fail_node(n, "ожидается bool")
        }
    }

    func xstep(var self)
        requires self.nxq >= 1
        ensures true
    {
        let f: u32 = self.nxq - 1
        let n: u32 = self.xn[f]
        let k: u32 = self.p.nk[n / 65536][n % 65536]
        if k == 32 or k == 33 or k == 34 or k == 37 or k == 38 {
            self.xs_leaf(n, k)
        } elif k == 35 {
            self.xs_str(f, n)
        } elif k == 40 {
            self.xs_unary(f, n)
        } elif k == 39 {
            self.xs_binop(f, n)
        } elif k == 41 {
            self.xs_call(f, n)
        } elif k == 42 {
            self.xs_method(f, n)
        } elif k == 43 {
            self.xs_member(f, n)
        } elif k == 44 {
            self.xs_index(f, n)
        } elif k == 45 {
            self.xs_slit(f, n)
        } elif k == 47 {
            self.xs_alit(f, n)
        } elif k == 48 {
            self.xs_afill(f, n)
        } else {
            self.fail_node(n, "диапазон допустим только в for")
        }
    }

    func xs_leaf(var self, n: u32, k: u32)
        requires n < 131072
        ensures true
    {
        if k == 32 {
            let exp: u32 = self.xe[self.nxq - 1]
            var t: u32 = 0
            if exp != NONE and (self.yk[exp] <= 2 or self.yk[exp] >= 12) {
                t = exp
            }
            if not self.int_fits(t, self.p.ny[n / 65536][n % 65536], self.p.mag(n)) {
                self.fail_node(n, "литерал не помещается в тип")
            }
            self.tres = t
        } elif k == 33 {
            self.tres = 3
        } elif k == 34 {
            self.tres = 4
        } elif k == 38 {
            if self.self_ty2 == NONE {
                self.fail_node(n, "self доступен только в методе struct")
                self.tres = 0
            } else {
                self.tres = self.self_ty2
                let v: u32 = self.lookup_self()
                if v != NONE {
                    self.sv_u[v] = 1
                }
            }
        } else {
            self.xs_name(n)
        }
        self.xdone()
    }

    func xs_name(var self, n: u32)
        requires n < 131072
        ensures true
    {
        let a: u32 = self.p.nss[n / 65536][n % 65536]
        let l: u32 = self.p.nsl[n / 65536][n % 65536]
        if self.res_ty2 != NONE and self.span_is(a, l, "result") {
            self.tres = self.res_ty2
            return
        }
        let v: u32 = self.lookup(a, l)
        if v != NONE {
            self.tres = self.sv_t[v]
            return
        }
        if self.span_is(a, l, "None") {
            # конструктор None: только в контексте cr с ожидаемым Option
            let exp: u32 = self.xe[self.nxq - 1]
            var ok: bool = n == self.cr and exp != NONE
            if ok {
                if self.yk[exp] != 11 {
                    ok = false
                }
            }
            if not ok {
                self.fail_node(
                    n,
                    "None допустим только там, где ожидается Option: в return и в let с аннотацией"
                )
                self.tres = 0
                return
            }
            self.tres = exp
            return
        }
        let ci: u32 = self.find_const(a, l)
        if ci != NONE {
            self.tres = self.cty[ci]
            return
        }
        if self.find_func(a, l) != NONE or self.io_builtin(a, l) {
            self.fail_node(n, "функция, а не значение (правило 9)")
            self.tres = 0
            return
        }
        self.fail_node(n, "неизвестное имя")
        self.tres = 0
    }

    func xs_str(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        if self.xp[f] == 0 {
            self.xa[f] = self.p.nfc[n / 65536][n % 65536]
            self.xb[f] = 0
            self.xp[f] = 1
        } elif self.xp[f] == 2 {
            # выражение-сегмент готово: интерполируемый тип?
            let tk: u32 = self.yk[self.tres]
            if tk > 4 and tk != 6 and tk < 12 {
                self.fail_node(n, "нельзя интерполировать в строку (нет текстового представления)")
            }
            self.xb[f] = self.xb[f] % 2147483648 + 2147483648
            self.xp[f] = 1
        } else {
            let c: u32 = self.xa[f]
            if c == NONE {
                if self.xb[f] >= 2147483648 {
                    self.tres = self.ty_sq
                } else {
                    self.tres = self.intern(6, self.xb[f], NONE, NONE, 0)
                }
                self.xdone()
            } elif self.p.nk[c / 65536][c % 65536] == 36 {
                self.xb[f] = self.xb[f] + self.p.nsl[c / 65536][c % 65536]
                self.xa[f] = self.p.nns[c / 65536][c % 65536]
            } else {
                self.xa[f] = self.p.nns[c / 65536][c % 65536]
                self.xp[f] = 2
                self.xpush(c, NONE)
            }
        }
    }

    func xs_unary(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let op: u32 = self.p.nx[n / 65536][n % 65536]
        if self.xp[f] == 0 {
            self.xp[f] = 1
            if op == 3 {
                self.xpush(self.p.nfc[n / 65536][n % 65536], 3)
            } else {
                self.xpush(self.p.nfc[n / 65536][n % 65536], self.xe[f])
            }
        } else {
            if op == 3 {
                if self.tres != 3 {
                    self.fail_node(n, "операнд not: ожидается bool")
                }
                self.tres = 3
            } elif op == 21 {
                # как у битовых бинарных: только беззнаковые
                let bk: u32 = self.yk[self.tres]
                if bk != 1 and bk != 2 and bk != 12 and bk != 13 {
                    self.fail_node(n, "~ применим к u64/u32/u16/u8")
                }
            } else {
                let mk: u32 = self.yk[self.tres]
                if mk != 0 and mk != 14 {
                    self.fail_node(n, "унарный минус применим к i32/i64")
                    self.tres = 0
                }
            }
            self.xdone()
        }
    }

    func xs_binop(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let op: u32 = self.p.nx[n / 65536][n % 65536]
        let ph: u32 = self.xp[f]
        if op <= 2 { # or, and
            if ph == 0 {
                self.xp[f] = 1
                self.xpush(self.p.nfc[n / 65536][n % 65536], 3)
            } elif ph == 1 {
                if self.tres != 3 {
                    self.fail_node(n, "операнд and/or: ожидается bool")
                }
                self.xp[f] = 2
                self.xpush(
                    self.p.nns[self.p.nfc[n / 65536][n % 65536] / 65536][
                        self.p.nfc[n / 65536][n % 65536] % 65536
                    ],
                    3
                )
            } else {
                if self.tres != 3 {
                    self.fail_node(n, "операнд and/or: ожидается bool")
                }
                self.tres = 3
                self.xdone()
            }
            return
        }
        if ph == 0 {
            var hint: u32 = NONE
            if op >= 10 {
                if self.xe[f] != NONE and (self.yk[self.xe[f]] <= 2 or self.yk[self.xe[f]] >= 12) {
                    hint = self.xe[f]
                }
            }
            self.xp[f] = 1
            self.xpush(self.p.nfc[n / 65536][n % 65536], hint)
        } elif ph == 1 {
            self.xa[f] = self.tres
            self.xp[f] = 2
            self.xpush(
                self.p.nns[self.p.nfc[n / 65536][n % 65536] / 65536][
                    self.p.nfc[n / 65536][n % 65536] % 65536
                ],
                self.tres
            )
        } else {
            self.xs_binop_fin(n, op, self.xa[f])
        }
    }

    func xs_binop_fin(var self, n: u32, op: u32, left: u32)
        requires n < 131072 and left < 512
        ensures true
    {
        if not self.compat(left, self.tres) {
            self.fail_node(n, "разные типы (неявных преобразований нет)")
        }
        if op >= 16 { # битовые: только беззнаковые
            if (self.yk[left] != 1
                    and self.yk[left] != 2 and self.yk[left] != 12 and self.yk[left] != 13) {
                self.fail_node(n, "битовые операции применимы к u64/u32/u16/u8")
            }
            self.tres = left
            self.xdone()
            return
        }
        if op >= 10 { # арифметика
            if self.yk[left] > 2 and self.yk[left] < 12 {
                self.fail_node(n, "арифметика применима к целым")
            }
            self.tres = left
            self.xdone()
            return
        }
        if op >= 6 { # < <= > >=
            if self.yk[left] > 2 and self.yk[left] < 12 {
                self.fail_node(n, "порядок определён для целых")
            }
        } else { # == !=
            let tk: u32 = self.yk[left]
            if tk > 4 and tk != 6 and tk != 9 and tk < 12 {
                self.fail_node(n, "== не определено для этого типа")
            }
            if tk == 9 {
                if self.enum_has_payload(self.ys[left], self.yl[left]) {
                    self.fail_node(n, "== не определено для enum с нагрузкой — используйте match")
                }
            }
        }
        self.tres = 3
        self.xdone()
    }

    func enum_has_payload(var self, a: u32, l: u32) -> bool
        requires true
        ensures true
    {
        let ei: u32 = self.find_enum(a, l)
        if ei == NONE {
            return false
        }
        var has: bool = false
        for w in 0..256 {
            if w >= self.evs[ei] + self.evc[ei] {
                break
            }
            if w >= self.evs[ei] {
                if self.wpl[w] != NONE {
                    has = true
                }
            }
        }
        return has
    }

    # Вызов: коды xa — 100+каст(0/1/2), 104 char, 105 len, 106 print/write,
    # 107 — отставной (был parse_i32, ушёл в lib/Parse.eat; не
    # переиспользовать), 113 Ok, 114 Err, 115 Some (конструкторы;
    # новые — строго в конец), иначе fi пользовательской функции
    # (сдвиг +4096).
    func xs_call(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        if self.xp[f] == 0 {
            self.xs_call_start(f, n)
        } else {
            self.xs_call_next(f, n)
        }
    }

    func xs_call_start(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let a: u32 = self.p.nss[n / 65536][n % 65536]
        let l: u32 = self.p.nsl[n / 65536][n % 65536]
        let argc: u32 = self.nchildren(n)
        self.xp[f] = 1
        if self.span_is(a, l, "Ok") or self.span_is(a, l, "Err") or self.span_is(a, l, "Some") {
            self.xs_ctor_start(f, n, argc)
            return
        }
        if self.span_is(a, l, "None") {
            self.fail_node(n, "None не несёт значения — пишется без скобок")
            return
        }
        if (self.span_is(a, l, "i32")
                or self.span_is(a, l, "u32") or self.span_is(a, l, "u8")
                or self.span_is(a, l, "u16") or self.span_is(a, l, "u64")
                or self.span_is(a, l, "i64")) {
            if argc != 1 {
                self.fail_node(n, "каст: ровно один аргумент")
                return
            }
            var code: u32 = 100
            if self.span_is(a, l, "u32") {
                code = 101
            } elif self.span_is(a, l, "u8") {
                code = 102
            } elif self.span_is(a, l, "u16") {
                code = 103
            } elif self.span_is(a, l, "u64") {
                code = 111
            } elif self.span_is(a, l, "i64") {
                code = 112
            }
            self.xa[f] = code
            self.xpush(self.p.nfc[n / 65536][n % 65536], NONE)
            return
        }
        if self.span_is(a, l, "char") {
            if argc != 1 {
                self.fail_node(n, "char(): ровно один аргумент")
                return
            }
            self.xa[f] = 104
            self.xpush(self.p.nfc[n / 65536][n % 65536], 2)
            return
        }
        if self.span_is(a, l, "len") {
            if argc != 1 {
                self.fail_node(n, "len(): ровно один аргумент")
                return
            }
            self.xa[f] = 105
            self.xpush(self.p.nfc[n / 65536][n % 65536], NONE)
            return
        }
        self.xs_call_start2(f, n, argc)
    }

    # Конструкторы Ok/Err/Some (решение 2026-07-14): только там, где
    # ожидаемый тип известен точно — узел в cr (return, let с
    # аннотацией, payload вложенного конструктора); коды xa 113/114/115.
    func xs_ctor_start(var self, f: u32, n: u32, argc: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let a: u32 = self.p.nss[n / 65536][n % 65536]
        let l: u32 = self.p.nsl[n / 65536][n % 65536]
        let exp: u32 = self.xe[f]
        var code: u32 = 113
        if self.span_is(a, l, "Err") {
            code = 114
        } elif self.span_is(a, l, "Some") {
            code = 115
        }
        var want: u32 = 10
        if code == 115 {
            want = 11
        }
        var ok: bool = n == self.cr and exp != NONE
        if ok {
            if self.yk[exp] != want {
                ok = false
            }
        }
        if not ok {
            if code == 113 {
                self.fail_node(
                    n, "Ok допустим только там, где ожидается Result: в return и в let с аннотацией"
                )
            } elif code == 114 {
                self.fail_node(
                    n,
                    "Err допустим только там, где ожидается Result: в return и в let с аннотацией"
                )
            } else {
                self.fail_node(
                    n,
                    "Some допустим только там, где ожидается Option: в return и в let с аннотацией"
                )
            }
            return
        }
        if argc != 1 {
            if code == 113 {
                self.fail_node(
                    n, "Ok: ровно один аргумент (несколько значений — заверните в struct)"
                )
            } elif code == 114 {
                self.fail_node(
                    n, "Err: ровно один аргумент (несколько значений — заверните в struct)"
                )
            } else {
                self.fail_node(
                    n, "Some: ровно один аргумент (несколько значений — заверните в struct)"
                )
            }
            return
        }
        var payload: u32 = self.ya[exp]
        if code == 114 {
            payload = self.yb[exp]
        }
        self.xa[f] = code
        self.xb[f] = payload
        let arg: u32 = self.p.nfc[n / 65536][n % 65536]
        # payload вложенного конструктора — тоже контекст
        self.cr = arg
        self.xpush(arg, payload)
    }

    func xs_call_start2(var self, f: u32, n: u32, argc: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let a: u32 = self.p.nss[n / 65536][n % 65536]
        let l: u32 = self.p.nsl[n / 65536][n % 65536]
        if self.span_is(a, l, "print") or self.span_is(a, l, "write") {
            if argc != 1 {
                self.fail_node(n, "ожидается 1 аргумент")
                return
            }
            self.xa[f] = 106
            self.xpush(self.p.nfc[n / 65536][n % 65536], self.ty_sq)
            return
        }
        if self.span_is(a, l, "read_byte") {
            if argc != 0 {
                self.fail_node(n, "ожидается 0 аргументов")
                return
            }
            self.tres = self.ty_rb
            self.xdone()
            return
        }
        if self.span_is(a, l, "write_byte") or self.span_is(a, l, "write_err_byte") {
            if argc != 1 {
                self.fail_node(n, "ожидается 1 аргумент")
                return
            }
            self.xa[f] = 108
            self.xpush(self.p.nfc[n / 65536][n % 65536], 2)
            return
        }
        if self.span_is(a, l, "exit") {
            self.xs_exit_start(f, n, argc)
            return
        }
        if self.span_is(a, l, "write_span") {
            self.xs_ws_start(f, n, argc)
            return
        }
        if self.xs_arg_start(f, n, argc) {
            return
        }
        let fi: u32 = self.find_func(a, l)
        if fi == NONE {
            self.fail_node(n, "неизвестная функция")
            return
        }
        if argc != self.fpc[fi] {
            self.fail_node(n, "неверное число аргументов")
            return
        }
        # fi хранится со сдвигом 4096: коды встроенных (100..112) и
        # индексы функций живут в одном слоте xa — без сдвига функция
        # с fi 100..112 диспатчилась бы как встроенная
        self.xa[f] = fi + 4096
        self.xb[f] = 0
        if argc == 0 {
            self.xs_user_fin(fi)
        } else {
            self.xpush(self.p.nfc[n / 65536][n % 65536], self.pty[self.fps[fi]])
        }
    }

    # exit(code): только в main и не более одного раза (машина — код 109).
    func xs_exit_start(var self, f: u32, n: u32, argc: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        if argc != 1 {
            self.fail_node(n, "ожидается 1 аргумент")
            return
        }
        if self.cur_key != self.main_fi {
            self.fail_node(n, "exit допустим только в main")
            return
        }
        if self.nexit >= 1 {
            self.fail_node(n, "exit допустим не более одного раза на программу")
            return
        }
        self.nexit = self.nexit + 1
        self.xa[f] = 109
        self.xpush(self.p.nfc[n / 65536][n % 65536], 1)
    }

    # Аргументы командной строки: arg_count (0 арг, u32), arg_len
    # (1 арг u32, код 116), arg_byte (2 арг u32, код 117 → u8).
    func xs_arg_start(var self, f: u32, n: u32, argc: u32) -> bool
        requires f < 64 and n < 131072
        ensures true
    {
        let a: u32 = self.p.nss[n / 65536][n % 65536]
        let l: u32 = self.p.nsl[n / 65536][n % 65536]
        if self.span_is(a, l, "arg_count") {
            if argc != 0 {
                self.fail_node(n, "ожидается 0 аргументов")
                return true
            }
            self.tres = 1
            self.xdone()
            return true
        }
        if self.span_is(a, l, "arg_len") {
            if argc != 1 {
                self.fail_node(n, "ожидается 1 аргумент")
                return true
            }
            self.xa[f] = 116
            self.xpush(self.p.nfc[n / 65536][n % 65536], 1)
            return true
        }
        if self.span_is(a, l, "arg_byte") {
            if argc != 2 {
                self.fail_node(n, "ожидается 2 аргумента")
                return true
            }
            self.xa[f] = 117
            self.xb[f] = 0
            self.xpush(self.p.nfc[n / 65536][n % 65536], 1)
            return true
        }
        return false
    }

    # write_span(a, off, len): три аргумента, машина — код 110.
    func xs_ws_start(var self, f: u32, n: u32, argc: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        if argc != 3 {
            self.fail_node(n, "write_span(): ровно три аргумента")
            return
        }
        self.xa[f] = 110
        self.xb[f] = 0
        self.xpush(self.p.nfc[n / 65536][n % 65536], NONE)
    }

    func xs_call_next(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let code: u32 = self.xa[f]
        if code == 100 or code == 101 or code == 102 or code == 103 or code == 111 or code == 112 {
            let sk: u32 = self.yk[self.tres]
            if sk == 4 {
                if code != 102 {
                    self.fail_node(n, "каст не применим к char — код символа даёт u8(c)")
                }
                self.tres = 2
            } elif sk <= 2 or sk >= 12 {
                if code == 103 {
                    self.tres = self.u16_ty()
                } elif code == 111 {
                    self.tres = self.u64_ty()
                } elif code == 112 {
                    self.tres = self.i64_ty()
                } else {
                    self.tres = code - 100
                }
            } else {
                self.fail_node(n, "каст преобразует целые")
                self.tres = 0
            }
            self.xdone()
        } elif code == 104 {
            if self.tres != 2 {
                self.fail_node(n, "char() принимает u8 (сузьте явно через u8())")
            }
            self.tres = 4
            self.xdone()
        } elif code == 105 {
            let sk2: u32 = self.yk[self.tres]
            if sk2 != 6 and sk2 != 7 {
                self.fail_node(n, "len() применим к массиву или строке")
            }
            self.tres = 1
            self.xdone()
        } elif code == 106 {
            if not self.compat(self.ty_sq, self.tres) {
                self.fail_node(n, "ожидается строка")
            }
            self.tres = 5
            self.xdone()
        } elif code == 108 {
            if not self.compat(2, self.tres) {
                self.fail_node(n, "write_byte() принимает u8")
            }
            self.tres = 5
            self.xdone()
        } elif code == 109 {
            if not self.compat(1, self.tres) {
                self.fail_node(n, "exit() принимает u32")
            }
            self.tres = 5
            self.xdone()
        } elif code == 110 {
            let wi: u32 = self.xb[f]
            if wi == 0 {
                if self.yk[self.tres] != 7 or self.ya[self.tres] != 2 {
                    self.fail_node(n, "write_span() пишет из массива u8")
                }
            } elif not self.compat(1, self.tres) {
                self.fail_node(n, "write_span(): смещение и длина — u32")
            }
            if wi >= 2 {
                self.tres = 5
                self.xdone()
            } else {
                self.xb[f] = wi + 1
                self.xpush(self.nth_child(n, wi + 1), 1)
            }
        } elif code == 113 or code == 114 or code == 115 {
            # конструктор Ok/Err/Some: payload готов (тип в xb)
            if not self.compat(self.xb[f], self.tres) {
                self.fail_node(n, "тип значения не совпадает (неявных преобразований нет)")
            }
            self.tres = self.xe[f]
            self.xdone()
        } elif code == 116 or code == 117 {
            self.xs_arg_next(f, n, code)
        } else {
            self.xs_user_arg(f, n, code - 4096)
        }
    }

    # Финализация arg_len (116, → u32) и arg_byte (117, 2 арг → u8).
    func xs_arg_next(var self, f: u32, n: u32, code: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        if code == 116 {
            if not self.compat(1, self.tres) {
                self.fail_node(n, "arg_len() принимает u32")
            }
            self.tres = 1
            self.xdone()
            return
        }
        if not self.compat(1, self.tres) {
            self.fail_node(n, "arg_byte(): индексы — u32")
        }
        let ai: u32 = self.xb[f]
        if ai >= 1 {
            self.tres = 2
            self.xdone()
        } else {
            self.xb[f] = 1
            self.xpush(self.nth_child(n, 1), 1)
        }
    }

    # Очередной аргумент пользовательской функции готов.
    func xs_user_arg(var self, f: u32, n: u32, fi: u32)
        requires f < 64 and n < 131072 and fi < 1024
        ensures true
    {
        let i: u32 = self.xb[f]
        if not self.compat(self.pty[self.fps[fi] + i], self.tres) {
            self.fail_node(n, "тип аргумента не совпадает с параметром")
        }
        let nx2: u32 = i + 1
        if nx2 >= self.fpc[fi] {
            self.xs_user_fin(fi)
            return
        }
        self.xb[f] = nx2
        self.xpush(self.nth_child(n, nx2), self.pty[self.fps[fi] + nx2])
    }

    func xs_user_fin(var self, fi: u32)
        requires fi < 1024
        ensures true
    {
        self.add_edge(self.cur_key, fi)
        if self.fret[fi] == NONE {
            self.tres = 5
        } else {
            self.tres = self.fret[fi]
        }
        self.xdone()
    }

    # Имя — enum (пользовательский или встроенный)?
    func is_enum_name(var self, a: u32, l: u32) -> bool
        requires true
        ensures true
    {
        if self.find_enum(a, l) != NONE {
            return true
        }
        return self.span_is(a, l, "IoError") or self.span_is(a, l, "ParseError")
    }

    # Вариант enum по имени; NONE если нет. Встроенные — без нагрузки.
    func variant_of(var self, ea: u32, el: u32, va: u32, vl: u32) -> u32
        requires true
        ensures true
    {
        let ei: u32 = self.find_enum(ea, el)
        if ei == NONE {
            # встроенные: вариант «существует без нагрузки» → 999
            if self.builtin_variant(ea, el, va, vl) {
                return 999
            }
            return NONE
        }
        var found: u32 = NONE
        for w in 0..256 {
            if w >= self.evs[ei] + self.evc[ei] or found != NONE {
                break
            }
            if w >= self.evs[ei] {
                if self.span_eq(self.wn_s[w], self.wn_l[w], va, vl) {
                    found = w
                }
            }
        }
        return found
    }

    func builtin_variant(var self, ea: u32, el: u32, va: u32, vl: u32) -> bool
        requires true
        ensures true
    {
        if self.span_is(ea, el, "IoError") {
            return self.span_is(va, vl, "Eof") or self.span_is(va, vl, "Fail")
        }
        if self.span_is(va, vl, "Empty") or self.span_is(va, vl, "BadChar") {
            return true
        }
        return self.span_is(va, vl, "Overflow")
    }

    # Метод / конструктор варианта enum. Фазы: 0 старт; 1 объект готов;
    # 2+ аргументы; 9 аргумент конструктора готов.
    func xs_method(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let ph: u32 = self.xp[f]
        let obj: u32 = self.p.nfc[n / 65536][n % 65536]
        if ph == 0 {
            if self.p.nk[obj / 65536][obj % 65536] == 37 {
                if self.is_enum_name(
                    self.p.nss[obj / 65536][obj % 65536], self.p.nsl[obj / 65536][obj % 65536]
                ) {
                    self.xs_enum_ctor(f, n, obj)
                    return
                }
            }
            self.xp[f] = 1
            self.xpush(obj, NONE)
        } elif ph == 1 {
            self.xs_method_obj(f, n)
        } elif ph == 9 {
            if not self.compat(self.xa[f], self.tres) {
                self.fail_node(n, "нагрузка варианта другого типа")
            }
            self.tres = self.xb[f]
            self.xdone()
        } else {
            self.xs_marg(f, n, self.xa[f])
        }
    }

    func xs_enum_ctor(var self, f: u32, n: u32, obj: u32)
        requires f < 64 and n < 131072 and obj < 131072
        ensures true
    {
        let w: u32 = self.variant_of(
            self.p.nss[obj / 65536][obj % 65536], self.p.nsl[obj / 65536][obj % 65536],
            self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
        )
        if w == NONE {
            self.fail_node(n, "у enum нет такого варианта")
            return
        }
        if w == 999 or self.wpl[w] == NONE {
            self.fail_node(n, "вариант не несёт значения — литерал пишется без скобок")
            return
        }
        if self.nchildren(n) != 2 {
            self.fail_node(n, "конструктор варианта: ровно один аргумент")
            return
        }
        self.xa[f] = self.wpl[w]
        self.xb[f] = self.intern(
            9, NONE, NONE, self.p.nss[obj / 65536][obj % 65536],
            self.p.nsl[obj / 65536][obj % 65536]
        )
        self.xp[f] = 9
        self.xpush(self.p.nns[obj / 65536][obj % 65536], self.wpl[w])
    }

    func xs_method_obj(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        if self.yk[self.tres] != 8 {
            self.fail_node(n, "метод вызван не у struct")
            return
        }
        let si: u32 = self.find_struct(self.ys[self.tres], self.yl[self.tres])
        let mfi: u32 = self.fh_find(
            si, self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
        )
        if mfi == NONE {
            self.fail_node(n, "у struct нет такого метода")
            return
        }
        if self.fvs[mfi] == 1 {
            self.check_receiver(n)
        }
        if self.nchildren(n) != self.fpc[mfi] + 1 {
            self.fail_node(n, "неверное число аргументов")
            return
        }
        self.xa[f] = mfi
        self.xb[f] = 0
        if self.fpc[mfi] == 0 {
            self.xs_user_fin(mfi)
        } else {
            self.xp[f] = 2
            self.xpush(self.nth_child(n, 1), self.pty[self.fps[mfi]])
        }
    }

    func xs_marg(var self, f: u32, n: u32, mfi: u32)
        requires f < 64 and n < 131072 and mfi < 1024
        ensures true
    {
        let i: u32 = self.xb[f]
        if not self.compat(self.pty[self.fps[mfi] + i], self.tres) {
            self.fail_node(n, "тип аргумента не совпадает с параметром")
        }
        let nx2: u32 = i + 1
        if nx2 >= self.fpc[mfi] {
            self.xs_user_fin(mfi)
            return
        }
        self.xb[f] = nx2
        self.xpush(self.nth_child(n, nx2 + 1), self.pty[self.fps[mfi] + nx2])
    }

    # Метод с var self: получатель обязан быть изменяемым lvalue.
    func check_receiver(var self, n: u32)
        requires n < 131072
        ensures true
    {
        var base: u32 = self.p.nfc[n / 65536][n % 65536]
        for _ in 0..32 {
            if (self.p.nk[base / 65536][base % 65536] != 43
                    and self.p.nk[base / 65536][base % 65536] != 44) {
                break
            }
            base = self.p.nfc[base / 65536][base % 65536]
        }
        let bk: u32 = self.p.nk[base / 65536][base % 65536]
        if bk == 38 {
            if self.self_mu != 1 {
                self.fail_node(n, "метод с var self внутри немутирующего метода")
            }
            return
        }
        if bk == 37 {
            let v: u32 = self.lookup(
                self.p.nss[base / 65536][base % 65536], self.p.nsl[base / 65536][base % 65536]
            )
            if v == NONE or self.sv_m[v] != 1 {
                self.fail_node(n, "метод с var self: получатель — let (неизменяем)")
            }
            return
        }
        self.fail_node(n, "метод с var self: получатель обязан быть изменяемой переменной")
    }

    func xs_member(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let obj: u32 = self.p.nfc[n / 65536][n % 65536]
        if self.xp[f] == 0 {
            if self.p.nk[obj / 65536][obj % 65536] == 37 {
                if self.is_enum_name(
                    self.p.nss[obj / 65536][obj % 65536], self.p.nsl[obj / 65536][obj % 65536]
                ) {
                    let w: u32 = self.variant_of(
                        self.p.nss[obj / 65536][obj % 65536], self.p.nsl[obj / 65536][obj % 65536],
                        self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
                    )
                    if w == NONE {
                        self.fail_node(n, "у enum нет такого варианта")
                        return
                    }
                    self.tres = self.intern(
                        9, NONE, NONE, self.p.nss[obj / 65536][obj % 65536],
                        self.p.nsl[obj / 65536][obj % 65536]
                    )
                    self.xdone()
                    return
                }
            }
            self.xp[f] = 1
            self.xpush(obj, NONE)
        } else {
            if self.yk[self.tres] != 8 {
                self.fail_node(n, "у этого типа нет полей (это не struct)")
                return
            }
            let si: u32 = self.find_struct(self.ys[self.tres], self.yl[self.tres])
            let g: u32 = self.field_of(
                si, self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
            )
            if g == NONE {
                self.fail_node(n, "у struct нет такого поля")
                return
            }
            self.tres = self.gty[g]
            self.xdone()
        }
    }

    func field_of(var self, si: u32, a: u32, l: u32) -> u32
        requires si < 128
        ensures true
    {
        var found: u32 = NONE
        for g in 0..1024 {
            if g >= self.sgs[si] + self.sgc[si] or found != NONE {
                break
            }
            if g >= self.sgs[si] {
                if self.span_eq(self.gn_s[g], self.gn_l[g], a, l) {
                    found = g
                }
            }
        }
        return found
    }

    func xs_index(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let ph: u32 = self.xp[f]
        if ph == 0 {
            self.xp[f] = 1
            self.xpush(self.p.nfc[n / 65536][n % 65536], NONE)
        } elif ph == 1 {
            self.xa[f] = self.tres
            self.xp[f] = 2
            self.xpush(
                self.p.nns[self.p.nfc[n / 65536][n % 65536] / 65536][
                    self.p.nfc[n / 65536][n % 65536] % 65536
                ],
                1
            )
        } else {
            if self.yk[self.tres] > 2 and self.yk[self.tres] < 12 {
                self.fail_node(n, "индекс — целое")
            }
            let ok2: u32 = self.xa[f]
            if self.yk[ok2] == 7 {
                self.tres = self.ya[ok2]
            } elif self.yk[ok2] == 6 {
                self.tres = 4
            } else {
                self.fail_node(n, "индексирование применимо к массиву или строке")
                self.tres = 0
            }
            self.xdone()
        }
    }

    # Struct-литерал: xa — текущий fld-ребёнок, xb — тип текущего поля.
    func xs_slit(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let ph: u32 = self.xp[f]
        if ph == 0 {
            let si: u32 = self.find_struct(
                self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
            )
            if si == NONE {
                self.fail_node(n, "неизвестный struct")
                return
            }
            self.slit_fields_ok(n, si)
            if self.failed {
                return
            }
            self.xa[f] = self.p.nfc[n / 65536][n % 65536]
            self.xp[f] = 1
        } elif ph == 2 {
            if not self.compat(self.xb[f], self.tres) {
                self.fail_node(n, "поле другого типа")
            }
            self.xp[f] = 1
        } else {
            let c: u32 = self.xa[f]
            if c == NONE {
                self.tres = self.intern(
                    8, NONE, NONE, self.p.nss[n / 65536][n % 65536],
                    self.p.nsl[n / 65536][n % 65536]
                )
                self.xdone()
                return
            }
            let si2: u32 = self.find_struct(
                self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536]
            )
            let g: u32 = self.field_of(
                si2, self.p.nss[c / 65536][c % 65536], self.p.nsl[c / 65536][c % 65536]
            )
            self.xa[f] = self.p.nns[c / 65536][c % 65536]
            self.xb[f] = self.gty[g]
            self.xp[f] = 2
            self.xpush(self.p.nfc[c / 65536][c % 65536], self.gty[g])
        }
    }

    # Литерал: без повторов, без лишних, все поля struct на месте.
    func slit_fields_ok(var self, n: u32, si: u32)
        requires n < 131072 and si < 128
        ensures true
    {
        var c: u32 = self.p.nfc[n / 65536][n % 65536]
        var cnt: u32 = 0
        for _ in 0..512 {
            if c == NONE or self.failed {
                break
            }
            var w: u32 = self.p.nns[c / 65536][c % 65536]
            for _ in 0..512 {
                if w == NONE {
                    break
                }
                if self.span_eq(
                    self.p.nss[c / 65536][c % 65536], self.p.nsl[c / 65536][c % 65536],
                    self.p.nss[w / 65536][w % 65536], self.p.nsl[w / 65536][w % 65536]
                ) {
                    self.fail_node(n, "поле повторяется в литерале")
                }
                w = self.p.nns[w / 65536][w % 65536]
            }
            if self.field_of(
                si, self.p.nss[c / 65536][c % 65536], self.p.nsl[c / 65536][c % 65536]
            ) == NONE {
                self.fail_node(n, "лишнее поле в литерале")
            }
            cnt = cnt + 1
            c = self.p.nns[c / 65536][c % 65536]
        }
        if cnt != self.sgc[si] and not self.failed {
            self.fail_node(n, "в литерале не хватает полей")
        }
    }

    # Массив-литерал: xa — текущий ребёнок, xb — тип первого элемента.
    func xs_alit(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let ph: u32 = self.xp[f]
        let exp: u32 = self.xe[f]
        if ph == 0 {
            var hint: u32 = NONE
            if exp != NONE and self.yk[exp] == 7 {
                hint = self.ya[exp]
            }
            self.xa[f] = self.p.nfc[n / 65536][n % 65536]
            self.xp[f] = 1
            self.xpush(self.p.nfc[n / 65536][n % 65536], hint)
        } elif ph == 1 {
            self.xb[f] = self.tres
            self.xa[f] = self.p.nns[self.xa[f] / 65536][self.xa[f] % 65536]
            self.xp[f] = 2
        } elif ph == 3 {
            if not self.compat(self.xb[f], self.tres) {
                self.fail_node(n, "элементы массива разных типов")
            }
            self.xa[f] = self.p.nns[self.xa[f] / 65536][self.xa[f] % 65536]
            self.xp[f] = 2
        } else {
            let c: u32 = self.xa[f]
            if c == NONE {
                let cnt: u32 = self.nchildren(n)
                if exp != NONE and self.yk[exp] == 7 {
                    if self.yb[exp] != cnt {
                        self.fail_node(n, "число элементов массива не совпадает с типом")
                    }
                }
                self.tres = self.intern(7, self.xb[f], cnt, NONE, 0)
                self.xdone()
            } else {
                self.xp[f] = 3
                self.xpush(c, self.xb[f])
            }
        }
    }

    func xs_afill(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let exp: u32 = self.xe[f]
        if self.xp[f] == 0 {
            self.const_eval(
                self.p.nns[self.p.nfc[n / 65536][n % 65536] / 65536][
                    self.p.nfc[n / 65536][n % 65536] % 65536
                ]
            )
            if self.failed {
                return
            }
            if self.ces == 1 or self.cem == 0 or self.cem > 65536 {
                self.fail_node(n, "размер массива вне (0, 65536]")
                return
            }
            self.xb[f] = u32(self.cem)
            var hint: u32 = NONE
            if exp != NONE and self.yk[exp] == 7 {
                hint = self.ya[exp]
            }
            self.xp[f] = 1
            self.xpush(self.p.nfc[n / 65536][n % 65536], hint)
        } else {
            if exp != NONE and self.yk[exp] == 7 {
                if self.yb[exp] != self.xb[f] {
                    self.fail_node(n, "число элементов массива не совпадает с типом")
                }
            }
            self.tres = self.intern(7, self.tres, self.xb[f], NONE, 0)
            self.xdone()
        }
    }

    # --- машина инструкций ---------------------------------------------------
    # Кадры (qk2): 0 блок, 1 if, 2 for, 3 match, 4 loop.
    # Биты aux блока: 1 своя область, 2 finished, 4 «возвращает».

    func qpush(var self, k: u32, node: u32, cursor: u32, aux: u32)
        requires k <= 4 and node < 131072
        ensures true
    {
        if self.nq >= 128 {
            self.fail_node(node, "слишком глубокая вложенность")
            return
        }
        self.qk2[self.nq] = k
        self.qn[self.nq] = node
        self.qp[self.nq] = cursor
        self.qx[self.nq] = aux
        self.qy[self.nq] = NONE
        self.nq = self.nq + 1
    }

    func start_block_frame(var self, body: u32, ns: u32)
        requires body < 131072 and ns <= 1
        ensures true
    {
        if ns == 1 {
            self.push_scope()
        }
        self.qpush(0, body, self.p.nfc[body / 65536][body % 65536], ns)
    }

    func run_block_machine(var self, body: u32, ns: u32)
        requires body < 131072 and ns <= 1
        ensures true
    {
        self.nq = 0
        self.start_block_frame(body, ns)
        for _ in 0..4096 {
            if self.nq == 0 or self.failed {
                break
            }
            self.qstep()
        }
        if self.nq > 0 and not self.failed {
            self.fail_node(body, "тело функции слишком велико для self-host")
        }
    }

    func qstep(var self)
        requires self.nq >= 1
        ensures true
    {
        let k: u32 = self.qk2[self.nq - 1]
        if k == 0 {
            self.q_block()
        } elif k == 1 {
            self.q_if()
        } elif k == 2 {
            self.q_for_end()
        } elif k == 3 {
            self.q_match()
        } else {
            self.q_loop_end()
        }
    }

    # call-statement exit(...): управление не возвращается (правило 10).
    func stmt_is_exit(var self, st: u32) -> bool
        requires st < 131072
        ensures true
    {
        if self.p.nk[st / 65536][st % 65536] != 25 {
            return false
        }
        let cal: u32 = self.p.nfc[st / 65536][st % 65536]
        if self.p.nk[cal / 65536][cal % 65536] != 41 {
            return false
        }
        return self.span_is(
            self.p.nss[cal / 65536][cal % 65536], self.p.nsl[cal / 65536][cal % 65536], "exit"
        )
    }

    func q_block(var self)
        requires self.nq >= 1
        ensures true
    {
        let f: u32 = self.nq - 1
        let last: u32 = self.qy[f]
        if last != NONE {
            if (self.nrt[last / 65536][last % 65536] == 1
                    or self.p.nk[last / 65536][last % 65536] == 23 or self.stmt_is_exit(last)) {
                if self.qx[f] / 2 % 2 == 0 {
                    self.qx[f] = self.qx[f] + 2
                }
            }
            if self.nrt[last / 65536][last % 65536] == 1 {
                if self.qx[f] / 4 % 2 == 0 {
                    self.qx[f] = self.qx[f] + 4
                }
            }
            self.qy[f] = NONE
        }
        let cur: u32 = self.qp[f]
        if cur == NONE {
            self.nrt[self.qn[f] / 65536][self.qn[f] % 65536] = self.qx[f] / 4 % 2
            if self.qx[f] % 2 == 1 {
                self.pop_scope()
            }
            self.nq = f
            return
        }
        if self.qx[f] / 2 % 2 == 1 {
            self.fail_node(cur, "недостижимый код после return/break (правило 10)")
            return
        }
        self.qp[f] = self.p.nns[cur / 65536][cur % 65536]
        self.qy[f] = cur
        self.check_stmt(cur)
    }

    func check_stmt(var self, cur: u32)
        requires cur < 131072
        ensures true
    {
        let k: u32 = self.p.nk[cur / 65536][cur % 65536]
        if k == 13 {
            self.q_let(cur)
        } elif k == 14 {
            self.q_assign(cur)
        } elif k == 15 {
            self.expect_bool(self.p.nfc[cur / 65536][cur % 65536])
            if not self.failed {
                self.qpush(
                    1, cur,
                    self.p.nns[self.p.nfc[cur / 65536][cur % 65536] / 65536][
                        self.p.nfc[cur / 65536][cur % 65536] % 65536
                    ],
                    0
                )
            }
        } elif k == 18 {
            self.q_for_start(cur)
        } elif k == 19 {
            if self.cur_key != self.main_fi {
                self.fail_node(cur, "loop допустим только в main (правило 2)")
                return
            }
            self.loopd = self.loopd + 1
            self.brkc[self.loopd - 1] = 0
            self.qpush(4, cur, NONE, 0)
            self.start_block_frame(self.p.nfc[cur / 65536][cur % 65536], 1)
        } elif k == 20 {
            self.q_match_start(cur)
        } elif k == 22 {
            self.q_return(cur)
        } elif k == 23 {
            if self.loopd == 0 {
                self.fail_node(cur, "break вне цикла")
            } else {
                self.brkc[self.loopd - 1] = self.brkc[self.loopd - 1] + 1
                if self.brkc[self.loopd - 1] > 1 {
                    self.fail_node(cur, "не более одного break на цикл (правило 1)")
                }
            }
        } elif k == 24 {
            self.expect_bool(self.p.nfc[cur / 65536][cur % 65536])
        } elif k == 25 {
            self.expr_check(self.p.nfc[cur / 65536][cur % 65536], NONE, 1)
            if not self.failed and self.tres != 5 {
                self.fail_node(
                    cur, "результат отброшен молча; используйте значение или discard (правило 7)"
                )
            }
        } else {
            self.expr_check(self.p.nfc[cur / 65536][cur % 65536], NONE, 1)
            if not self.failed and self.tres == 5 {
                self.fail_node(cur, "discard бессмыслен: функция ничего не возвращает")
            }
        }
    }

    func q_let(var self, cur: u32)
        requires cur < 131072
        ensures true
    {
        let ty: u32 = self.resolve(self.p.nfc[cur / 65536][cur % 65536])
        if self.failed {
            return
        }
        self.nty[cur / 65536][cur % 65536] = ty
        let value: u32 = self.p.nns[self.p.nfc[cur / 65536][cur % 65536] / 65536][
            self.p.nfc[cur / 65536][cur % 65536] % 65536
        ]
        # let с аннотацией — контекст конструкторов Ok/Err/Some/None
        self.cr = value
        self.expr_check(value, ty, 0)
        if self.failed {
            return
        }
        if not self.compat(ty, self.tres) {
            self.fail_node(cur, "тип значения не совпадает (неявных преобразований нет)")
            return
        }
        self.declare(
            cur, self.p.nss[cur / 65536][cur % 65536], self.p.nsl[cur / 65536][cur % 65536], ty,
            self.p.nx[cur / 65536][cur % 65536]
        )
    }

    func q_assign(var self, cur: u32)
        requires cur < 131072
        ensures true
    {
        let tgt: u32 = self.p.nfc[cur / 65536][cur % 65536]
        self.expr_check(tgt, NONE, 0)
        if self.failed {
            return
        }
        let tt: u32 = self.tres
        var base: u32 = tgt
        for _ in 0..32 {
            if (self.p.nk[base / 65536][base % 65536] != 43
                    and self.p.nk[base / 65536][base % 65536] != 44) {
                break
            }
            base = self.p.nfc[base / 65536][base % 65536]
        }
        let bk: u32 = self.p.nk[base / 65536][base % 65536]
        if bk == 38 {
            let v: u32 = self.lookup_self()
            if v == NONE or self.sv_m[v] != 1 {
                self.fail_node(cur, "self неизменяем: мутирующий метод — func имя(var self, ...)")
                return
            }
        } elif bk == 37 {
            let v2: u32 = self.lookup(
                self.p.nss[base / 65536][base % 65536], self.p.nsl[base / 65536][base % 65536]
            )
            if v2 == NONE {
                self.fail_node(base, "неизвестное имя")
                return
            }
            if self.sv_m[v2] != 1 {
                self.fail_node(cur, "объявлена как let — неизменяема (мутабельность — это var)")
                return
            }
        } else {
            self.fail_node(cur, "некорректная цель присваивания")
            return
        }
        self.expr_check(self.p.nns[tgt / 65536][tgt % 65536], tt, 0)
        if not self.failed and not self.compat(tt, self.tres) {
            self.fail_node(cur, "тип значения не совпадает (неявных преобразований нет)")
        }
    }

    func q_if(var self)
        requires self.nq >= 1
        ensures true
    {
        let f: u32 = self.nq - 1
        let cur: u32 = self.qp[f]
        if cur == NONE {
            self.nrt[self.qn[f] / 65536][self.qn[f] % 65536] = self.if_returns(self.qn[f])
            self.nq = f
            return
        }
        self.qp[f] = self.p.nns[cur / 65536][cur % 65536]
        let k: u32 = self.p.nk[cur / 65536][cur % 65536]
        if k == 12 {
            self.start_block_frame(cur, 1)
        } elif k == 16 {
            self.expect_bool(self.p.nfc[cur / 65536][cur % 65536])
            if not self.failed {
                self.start_block_frame(
                    self.p.nns[self.p.nfc[cur / 65536][cur % 65536] / 65536][
                        self.p.nfc[cur / 65536][cur % 65536] % 65536
                    ],
                    1
                )
            }
        } elif k == 17 {
            self.start_block_frame(self.p.nfc[cur / 65536][cur % 65536], 1)
        }
    }

    func if_returns(var self, n: u32) -> u32
        requires n < 131072
        ensures result <= 1
    {
        var has_else: bool = false
        var all: u32 = 1
        var c: u32 = self.p.nfc[n / 65536][n % 65536]
        for _ in 0..64 {
            if c == NONE {
                break
            }
            let k: u32 = self.p.nk[c / 65536][c % 65536]
            if k == 12 {
                all = all * self.nrt[c / 65536][c % 65536]
            } elif k == 16 {
                all = all * self.nrt[
                    self.p.nns[self.p.nfc[c / 65536][c % 65536] / 65536][
                        self.p.nfc[c / 65536][c % 65536] % 65536
                    ] / 65536
                ][
                    self.p.nns[self.p.nfc[c / 65536][c % 65536] / 65536][
                        self.p.nfc[c / 65536][c % 65536] % 65536
                    ] % 65536
                ]
            } elif k == 17 {
                has_else = true
                all = all * self.nrt[self.p.nfc[c / 65536][c % 65536] / 65536][
                    self.p.nfc[c / 65536][c % 65536] % 65536
                ]
            }
            c = self.p.nns[c / 65536][c % 65536]
        }
        if has_else {
            return all
        }
        return 0
    }

    # Знаковое сравнение (s1,m1) < (s2,m2).
    func slt(var self, s1: u32, m1: u64, s2: u32, m2: u64) -> bool
        requires true
        ensures true
    {
        if s1 == 1 and s2 == 0 {
            return true
        }
        if s1 == 0 and s2 == 1 {
            return false
        }
        if s1 == 0 {
            return m1 < m2
        }
        return m1 > m2
    }

    func q_for_start(var self, cur: u32)
        requires cur < 131072
        ensures true
    {
        self.loopd = self.loopd + 1
        self.brkc[self.loopd - 1] = 0
        let it: u32 = self.p.nfc[cur / 65536][cur % 65536]
        var elem: u32 = 1
        if self.p.nk[it / 65536][it % 65536] == 49 {
            self.const_eval(self.p.nfc[it / 65536][it % 65536])
            let s1: u32 = self.ces
            let m1: u64 = self.cem
            self.const_eval(
                self.p.nns[self.p.nfc[it / 65536][it % 65536] / 65536][
                    self.p.nfc[it / 65536][it % 65536] % 65536
                ]
            )
            if self.failed {
                return
            }
            if self.slt(self.ces, self.cem, s1, m1) {
                self.fail_node(it, "пустой диапазон")
                return
            }
            if s1 == 1 and m1 != 0 {
                # старт < 0: i32, при выходе границ за i32 — i64
                elem = 0
                if m1 > 2147483648 or (self.ces == 0 and self.cem > 2147483647) {
                    elem = self.i64_ty()
                }
            } elif self.ces == 0 and self.cem > 4294967295 {
                elem = self.u64_ty()
            }
            if not self.int_fits(elem, s1, m1) or not self.int_fits(elem, self.ces, self.cem) {
                self.fail_node(it, "граница диапазона не помещается в тип")
                return
            }
            if self.nrb >= 512 {
                self.fail_node(cur, "слишком много for-диапазонов")
                return
            }
            self.rb_n[self.nrb] = cur
            self.rb_ss[self.nrb] = s1
            self.rb_sm[self.nrb] = m1
            self.rb_es[self.nrb] = self.ces
            self.rb_em[self.nrb] = self.cem
            self.nrb = self.nrb + 1
        } else {
            self.expr_check(it, NONE, 0)
            if self.failed {
                return
            }
            if self.yk[self.tres] == 7 {
                elem = self.ya[self.tres]
            } elif self.yk[self.tres] == 6 {
                elem = 4
            } else {
                self.fail_node(it, "итерация возможна по диапазону, массиву или строке")
                return
            }
        }
        self.nty[cur / 65536][cur % 65536] = elem
        self.push_scope()
        self.declare(
            cur, self.p.nss[cur / 65536][cur % 65536], self.p.nsl[cur / 65536][cur % 65536], elem, 0
        )
        self.qpush(2, cur, NONE, 0)
        self.start_block_frame(self.p.nns[it / 65536][it % 65536], 0)
    }

    func q_for_end(var self)
        requires self.nq >= 1
        ensures true
    {
        self.loopd = self.loopd - 1
        self.pop_scope()
        self.nq = self.nq - 1
    }

    func q_loop_end(var self)
        requires self.nq >= 1
        ensures true
    {
        self.loopd = self.loopd - 1
        self.nq = self.nq - 1
    }

    func q_return(var self, cur: u32)
        requires cur < 131072
        ensures true
    {
        var ret: u32 = NONE
        if self.cur_key < 2048 {
            ret = self.fret[self.cur_key]
        }
        let value: u32 = self.p.nfc[cur / 65536][cur % 65536]
        if ret == NONE {
            if value != NONE {
                self.fail_node(cur, "функция ничего не возвращает")
            }
        } elif value == NONE {
            self.fail_node(cur, "функция обязана вернуть значение")
        } else {
            # return — контекст конструкторов Ok/Err/Some/None
            self.cr = value
            self.expr_check(value, ret, 0)
            if not self.failed and not self.compat(ret, self.tres) {
                self.fail_node(cur, "тип возврата не совпадает")
            }
        }
        self.nrt[cur / 65536][cur % 65536] = 1
    }

    # --- match ------------------------------------------------------------

    func q_match_start(var self, cur: u32)
        requires cur < 131072
        ensures true
    {
        let subj: u32 = self.p.nfc[cur / 65536][cur % 65536]
        self.expr_check(subj, NONE, 0)
        if self.failed {
            return
        }
        let dk: u32 = self.yk[self.tres]
        if dk != 9 and dk != 10 and dk != 11 {
            self.fail_node(subj, "match возможен по Result, Option или enum")
            return
        }
        self.qpush(3, cur, self.p.nns[subj / 65536][subj % 65536], self.tres)
    }

    func q_match(var self)
        requires self.nq >= 1
        ensures true
    {
        let f: u32 = self.nq - 1
        if self.qy[f] == 1 {
            self.pop_scope()
            self.qy[f] = NONE
            self.qp[f] = self.p.nns[self.qp[f] / 65536][self.qp[f] % 65536]
            return
        }
        let cur: u32 = self.qp[f]
        if cur == NONE {
            self.exhaust_check(self.qn[f], self.qx[f])
            self.nrt[self.qn[f] / 65536][self.qn[f] % 65536] = self.arms_return(self.qn[f])
            self.nq = f
            return
        }
        self.q_arm(f, cur)
    }

    func q_arm(var self, f: u32, arm: u32)
        requires f < 128 and arm < 131072
        ensures true
    {
        let dom: u32 = self.qx[f]
        # повтор варианта
        var w: u32 = self.p.nns[self.p.nfc[self.qn[f] / 65536][self.qn[f] % 65536] / 65536][
            self.p.nfc[self.qn[f] / 65536][self.qn[f] % 65536] % 65536
        ]
        for _ in 0..64 {
            if w == NONE or w == arm {
                break
            }
            if self.span_eq(
                self.p.nss[w / 65536][w % 65536], self.p.nsl[w / 65536][w % 65536],
                self.p.nss[arm / 65536][arm % 65536], self.p.nsl[arm / 65536][arm % 65536]
            ) {
                self.fail_node(arm, "вариант повторяется")
            }
            w = self.p.nns[w / 65536][w % 65536]
        }
        let payload: u32 = self.arm_payload(dom, arm)
        if self.failed {
            return
        }
        self.nty[arm / 65536][arm % 65536] = payload
        let bind: u32 = self.p.nx[arm / 65536][arm % 65536]
        if payload == NONE and bind != NONE {
            self.fail_node(arm, "вариант не несёт значения")
            return
        }
        if payload != NONE and bind == NONE {
            self.fail_node(arm, "вариант несёт значение: назовите его или используйте _")
            return
        }
        self.push_scope()
        if payload != NONE {
            self.declare(arm, bind, self.p.ny[arm / 65536][arm % 65536], payload, 0)
        }
        self.qy[f] = 1
        self.start_block_frame(self.p.nfc[arm / 65536][arm % 65536], 0)
    }

    # Тип нагрузки варианта арма в домене dom; ошибка — не вариант.
    func arm_payload(var self, dom: u32, arm: u32) -> u32
        requires dom < 512 and arm < 131072
        ensures true
    {
        let va: u32 = self.p.nss[arm / 65536][arm % 65536]
        let vl: u32 = self.p.nsl[arm / 65536][arm % 65536]
        let dk: u32 = self.yk[dom]
        if dk == 10 {
            if self.span_is(va, vl, "Ok") {
                return self.ya[dom]
            }
            if self.span_is(va, vl, "Err") {
                return self.yb[dom]
            }
            self.fail_node(arm, "не вариант типа match")
            return NONE
        }
        if dk == 11 {
            if self.span_is(va, vl, "Some") {
                return self.ya[dom]
            }
            if self.span_is(va, vl, "None") {
                return NONE
            }
            self.fail_node(arm, "не вариант типа match")
            return NONE
        }
        let w: u32 = self.variant_of(self.ys[dom], self.yl[dom], va, vl)
        if w == NONE {
            self.fail_node(arm, "не вариант типа match")
            return NONE
        }
        if w == 999 {
            return NONE
        }
        return self.wpl[w]
    }

    func has_arm16(var self, m: u32, kw: str<16>) -> bool
        requires m < 131072
        ensures true
    {
        var a: u32 = self.p.nns[self.p.nfc[m / 65536][m % 65536] / 65536][
            self.p.nfc[m / 65536][m % 65536] % 65536
        ]
        var found: bool = false
        for _ in 0..64 {
            if a == NONE {
                break
            }
            if self.span_is(
                self.p.nss[a / 65536][a % 65536], self.p.nsl[a / 65536][a % 65536], kw
            ) {
                found = true
            }
            a = self.p.nns[a / 65536][a % 65536]
        }
        return found
    }

    func exhaust_check(var self, m: u32, dom: u32)
        requires m < 131072 and dom < 512
        ensures true
    {
        let dk: u32 = self.yk[dom]
        if dk == 10 {
            if not self.has_arm16(m, "Ok") or not self.has_arm16(m, "Err") {
                self.fail_node(m, "match не исчерпывающий (правило 7)")
            }
            return
        }
        if dk == 11 {
            if not self.has_arm16(m, "Some") or not self.has_arm16(m, "None") {
                self.fail_node(m, "match не исчерпывающий (правило 7)")
            }
            return
        }
        let ei: u32 = self.find_enum(self.ys[dom], self.yl[dom])
        if ei == NONE {
            self.exhaust_builtin(m, dom)
            return
        }
        for w in 0..256 {
            if w >= self.evs[ei] + self.evc[ei] or self.failed {
                break
            }
            if w >= self.evs[ei] {
                if not self.has_arm_span(m, self.wn_s[w], self.wn_l[w]) {
                    self.fail_node(m, "match не исчерпывающий (правило 7)")
                }
            }
        }
    }

    func exhaust_builtin(var self, m: u32, dom: u32)
        requires m < 131072 and dom < 512
        ensures true
    {
        if self.span_is(self.ys[dom], self.yl[dom], "IoError") {
            if not self.has_arm16(m, "Eof") or not self.has_arm16(m, "Fail") {
                self.fail_node(m, "match не исчерпывающий (правило 7)")
            }
            return
        }
        if not self.has_arm16(m, "Empty") or not self.has_arm16(m, "BadChar") {
            self.fail_node(m, "match не исчерпывающий (правило 7)")
            return
        }
        if not self.has_arm16(m, "Overflow") {
            self.fail_node(m, "match не исчерпывающий (правило 7)")
        }
    }

    func has_arm_span(var self, m: u32, a: u32, l: u32) -> bool
        requires m < 131072
        ensures true
    {
        var c: u32 = self.p.nns[self.p.nfc[m / 65536][m % 65536] / 65536][
            self.p.nfc[m / 65536][m % 65536] % 65536
        ]
        var found: bool = false
        for _ in 0..64 {
            if c == NONE {
                break
            }
            if self.span_eq(
                self.p.nss[c / 65536][c % 65536], self.p.nsl[c / 65536][c % 65536], a, l
            ) {
                found = true
            }
            c = self.p.nns[c / 65536][c % 65536]
        }
        return found
    }

    func arms_return(var self, m: u32) -> u32
        requires m < 131072
        ensures result <= 1
    {
        var all: u32 = 1
        var c: u32 = self.p.nns[self.p.nfc[m / 65536][m % 65536] / 65536][
            self.p.nfc[m / 65536][m % 65536] % 65536
        ]
        for _ in 0..64 {
            if c == NONE {
                break
            }
            all = all * self.nrt[self.p.nfc[c / 65536][c % 65536] / 65536][
                self.p.nfc[c / 65536][c % 65536] % 65536
            ]
            c = self.p.nns[c / 65536][c % 65536]
        }
        return all
    }

    # --- проверка тел -----------------------------------------------------

    func check_func_body(var self, fi: u32)
        requires fi < 1024
        ensures true
    {
        self.cur_key = fi
        self.self_ty2 = NONE
        self.self_mu = 0
        self.push_scope()
        let d: u32 = self.fnd[fi]
        if self.fown[fi] != NONE {
            let si: u32 = self.fown[fi]
            self.self_ty2 = self.intern(8, NONE, NONE, self.sn_s[si], self.sn_l[si])
            self.self_mu = self.fvs[fi]
            self.decl_self(self.self_ty2, self.fvs[fi])
        }
        for k in 0..8 {
            if k >= self.fpc[fi] or self.failed {
                break
            }
            let pi: u32 = self.fps[fi] + k
            self.declare(self.pnd[pi], self.pn_s[pi], self.pn_l[pi], self.pty[pi], 0)
        }
        var body: u32 = NONE
        var c: u32 = self.p.nfc[d / 65536][d % 65536]
        for _ in 0..64 {
            if c == NONE or self.failed {
                break
            }
            let ck: u32 = self.p.nk[c / 65536][c % 65536]
            if ck == 9 {
                self.expect_bool(self.p.nfc[c / 65536][c % 65536])
            } elif ck == 10 {
                self.res_ty2 = self.fret[fi]
                self.expect_bool(self.p.nfc[c / 65536][c % 65536])
                self.res_ty2 = NONE
            } elif ck == 12 {
                body = c
            }
            c = self.p.nns[c / 65536][c % 65536]
        }
        if self.failed {
            return
        }
        if self.p.nk[d / 65536][d % 65536] == 50 {
            self.extern_boundary(fi)
            self.mark_params_used()
            self.pop_scope()
            return
        }
        self.run_block_machine(body, 0)
        if self.failed {
            return
        }
        if self.fret[fi] != NONE and self.nrt[body / 65536][body % 65536] == 0 {
            self.fail_node(d, "не все пути возвращают значение")
            return
        }
        self.pop_scope()
        self.self_ty2 = NONE
    }

    # Граница с C (SPEC §7): параметры — скаляры или [u8|u16|u32; N],
    # возврат — только скаляр.
    func extern_boundary(var self, fi: u32)
        requires fi < 1024
        ensures true
    {
        let d: u32 = self.fnd[fi]
        for k in 0..8 {
            if k >= self.fpc[fi] or self.failed {
                break
            }
            let t: u32 = self.pty[self.fps[fi] + k]
            if not self.extern_ok(t, true) {
                self.fail_node(d, "extern: на границе с C допустимы скаляры и [u8|u16|u32|u64; N]")
            }
        }
        let rt: u32 = self.fret[fi]
        if rt != NONE and not self.extern_ok(rt, false) {
            self.fail_node(d, "extern: возврат через границу с C — только скаляр")
        }
    }

    func extern_ok(var self, t: u32, arrays: bool) -> bool
        requires t < 512
        ensures true
    {
        let k: u32 = self.yk[t]
        if k <= 4 or k >= 12 {
            return true
        }
        if arrays and k == 7 {
            let ek: u32 = self.yk[self.ya[t]]
            return ek == 1 or ek == 2 or ek == 12 or ek == 13
        }
        return false
    }

    # Параметры extern «использует» C-реализация — не считаем мёртвыми.
    func mark_params_used(var self)
        requires true
        ensures true
    {
        for v in 0..256 {
            if v >= self.nsv {
                break
            }
            self.sv_u[v] = 1
        }
    }

    func run_bodies(var self)
        requires true
        ensures true
    {
        var d: u32 = self.p.nfc[0 / 65536][0 % 65536]
        for _ in 0..131072 {
            if d == NONE or self.failed {
                break
            }
            let k: u32 = self.p.nk[d / 65536][d % 65536]
            if k == 6 or k == 50 {
                self.check_func_body(self.func_by_node(d))
            } elif k == 4 {
                var m: u32 = self.p.nfc[d / 65536][d % 65536]
                for _ in 0..1024 {
                    if m == NONE or self.failed {
                        break
                    }
                    if self.p.nk[m / 65536][m % 65536] == 6 {
                        self.check_func_body(self.func_by_node(m))
                    }
                    m = self.p.nns[m / 65536][m % 65536]
                }
            } elif k == 11 {
                self.check_test_body(d)
            }
            d = self.p.nns[d / 65536][d % 65536]
        }
    }

    func check_test_body(var self, d: u32)
        requires d < 131072
        ensures true
    {
        if self.ttn >= 64 {
            self.fail_node(d, "слишком много тестов")
            return
        }
        let ti: u32 = self.ttn
        self.tt_s[ti] = self.p.nss[d / 65536][d % 65536]
        self.tt_l[ti] = self.p.nsl[d / 65536][d % 65536]
        self.ttn = ti + 1
        self.cur_key = 2048 + ti
        self.self_ty2 = NONE
        self.res_ty2 = NONE
        self.run_block_machine(self.p.nfc[d / 65536][d % 65536], 1)
    }

    # --- правило 1: DAG вызовов и глубина стека ------------------------------
    # Идентификаторы: fi < 1024; тест — 1024 + ti (код ребра 2048 + ti).

    func cg_code(var self, idx: u32) -> u32
        requires idx < 1024
        ensures true
    {
        if idx < 1024 {
            return idx
        }
        return 2048 + idx - 1024
    }

    # k-й вызываемый из idx; NONE.
    func cg_callee(var self, idx: u32, k: u32) -> u32
        requires idx < 1024
        ensures true
    {
        let code: u32 = self.cg_code(idx)
        var cnt: u32 = 0
        var found: u32 = NONE
        for i in 0..4096 {
            if i >= self.neg or found != NONE {
                break
            }
            if self.eg_c[i] == code {
                if cnt == k {
                    found = self.eg_d[i]
                }
                cnt = cnt + 1
            }
        }
        return found
    }

    func callgraph(var self)
        requires true
        ensures true
    {
        var col: [u32; 1024] = [0; 1024]
        var dep: [u32; 1024] = [0; 1024]
        var st: [u32; 128] = [0; 128]
        var sp2: [u32; 128] = [0; 128]
        for r in 0..1024 {
            if self.cg_valid(r) and col[r] == 0 and not self.failed {
                var sp: u32 = 1
                st[0] = r
                sp2[0] = 0
                col[r] = 1
                for _ in 0..8192 {
                    if sp == 0 or self.failed {
                        break
                    }
                    let f: u32 = sp - 1
                    let id: u32 = st[f]
                    let cal: u32 = self.cg_callee(id, sp2[f])
                    sp2[f] = sp2[f] + 1
                    if cal == NONE {
                        col[id] = 2
                        dep[id] = self.cg_maxdep(id, dep) + 1
                        sp = f
                    } elif col[cal] == 1 {
                        self.fail_node(
                            self.fnd[cal], "рекурсия запрещена (правило 1): цикл вызовов"
                        )
                    } elif col[cal] == 0 {
                        if sp >= 128 {
                            self.fail_at(1, 1, "слишком глубокий граф вызовов")
                        } else {
                            col[cal] = 1
                            st[sp] = cal
                            sp2[sp] = 0
                            sp = sp + 1
                        }
                    }
                }
            }
        }
        if self.main_fi != NONE {
            self.sdep = dep[self.main_fi]
        }
    }

    func cg_valid(var self, idx: u32) -> bool
        requires idx < 1024
        ensures true
    {
        if idx < 1024 {
            return idx < self.nfun
        }
        return idx - 1024 < self.ttn
    }

    func cg_maxdep(var self, idx: u32, dep: [u32; 1024]) -> u32
        requires idx < 1024
        ensures true
    {
        var best: u32 = 0
        for k in 0..64 {
            let cal: u32 = self.cg_callee(idx, k)
            if cal != NONE {
                if dep[cal] > best {
                    best = dep[cal]
                }
            }
        }
        return best
    }

    # --- типизированный дамп (`eatc typed`) --------------------------------

    func run_typed(var self)
        requires true
        ensures true
    {
        self.run()
        if self.failed {
            return
        }
        if self.bdone == 0 {
            self.init_builtins()
            self.run_bodies()
        }
        if self.failed {
            return
        }
        self.callgraph()
    }

    func range_of(var self, n: u32) -> u32
        requires true
        ensures true
    {
        var found: u32 = NONE
        for i in 0..512 {
            if i >= self.nrb or found != NONE {
                break
            }
            if self.rb_n[i] == n {
                found = i
            }
        }
        return found
    }

    func tprint(var self, n: u32, d: u32)
        requires n < 131072
        ensures true
    {
        for i in 0..64 {
            if i >= d {
                break
            }
            write("  ")
        }
        let k: u32 = self.p.nk[n / 65536][n % 65536]
        write_nkind(k)
        if has_pos(k) {
            write(" {self.p.nl[n / 65536][n % 65536]}:{self.p.nc[n / 65536][n % 65536]}")
        }
        self.textras(n, k)
        if self.nty[n / 65536][n % 65536] != NONE {
            write(" :: ")
            self.write_type(self.nty[n / 65536][n % 65536])
            if k == 18 {
                let r: u32 = self.range_of(n)
                if r != NONE {
                    write(" bounds=")
                    if self.rb_ss[r] == 1 {
                        write("-")
                    }
                    write("{self.rb_sm[r]}..")
                    if self.rb_es[r] == 1 {
                        write("-")
                    }
                    write("{self.rb_em[r]}")
                }
            }
        }
        write("\n")
    }

    func textras(var self, n: u32, k: u32)
        requires n < 131072
        ensures true
    {
        if k == 6 {
            write(" name=")
            self.write_span2(self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536])
            write(" method={self.p.nx[n / 65536][n % 65536]}")
        } elif k == 7 {
            write(" name=")
            if self.p.nss[n / 65536][n % 65536] == NONE {
                write("self")
            } else {
                self.write_span2(self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536])
            }
            write(" mut={self.p.nx[n / 65536][n % 65536]}")
        } elif k == 13 {
            write(" name=")
            self.write_span2(self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536])
            write(" mut={self.p.nx[n / 65536][n % 65536]}")
        } elif k == 21 {
            write(" name=")
            self.write_span2(self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536])
            if self.p.nx[n / 65536][n % 65536] != NONE {
                write(" bind=")
                self.write_span2(self.p.nx[n / 65536][n % 65536], self.p.ny[n / 65536][n % 65536])
            }
        } elif k == 32 {
            write(" val=")
            if self.p.ny[n / 65536][n % 65536] == 1 {
                write("-")
            }
            let m: u64 = self.p.mag(n)
            write("{m}")
        } elif k == 33 {
            if self.p.nx[n / 65536][n % 65536] == 1 {
                write(" val=true")
            } else {
                write(" val=false")
            }
        } elif k == 34 or k == 36 {
            write(" val=")
            self.wesc_span(self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536])
        } elif k == 37 {
            write(" val=")
            self.write_span2(self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536])
        } elif k == 39 or k == 40 {
            write(" op=")
            write_opname(self.p.nx[n / 65536][n % 65536])
        } elif k == 54 {
            write(" name=")
            self.write_span2(self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536])
            if self.p.ny[n / 65536][n % 65536] > 0 {
                write(" as=")
                self.write_span2(self.p.nx[n / 65536][n % 65536], self.p.ny[n / 65536][n % 65536])
            }
        } elif has_name(k) {
            write(" name=")
            self.write_span2(self.p.nss[n / 65536][n % 65536], self.p.nsl[n / 65536][n % 65536])
        }
    }

    func wesc_span(var self, a: u32, l: u32)
        requires true
        ensures true
    {
        for i in 0..256 {
            if i >= l {
                break
            }
            write_esc(self.p.lex.sb_at(a + i))
        }
    }

    func tdump(var self)
        requires true
        ensures true
    {
        var st: [u32; 64] = [0; 64]
        var sp: u32 = 0
        var cur: u32 = 0
        var dpt: u32 = 0
        var done: bool = false
        for _ in 0..131072 {
            if done {
                break
            }
            self.tprint(cur, dpt)
            if self.p.nfc[cur / 65536][cur % 65536] != NONE and sp < 64 {
                st[sp] = cur
                sp = sp + 1
                dpt = dpt + 1
                cur = self.p.nfc[cur / 65536][cur % 65536]
            } else {
                var moved: bool = false
                for _ in 0..64 {
                    if moved {
                        break
                    }
                    if sp == 0 {
                        done = true
                        moved = true
                    } elif self.p.nns[cur / 65536][cur % 65536] != NONE {
                        cur = self.p.nns[cur / 65536][cur % 65536]
                        moved = true
                    } else {
                        sp = sp - 1
                        cur = st[sp]
                        dpt = dpt - 1
                    }
                }
            }
        }
        write("stack {self.sdep}\n")
        self.dump_edges()
    }

    # --- сортировка и печать рёбер ------------------------------------------

    # i-й байт ключа вызывающего/вызываемого; 999 — конец.
    func key_byte(var self, code: u32, i: u32) -> u32
        requires true
        ensures true
    {
        if code >= 2048 {
            let pre: str<8> = "test:"
            if i < 5 {
                return u32(u8(pre[i]))
            }
            let ti: u32 = code - 2048
            if i - 5 < self.tt_l[ti] {
                return u32(self.p.lex.sb_at(self.tt_s[ti] + i - 5))
            }
            return 999
        }
        var off: u32 = 0
        let own: u32 = self.fown[code]
        if own != NONE {
            if i < self.sn_l[own] {
                return u32(self.p.lex.sb_at(self.sn_s[own] + i))
            }
            if i == self.sn_l[own] {
                return 46
            }
            off = self.sn_l[own] + 1
        }
        if i - off < self.fn_l[code] {
            return u32(self.p.lex.sb_at(self.fn_s[code] + i - off))
        }
        return 999
    }

    # 0: a < b, 1: равны, 2: a > b.
    func cmp_key(var self, a: u32, b: u32) -> u32
        requires true
        ensures result <= 2
    {
        var r: u32 = 1
        var stop: bool = false
        for i in 0..300 {
            if stop {
                break
            }
            let ba: u32 = self.key_byte(a, i)
            let bb: u32 = self.key_byte(b, i)
            if ba == 999 and bb == 999 {
                stop = true
            } elif ba == 999 {
                r = 0
                stop = true
            } elif bb == 999 {
                r = 2
                stop = true
            } elif ba < bb {
                r = 0
                stop = true
            } elif ba > bb {
                r = 2
                stop = true
            }
        }
        return r
    }

    # Ребро i больше ребра j (по ключам вызывающего, затем вызываемого)?
    # Ранг кода — число ключей строго меньше его ключа: порядок рангов
    # совпадает с порядком ключей (строгая монотонность), равенство
    # рангов равносильно равенству ключей — сортировка по рангам даёт
    # байт-в-байт тот же порядок, что посимвольная.
    func rank_of(var self, code: u32) -> u32
        requires true
        ensures true
    {
        var r: u32 = 0
        for c2 in 0..1024 {
            if c2 >= self.nfun {
                break
            }
            if self.cmp_key(c2, code) == 0 {
                r = r + 1
            }
        }
        for t2 in 0..64 {
            if t2 >= self.ttn {
                break
            }
            if self.cmp_key(2048 + t2, code) == 0 {
                r = r + 1
            }
        }
        return r
    }

    func rank_build(var self)
        requires true
        ensures true
    {
        for c1 in 0..1024 {
            if c1 >= self.nfun {
                break
            }
            self.erk[c1] = self.rank_of(c1)
        }
        for t1 in 0..64 {
            if t1 >= self.ttn {
                break
            }
            self.erk[2048 + t1] = self.rank_of(2048 + t1)
        }
    }

    func edge_gt(var self, i: u32, j: u32) -> bool
        requires i < 4096 and j < 4096
        ensures true
    {
        let a1: u32 = self.erk[self.eg_c[i] & 4095]
        let b1: u32 = self.erk[self.eg_c[j] & 4095]
        if a1 != b1 {
            return a1 > b1
        }
        return self.erk[self.eg_d[i] & 4095] > self.erk[self.eg_d[j] & 4095]
    }

    func dump_edges(var self)
        requires true
        ensures true
    {
        self.rank_build()
        # сортировка выбором
        for i in 0..4096 {
            if i >= self.neg {
                break
            }
            var best: u32 = i
            for j in 0..4096 {
                if j >= self.neg {
                    break
                }
                if j > i {
                    if self.edge_gt(best, j) {
                        best = j
                    }
                }
            }
            if best != i {
                let tc: u32 = self.eg_c[i]
                let td: u32 = self.eg_d[i]
                self.eg_c[i] = self.eg_c[best]
                self.eg_d[i] = self.eg_d[best]
                self.eg_c[best] = tc
                self.eg_d[best] = td
            }
        }
        for i in 0..4096 {
            if i >= self.neg {
                break
            }
            write("edge ")
            self.write_key(self.eg_c[i])
            write(" -> ")
            self.write_key(self.eg_d[i])
            write("\n")
        }
    }

    func write_key(var self, code: u32)
        requires true
        ensures true
    {
        for i in 0..300 {
            let b: u32 = self.key_byte(code, i)
            if b != 999 {
                write_byte(u8(b))
            }
        }
    }
}

# Вид узла — инструкция (для подсчёта правила 4).
func is_stmt_kind(k: u32) -> bool
    requires true
    ensures true
{
    if k >= 13 and k <= 26 {
        return k != 16 and k != 17 and k != 21
    }
    return false
}
