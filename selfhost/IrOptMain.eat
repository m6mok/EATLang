# Self-hosted эмиттер LLVM IR, оптимизированная ось `-O` (фаза 4,
# SELFHOST_OPT_PLAN): точка входа SelfIrOpt. Как IrMain, плюс проход
# свёртки вызовов ct_fold_pass между типизацией и эмиссией. Фильтр
# stdin → stdout: текстовый модуль LLVM, байт-в-байт совпадающий с
# эталоном `eatc ir -O` (сверка в make verify_selfhost_opt).

func main() {
    var lex: Lexer = lexer_new()
    var eof: bool = false
    loop {
        match read_byte() {
            Ok(b) {
                lex.step(b)
            }
            Err(_) {
                eof = true
            }
        }
        if eof or lex.failed {
            break
        }
    }
    lex.finish()
    if not lex.failed {
        lex.sublex_pass()
    }
    var bad: bool = lex.failed
    if not bad {
        var p: Parser = parser_new(lex)
        p.parse()
        if not p.failed {
            var c: Check = check_new(p)
            c.run_typed()
            if not c.failed {
                c.ct_fold_pass()
                var ir: Ir = ir_new(c)
                ir.emit()
                if ir.failed {
                    bad = true
                }
            } else {
                bad = true
            }
        } else {
            bad = true
        }
    }
    if bad {
        exit(1)
    }
}
