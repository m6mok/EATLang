        requires true
        ensures true
    {
        self.vpre()
        self.lb_lit("call void @\"eat_RtStr__")
        self.lb_lit(nm)
        self.lb_lit("\"(")
        self.w_strty()
        self.lb_lit("* ")
        self.wr1()
        self.lb_lit(")")
        self.line_fin()
    }

