        let si: u32 = self.c.find_struct(self.c.p.nss[n / 65536][n % 65536], self.c.p.nsl[n / 65536][n % 65536])
        let g: u32 = self.c.field_of(si, self.c.p.nss[cur / 65536][cur % 65536], self.c.p.nsl[cur / 65536][cur % 65536])
        self.set1(1, self.xa3[f], self.xb3[f])
        self.e_gepc(self.c.nty[n / 65536][n % 65536], g - self.c.sgs[si])
        self.xd3[f] = self.rra
        self.xe3[f] = self.c.gty[g]
        self.xc3[f] = self.c.p.nns[cur / 65536][cur % 65536]
        self.xp3[f] = 2
        self.xpush2(self.c.p.nfc[cur / 65536][cur % 65536])
