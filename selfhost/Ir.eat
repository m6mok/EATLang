    # --- стек аргументов и вызовы пользовательских функций -------------------

    func ag_push(var self, t: u32)
        requires t < 512
        ensures true
    {
        if self.nag >= 256 {
            self.fail("слишком глубокий стек аргументов")
            return
        }
        self.agk[self.nag] = self.erk
        self.aga[self.nag] = self.era
        self.agb[self.nag] = self.erb
        self.agt[self.nag] = t
        self.nag = self.nag + 1
    }

    func ag_push_rr(var self, t: u32)
        requires t < 512
        ensures true
    {
        if self.nag >= 256 {
            self.fail("слишком глубокий стек аргументов")
            return
        }
        self.agk[self.nag] = self.rrk
        self.aga[self.nag] = self.rra
        self.agb[self.nag] = self.rrb
        self.agt[self.nag] = t
        self.nag = self.nag + 1
    }

    func e_ucall(var self, fi: u32, base: u32)
        requires fi < 1024 and base < 256
        ensures true
    {
        let cnt: u32 = self.nag - base
        let rt2: u32 = self.c.fret[fi]
        var isv: bool = true
        if rt2 != 4294967295 {
            if not self.is_agg(rt2) {
                isv = false
            }
        }
        if isv {
            self.vpre()
            self.lb_lit("call void @\"")
        } else {
            self.rpre()
            self.lb_lit("call ")
            self.wty(rt2)
            self.lb_lit(" @\"")
        }
        self.w_mangle(fi)
        self.lb_lit("\"(")
        for j in 0..8 {
            if j >= cnt {
                break
            }
            if j > 0 {
                self.lb_lit(", ")
            }
            let t: u32 = self.agt[base + j]
            self.wty(t)
            if self.is_agg(t) {
                self.lb_lit("*")
            }
            self.lb_lit(" ")
            self.wref(self.agk[base + j], self.aga[base + j], self.agb[base + j])
        }
        self.lb_lit(")")
        self.line_fin()
        self.nag = base
    }

    # --- копирование значений -----------------------------------------------

    # w1 — указатель-назначение, w2 — источник (значение или указатель).
    func copy_into(var self, t: u32)
        requires t < 512
        ensures true
    {
        if not self.is_agg(t) {
            let dk: u32 = self.w1k
            let da: u32 = self.w1a
            let db: u32 = self.w1b
            self.set1(self.w2k, self.w2a, self.w2b)
            self.set2(dk, da, db)
            self.e_store(t)
            return
        }
        self.use_intr(0)
        let dk2: u32 = self.w1k
        let da2: u32 = self.w1a
        let db2: u32 = self.w1b
        let sk2: u32 = self.w2k
        let sa2: u32 = self.w2a
        let sb2: u32 = self.w2b
        self.e_gepn(t)
        self.set1rr()
        self.e_p2i(t)
        let zk: u32 = self.rrk
        let za: u32 = self.rra
        let zb: u32 = self.rrb
        self.set1(dk2, da2, db2)
        self.e_bc(t)
        let xk: u32 = self.rrk
        let xa: u32 = self.rra
        let xb: u32 = self.rrb
        self.set1(sk2, sa2, sb2)
        self.e_bc(t)
        self.set2rr()
        self.set1(xk, xa, xb)
        self.set3(zk, za, zb)
        self.e_mcpy()
    }

    # w2 — источник; результат (указатель на копию) — rr.
    func materialize(var self, t: u32)
        requires t < 512
        ensures true
    {
        let sk2: u32 = self.w2k
        let sa2: u32 = self.w2a
        let sb2: u32 = self.w2b
        self.e_alloca_u(t)
        let ok2: u32 = self.rra
        self.set1(0, ok2, 0)
        self.set2(sk2, sa2, sb2)
        self.copy_into(t)
        self.rrk = 0
        self.rra = ok2
        self.rrb = 0
    }

    # w1 — i1: если истина, аварийная остановка.
    func trap_if(var self, ln: u32, cl: u32, mk: u32, e1: u32, e2: u32)
        requires mk <= 8
        ensures true
    {
        let bk2: u32 = self.w1k
        let ba2: u32 = self.w1a
        let bb2: u32 = self.w1b
        let tb: u32 = self.blk_new("trap")
        let ob: u32 = self.blk_new("ok")
        self.set1(bk2, ba2, bb2)
        self.e_cbr(tb, ob)
        self.cb = tb
        let g: u32 = self.trap_glob(ln, cl, mk, e1, e2)
        self.e_gepg(g)
        self.set1rr()
        self.e_trapc()
        self.e_unr()
        self.cb = ob
    }

    func ensure_br(var self, b: u32)
        requires b < 16384
        ensures true
    {
        if self.bkt[self.cb] == 0 {
            self.e_br(b)
        }
    }

    # --- области видимости значений ------------------------------------------

    func push_sc(var self)
        requires true
        ensures true
    {
        if self.nsb >= 64 {
            self.fail("слишком глубокие области видимости")
            return
        }
        self.scb[self.nsb] = self.nvr
        self.nsb = self.nsb + 1
    }

    func pop_sc(var self)
        requires self.nsb >= 1
        ensures true
    {
        self.nvr = self.scb[self.nsb - 1]
        self.nsb = self.nsb - 1
    }

    # w1 — указатель привязки; a=NONE — self, «_» пропускается.
    func bindv(var self, a: u32, l: u32, t: u32)
        requires t < 512
        ensures true
    {
        if a != 4294967295 {
            if self.c.span_is(a, l, "_") {
                return
            }
        }
        if self.nvr >= 256 {
            self.fail("слишком много переменных")
            return
        }
        let v: u32 = self.nvr
        self.vns[v] = a
        self.vnl[v] = l
        self.vty[v] = t
        self.vkk[v] = self.w1k
        self.vka[v] = self.w1a
        self.vkb[v] = self.w1b
        self.nvr = v + 1
    }

    func lookupv(var self, a: u32, l: u32) -> u32
        requires true
        ensures true
    {
        var f: u32 = 4294967295
        for i in 0..256 {
            if i >= self.nvr or f != 4294967295 {
                break
            }
            if self.vns[i] != 4294967295 {
                if self.c.span_eq(self.vns[i], self.vnl[i], a, l) {
                    f = i
                }
            }
        }
        return f
    }

    func lookup_self2(var self) -> u32
        requires true
        ensures true
    {
        var f: u32 = 4294967295
        for i in 0..256 {
            if i >= self.nvr or f != 4294967295 {
                break
            }
            if self.vns[i] == 4294967295 {
                f = i
            }
        }
        return f
    }

    # --- машина выражений -----------------------------------------------------

    func xpush2(var self, n: u32)
        requires n < 131072
        ensures true
    {
        if self.nx3 >= 64 {
            self.fail("слишком глубокое выражение")
            return
        }
        self.xn3[self.nx3] = n
        self.xp3[self.nx3] = 0
        self.xa3[self.nx3] = 0
        self.xb3[self.nx3] = 0
        self.xc3[self.nx3] = 0
        self.xd3[self.nx3] = 0
        self.xe3[self.nx3] = 0
        self.xf3[self.nx3] = 0
        self.xg3[self.nx3] = 0
        self.nx3 = self.nx3 + 1
    }

    func expr_run(var self, root: u32)
        requires root < 131072
        ensures true
    {
        self.nx3 = 0
        self.xpush2(root)
        for _ in 0..8192 {
            if self.nx3 == 0 or self.failed {
                break
            }
            self.xstep()
        }
        if self.nx3 > 0 and not self.failed {
            self.fail("выражение слишком велико для self-host")
        }
    }

    func xstep(var self)
        requires self.nx3 >= 1
        ensures true
    {
        let f: u32 = self.nx3 - 1
        let n: u32 = self.xn3[f]
        let k: u32 = self.c.p.nk[n / 65536][n % 65536]
        if k == 32 or k == 33 or k == 34 or k == 37 or k == 38 {
            self.xleaf(n, k)
        } elif k == 35 {
            self.xstr(f, n)
        } elif k == 39 {
            self.xbin(f, n)
        } elif k == 40 {
            self.xun(f, n)
        } elif k == 41 {
            self.xcall(f, n)
        } elif k == 42 {
            self.xmeth(f, n)
        } elif k == 43 {
            self.xmem(f, n)
        } elif k == 44 {
            self.xidx(f, n)
        } elif k == 45 {
            self.xslit(f, n)
        } elif k == 47 {
            self.xalit(f, n)
        } else {
            self.xafill(f, n)
        }
    }

    func xleaf(var self, n: u32, k: u32)
        requires n < 131072
        ensures true
    {
        if k == 32 {
            self.ser(2, self.c.p.ny[n / 65536][n % 65536], self.c.p.nx[n / 65536][n % 65536])
            self.ert = self.c.nty[n / 65536][n % 65536]
        } elif k == 33 {
            self.ser(2, 0, self.c.p.nx[n / 65536][n % 65536])
            self.ert = 3
        } elif k == 34 {
            self.ser(2, 0, u32(self.c.p.lex.sb_at(self.c.p.nss[n / 65536][n % 65536])))
            self.ert = 4
        } elif k == 38 {
            let v: u32 = self.lookup_self2()
            self.ser(self.vkk[v], self.vka[v], self.vkb[v])
            self.ert = self.vty[v]
        } else {
            self.xname(n)
        }
        self.nx3 = self.nx3 - 1
    }

    func xname(var self, n: u32)
        requires n < 131072
        ensures true
    {
        let a: u32 = self.c.p.nss[n / 65536][n % 65536]
        let l: u32 = self.c.p.nsl[n / 65536][n % 65536]
        if self.res_on == 1 {
            if self.c.span_is(a, l, "result") {
                if self.is_agg(self.rett) {
                    self.ser(self.rsk, self.rsa, self.rsb)
                    self.ert = self.rett
                } else {
                    self.set1(self.rsk, self.rsa, self.rsb)
                    self.e_load(self.rett)
                    self.serrr(self.rett)
                }
                return
            }
        }
        let v: u32 = self.lookupv(a, l)
        if v != 4294967295 {
            let t: u32 = self.vty[v]
            if self.is_agg(t) {
                self.ser(self.vkk[v], self.vka[v], self.vkb[v])
                self.ert = t
            } else {
                self.set1(self.vkk[v], self.vka[v], self.vkb[v])
                self.e_load(t)
                self.serrr(t)
            }
            return
        }
        let ci: u32 = self.c.find_const(a, l)
        self.ser(2, self.c.cvs[ci], self.c.cvm[ci])
        self.ert = self.c.cty[ci]
    }

    func xstr(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let ph: u32 = self.xp3[f]
        if ph == 0 {
            self.nm_lit("str")
            self.e_alloca_n(self.c.nty[n / 65536][n % 65536])
            self.xb3[f] = self.rra
            self.xc3[f] = self.rrb
            self.set1rr()
            self.e_rt_s("init")
            self.xa3[f] = self.c.p.nfc[n / 65536][n % 65536]
            self.xp3[f] = 1
            return
        }
        if ph == 2 {
            self.xseg(f)
            self.xp3[f] = 1
            return
        }
        let cur: u32 = self.xa3[f]
        if cur == 4294967295 {
            self.ser(1, self.xb3[f], self.xc3[f])
            self.ert = self.c.nty[n / 65536][n % 65536]
            self.nx3 = self.nx3 - 1
            return
        }
        self.xa3[f] = self.c.p.nns[cur / 65536][cur % 65536]
        if self.c.p.nk[cur / 65536][cur % 65536] == 36 {
            let g: u32 = self.cstr_seg(self.c.p.nss[cur / 65536][cur % 65536], self.c.p.nsl[cur / 65536][cur % 65536])
            self.set1(1, self.xb3[f], self.xc3[f])
            self.set2(3, g, 0)
            self.e_as()
        } else {
            self.xp3[f] = 2
            self.xpush2(cur)
        }
    }

    # Выражение-сегмент готово (er): подобрать eat_str_append_*.
    func xseg(var self, f: u32)
        requires f < 64
        ensures true
    {
        let tk: u32 = self.c.yk[self.ert]
        if tk == 6 {
            self.set1(1, self.xb3[f], self.xc3[f])
            self.set2er()
            self.e_as()
        } elif tk == 4 {
            self.set1(1, self.xb3[f], self.xc3[f])
            self.set2er()
            self.e_rt_si("char", "i8")
        } elif tk == 3 {
            self.set1(1, self.xb3[f], self.xc3[f])
            self.set2er()
            self.e_rt_si("bool", "i1")
        } elif tk == 0 {
            self.set1(1, self.xb3[f], self.xc3[f])
            self.set2er()
            self.e_rt_si("i32", "i32")
        } elif tk == 2 {
            self.set1er()
            self.e_cvt(0, 2, 0)
            self.set1(1, self.xb3[f], self.xc3[f])
            self.set2rr()
            self.e_rt_si("u32", "i32")
        } else {
            self.set1(1, self.xb3[f], self.xc3[f])
            self.set2er()
            self.e_rt_si("u32", "i32")
        }
    }

    func xun(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        if self.xp3[f] == 0 {
            self.xp3[f] = 1
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
            return
        }
        if self.c.p.nx[n / 65536][n % 65536] == 3 {
            self.set1er()
            self.e_not()
            self.serrr(3)
        } else {
            # унарный минус: 0 - x с проверкой переполнения i32
            self.use_intr(2)
            self.set1(2, 0, 0)
            self.set2er()
            self.e_ov(2)
            let pk: u32 = self.rrk
            let pa: u32 = self.rra
            let pb: u32 = self.rrb
            self.set1(pk, pa, pb)
            self.e_exv(2, 1)
            self.set1rr()
            self.trap_if(self.c.p.nl[n / 65536][n % 65536], self.c.p.nc[n / 65536][n % 65536], 2, 0, 0)
            self.set1(pk, pa, pb)
            self.e_exv(2, 0)
            self.serrr(0)
        }
        self.nx3 = self.nx3 - 1
    }

    func xbin(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let op: u32 = self.c.p.nx[n / 65536][n % 65536]
        if op <= 2 {
            self.xsc(f, n, op)
            return
        }
        let ph: u32 = self.xp3[f]
        if ph == 0 {
            self.xp3[f] = 1
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } elif ph == 1 {
            self.xa3[f] = self.erk
            self.xb3[f] = self.era
            self.xc3[f] = self.erb
            self.xd3[f] = self.ert
            self.xp3[f] = 2
            self.xpush2(self.c.p.nns[self.c.p.nfc[n / 65536][n % 65536] / 65536][self.c.p.nfc[n / 65536][n % 65536] % 65536])
        } else {
            self.xbfin(f, n, op)
        }
    }

    # Короткое замыкание and/or (op: 1 or, 2 and).
    func xsc(var self, f: u32, n: u32, op: u32)
        requires f < 64 and n < 131072 and op <= 2
        ensures true
    {
        let ph: u32 = self.xp3[f]
        if ph == 0 {
            self.xp3[f] = 1
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
            return
        }
        if ph == 1 {
            self.xa3[f] = self.erk
            self.xb3[f] = self.era
            self.xc3[f] = self.erb
            self.xe3[f] = self.cb
            var rhs: u32 = 0
            var mrg: u32 = 0
            if op == 2 {
                rhs = self.blk_new("and")
                mrg = self.blk_new("and.end")
            } else {
                rhs = self.blk_new("or")
                mrg = self.blk_new("or.end")
            }
            self.xf3[f] = mrg
            self.set1er()
            if op == 2 {
                self.e_cbr(rhs, mrg)
            } else {
                self.e_cbr(mrg, rhs)
            }
            self.cb = rhs
            self.xp3[f] = 2
            self.xpush2(self.c.p.nns[self.c.p.nfc[n / 65536][n % 65536] / 65536][self.c.p.nfc[n / 65536][n % 65536] % 65536])
            return
        }
        let re: u32 = self.cb
        let mrg2: u32 = self.xf3[f]
        self.e_br(mrg2)
        self.cb = mrg2
        self.set1(self.xa3[f], self.xb3[f], self.xc3[f])
        self.set2er()
        self.e_phi(3, self.xe3[f], re)
        self.serrr(3)
        self.nx3 = self.nx3 - 1
    }

    func xbfin(var self, f: u32, n: u32, op: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let lt: u32 = self.xd3[f]
        let lk: u32 = self.c.yk[lt]
        if op >= 16 {
            self.xbit(f, n, op)
            return
        }
        if op >= 10 {
            self.xarith(f, n, op)
            return
        }
        if lk == 6 {
            self.set1(self.xa3[f], self.xb3[f], self.xc3[f])
            self.set2er()
            self.e_streq()
            if op != 4 {
                self.set1rr()
                self.e_not()
            }
            self.serrr(3)
            self.nx3 = self.nx3 - 1
            return
        }
        var oc: u32 = 0
        if op == 4 {
            oc = 1
        } elif op == 5 {
            oc = 2
        } elif op == 6 {
            oc = 3
        } elif op == 7 {
            oc = 4
        } elif op == 8 {
            oc = 5
        } else {
            oc = 6
        }
        if oc >= 3 and lk != 0 {
            oc = oc + 4
        }
        self.set1(self.xa3[f], self.xb3[f], self.xc3[f])
        self.set2er()
        self.e_icmp(oc, lt)
        self.serrr(3)
        self.nx3 = self.nx3 - 1
    }

    # Арифметика с проверками; левый операнд в кадре, правый в er.
    func xarith(var self, f: u32, n: u32, op: u32)
        requires f < 64 and n < 131072 and op >= 10 and op <= 14
        ensures true
    {
        let lt: u32 = self.xd3[f]
        let lk: u32 = self.c.yk[lt]
        if op <= 12 {
            var iid: u32 = op - 9
            if lk == 1 {
                iid = op - 6
            } elif lk == 2 {
                iid = op - 3
            }
            self.use_intr(iid)
            self.set1(self.xa3[f], self.xb3[f], self.xc3[f])
            self.set2er()
            self.e_ov(iid)
            let pk: u32 = self.rrk
            let pa: u32 = self.rra
            let pb: u32 = self.rrb
            self.set1(pk, pa, pb)
            self.e_exv(iid, 1)
            self.set1rr()
            self.trap_if(self.c.p.nl[n / 65536][n % 65536], self.c.p.nc[n / 65536][n % 65536], 2, lk, 0)
            self.set1(pk, pa, pb)
            self.e_exv(iid, 0)
            self.serrr(lt)
            self.nx3 = self.nx3 - 1
            return
        }
        self.xdiv(f, n, op, lt)
        self.nx3 = self.nx3 - 1
    }

    # Битовые операции: & | ^ — одна инструкция; сдвиги — с проверками
    # (рисунок инструкций и trap'ов — байт-в-байт как у эталона).
    func xbit(var self, f: u32, n: u32, op: u32)
        requires f < 64 and n < 131072 and op >= 16 and op <= 20
        ensures true
    {
        let lt: u32 = self.xd3[f]
        if op <= 18 {
            var o: u32 = 9 # |
            if op == 17 {
                o = 10 # ^
            } elif op == 18 {
                o = 8 # &
            }
            self.set1(self.xa3[f], self.xb3[f], self.xc3[f])
            self.set2er()
            self.e_bin(o, lt)
            self.serrr(lt)
            self.nx3 = self.nx3 - 1
            return
        }
        self.xshift(f, n, op, lt)
        self.nx3 = self.nx3 - 1
    }

    # Сдвиг: trap при n ≥ ширины типа; << дополнительно трапит вынос
    # битов (обратный lshr обязан восстановить операнд).
    func xshift(var self, f: u32, n: u32, op: u32, lt: u32)
        requires f < 64 and n < 131072 and lt < 512
        ensures true
    {
        let lk: u32 = self.c.yk[lt]
        let rk: u32 = self.erk
        let ra: u32 = self.era
        let rb: u32 = self.erb
        var width: u32 = 32
        if lk == 2 {
            width = 8
        }
        self.set1(rk, ra, rb)
        self.set2(2, 0, width)
        self.e_icmp(10, lt)
        self.set1rr()
        self.trap_if(self.c.p.nl[n / 65536][n % 65536], self.c.p.nc[n / 65536][n % 65536], 7, lk, 0)
        if op == 20 { # >>
            self.set1(self.xa3[f], self.xb3[f], self.xc3[f])
            self.set2(rk, ra, rb)
            self.e_bin(12, lt)
            self.serrr(lt)
            return
        }
        self.set1(self.xa3[f], self.xb3[f], self.xc3[f])
        self.set2(rk, ra, rb)
        self.e_bin(11, lt)
        let sk: u32 = self.rrk
        let sa: u32 = self.rra
        let sb: u32 = self.rrb
        self.set1(sk, sa, sb)
        self.set2(rk, ra, rb)
        self.e_bin(12, lt)
        self.set1rr()
        self.set2(self.xa3[f], self.xb3[f], self.xc3[f])
        self.e_icmp(2, lt)
        self.set1rr()
        self.trap_if(self.c.p.nl[n / 65536][n % 65536], self.c.p.nc[n / 65536][n % 65536], 2, lk, 0)
        self.erk = sk
        self.era = sa
        self.erb = sb
        self.ert = lt
    }

    func xdiv(var self, f: u32, n: u32, op: u32, lt: u32)
        requires f < 64 and n < 131072 and lt < 512
        ensures true
    {
        let rk: u32 = self.erk
        let ra: u32 = self.era
        let rb: u32 = self.erb
        self.set1(rk, ra, rb)
        self.set2(2, 0, 0)
        self.e_icmp(1, lt)
        self.set1rr()
        self.trap_if(self.c.p.nl[n / 65536][n % 65536], self.c.p.nc[n / 65536][n % 65536], 3, 0, 0)
        var o: u32 = 6
        if op == 14 {
            o = 7
        }
        if self.c.yk[lt] == 0 {
            self.set1(self.xa3[f], self.xb3[f], self.xc3[f])
            self.set2(2, 1, 2147483648)
            self.e_icmp(1, lt)
            let c1k: u32 = self.rrk
            let c1a: u32 = self.rra
            let c1b: u32 = self.rrb
            self.set1(rk, ra, rb)
            self.set2(2, 1, 1)
            self.e_icmp(1, lt)
            self.set2rr()
            self.set1(c1k, c1a, c1b)
            self.e_bin(8, 3)
            self.set1rr()
            self.trap_if(self.c.p.nl[n / 65536][n % 65536], self.c.p.nc[n / 65536][n % 65536], 2, 0, 0)
            o = 4
            if op == 14 {
                o = 5
            }
        }
        self.set1(self.xa3[f], self.xb3[f], self.xc3[f])
        self.set2(rk, ra, rb)
        self.e_bin(o, lt)
        self.serrr(lt)
    }

    # --- вызовы -----------------------------------------------------------

    func xcall(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        if self.xp3[f] == 0 {
            self.xcall_start(f, n)
        } else {
            self.xcall_next(f, n)
        }
    }

    func xcall_start(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let a: u32 = self.c.p.nss[n / 65536][n % 65536]
        let l: u32 = self.c.p.nsl[n / 65536][n % 65536]
        self.xp3[f] = 1
        if self.c.span_is(a, l, "print") {
            self.xa3[f] = 1
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } elif self.c.span_is(a, l, "write") {
            self.xa3[f] = 2
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } elif self.c.span_is(a, l, "read_byte") {
            self.xrbyte(n)
            self.nx3 = self.nx3 - 1
        } elif self.c.span_is(a, l, "read_line") {
            self.xrline(n)
            self.nx3 = self.nx3 - 1
        } elif self.c.span_is(a, l, "write_byte") {
            self.xa3[f] = 5
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } elif self.c.span_is(a, l, "write_err_byte") {
            self.xa3[f] = 6
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } elif self.c.span_is(a, l, "exit") {
            self.xa3[f] = 7
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } elif self.c.span_is(a, l, "parse_i32") {
            self.xa3[f] = 3
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } elif self.c.span_is(a, l, "write_span") {
            self.xa3[f] = 8
            self.xf3[f] = 0
            self.xg3[f] = self.nag
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } elif self.c.span_is(a, l, "len") {
            self.xcall_len(f, n)
        } elif self.c.span_is(a, l, "i32") {
            self.xa3[f] = 100
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } elif self.c.span_is(a, l, "u32") {
            self.xa3[f] = 101
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } elif self.c.span_is(a, l, "u8") {
            self.xa3[f] = 102
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } elif self.c.span_is(a, l, "char") {
            self.xa3[f] = 104
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } else {
            self.xcall_user(f, n, a, l)
        }
    }

    func xcall_len(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let at: u32 = self.c.nty[self.c.p.nfc[n / 65536][n % 65536] / 65536][self.c.p.nfc[n / 65536][n % 65536] % 65536]
        if self.c.yk[at] == 7 {
            # len массива — константа, аргумент не вычисляется
            self.ser(2, 0, self.c.yb[at])
            self.ert = 1
            self.nx3 = self.nx3 - 1
            return
        }
        self.xa3[f] = 4
        self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
    }

    func xcall_user(var self, f: u32, n: u32, a: u32, l: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let fi: u32 = self.c.find_func(a, l)
        self.xa3[f] = 0
        self.xb3[f] = fi
        self.xg3[f] = self.nag
        let rt2: u32 = self.c.fret[fi]
        if rt2 != 4294967295 {
            if self.is_agg(rt2) {
                self.nm_lit("call.ret")
                self.e_alloca_n(rt2)
                self.ag_push_rr(rt2)
            }
        }
        if self.c.fpc[fi] == 0 {
            self.xufin(f)
        } else {
            self.xf3[f] = 0
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        }
    }

    func xcall_next(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let code: u32 = self.xa3[f]
        if code == 1 or code == 2 {
            self.set1er()
            if code == 1 {
                self.e_rt_s("print")
            } else {
                self.e_rt_s("write")
            }
            self.ert = 5
            self.nx3 = self.nx3 - 1
        } elif code == 3 {
            self.xpi(n)
            self.nx3 = self.nx3 - 1
        } elif code == 5 {
            self.set1er()
            self.e_wbyte()
            self.ert = 5
            self.nx3 = self.nx3 - 1
        } elif code == 6 {
            self.set1er()
            self.e_webyte()
            self.ert = 5
            self.nx3 = self.nx3 - 1
        } elif code == 7 {
            self.set1er()
            self.e_exit()
            self.ert = 5
            self.nx3 = self.nx3 - 1
        } elif code == 8 {
            self.ag_push(1)
            self.xf3[f] = self.xf3[f] + 1
            if self.xf3[f] >= 3 {
                self.xwspan(f, n)
            } else {
                self.xpush2(self.c.nth_child(n, self.xf3[f]))
            }
        } elif code == 4 {
            # len строки: load текущей длины
            self.set1er()
            self.e_gepc(self.ert, 0)
            self.set1rr()
            self.e_load(0)
            self.serrr(1)
            self.nx3 = self.nx3 - 1
        } elif code >= 100 {
            self.xcast(n, code)
            self.nx3 = self.nx3 - 1
        } else {
            # очередной аргумент пользовательской функции
            let fi: u32 = self.xb3[f]
            self.ag_push(self.c.pty[self.c.fps[fi] + self.xf3[f]])
            self.xf3[f] = self.xf3[f] + 1
            if self.xf3[f] >= self.c.fpc[fi] {
                self.xufin(f)
            } else {
                self.xpush2(self.c.nth_child(n, self.xf3[f]))
            }
        }
    }

    # write_span: аргументы (массив, off, len) в ag[base..base+3);
    # границы off > N или len > N - off — trap (как codegen.py).
    func xwspan(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let base: u32 = self.xg3[f]
        let arg0: u32 = self.c.p.nfc[n / 65536][n % 65536]
        let at: u32 = self.c.nty[arg0 / 65536][arg0 % 65536]
        let sz: u32 = self.c.yb[at]
        # rem = sub N, off
        self.set1(2, 0, sz)
        self.set2(self.agk[base + 1], self.aga[base + 1], self.agb[base + 1])
        self.e_bin(2, 1)
        let mk1: u32 = self.rrk
        let ma1: u32 = self.rra
        let mb1: u32 = self.rrb
        # bad1 = icmp ugt off, N
        self.set1(self.agk[base + 1], self.aga[base + 1], self.agb[base + 1])
        self.set2(2, 0, sz)
        self.e_icmp(9, 1)
        let bk1: u32 = self.rrk
        let ba1: u32 = self.rra
        let bb1: u32 = self.rrb
        # bad2 = icmp ugt len, rem
        self.set1(self.agk[base + 2], self.aga[base + 2], self.agb[base + 2])
        self.set2(mk1, ma1, mb1)
        self.e_icmp(9, 1)
        # bad = or bad1, bad2
        self.set2rr()
        self.set1(bk1, ba1, bb1)
        self.e_bin(9, 3)
        self.set1rr()
        self.trap_if(self.c.p.nl[n / 65536][n % 65536], self.c.p.nc[n / 65536][n % 65536], 8, 0, 0)
        # ptr = gep [N x i8] arr, 0, off
        self.set1(self.agk[base], self.aga[base], self.agb[base])
        self.set2(self.agk[base + 1], self.aga[base + 1], self.agb[base + 1])
        self.e_gepi(at)
        self.set1rr()
        self.set2(self.agk[base + 2], self.aga[base + 2], self.agb[base + 2])
        self.e_wspan()
        self.nag = base
        self.ert = 5
        self.nx3 = self.nx3 - 1
    }

    # Завершение вызова функции/метода: аргументы в ag[xg3..nag).
    func xufin(var self, f: u32)
        requires f < 64
        ensures true
    {
        let fi: u32 = self.xb3[f]
        let base: u32 = self.xg3[f]
        let rt2: u32 = self.c.fret[fi]
        var ok2: u32 = 0
        var oa: u32 = 0
        var ob2: u32 = 0
        var agg2: bool = false
        if rt2 != 4294967295 {
            if self.is_agg(rt2) {
                agg2 = true
                ok2 = self.agk[base]
                oa = self.aga[base]
                ob2 = self.agb[base]
            }
        }
        self.e_ucall(fi, base)
        if rt2 == 4294967295 {
            self.ert = 5
        } elif agg2 {
            self.ser(ok2, oa, ob2)
            self.ert = rt2
        } else {
            self.serrr(rt2)
        }
        self.nx3 = self.nx3 - 1
    }

    func xmeth(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let ph: u32 = self.xp3[f]
        let obj: u32 = self.c.p.nfc[n / 65536][n % 65536]
        if ph == 0 {
            if self.c.p.nk[obj / 65536][obj % 65536] == 37 {
                if self.c.is_enum_name(self.c.p.nss[obj / 65536][obj % 65536], self.c.p.nsl[obj / 65536][obj % 65536]) {
                    self.xctor(f, n, obj)
                    return
                }
            }
            self.xp3[f] = 1
            self.xpush2(obj)
        } elif ph == 1 {
            self.xmeth_obj(f, n)
        } elif ph == 9 {
            # аргумент конструктора готов: скопировать в слот
            self.set1(0, self.xe3[f], 0)
            self.set2er()
            self.copy_into(self.xa3[f])
            self.ser(1, self.xb3[f], self.xc3[f])
            self.ert = self.xd3[f]
            self.nx3 = self.nx3 - 1
        } else {
            # очередной аргумент метода
            let mfi: u32 = self.xb3[f]
            self.ag_push(self.c.pty[self.c.fps[mfi] + self.xf3[f]])
            self.xf3[f] = self.xf3[f] + 1
            if self.xf3[f] >= self.c.fpc[mfi] {
                self.xufin(f)
            } else {
                self.xpush2(self.c.nth_child(n, self.xf3[f] + 1))
            }
        }
    }

    func xmeth_obj(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let st2: u32 = self.ert
        let si: u32 = self.c.find_struct(self.c.ys[st2], self.c.yl[st2])
        let mfi: u32 = self.c.fh_find(si, self.c.p.nss[n / 65536][n % 65536], self.c.p.nsl[n / 65536][n % 65536])
        self.xb3[f] = mfi
        self.xg3[f] = self.nag
        let ek: u32 = self.erk
        let ea: u32 = self.era
        let eb: u32 = self.erb
        let rt2: u32 = self.c.fret[mfi]
        if rt2 != 4294967295 {
            if self.is_agg(rt2) {
                self.nm_lit("call.ret")
                self.e_alloca_n(rt2)
                self.ag_push_rr(rt2)
            }
        }
        self.ser(ek, ea, eb)
        self.ag_push(st2)
        if self.c.fpc[mfi] == 0 {
            self.xufin(f)
        } else {
            self.xf3[f] = 0
            self.xp3[f] = 2
            self.xpush2(self.c.nth_child(n, 1))
        }
    }

    # Конструктор варианта enum с нагрузкой: E.V(x).
    func xctor(var self, f: u32, n: u32, obj: u32)
        requires f < 64 and n < 131072 and obj < 131072
        ensures true
    {
        let ei: u32 = self.c.find_enum(self.c.p.nss[obj / 65536][obj % 65536], self.c.p.nsl[obj / 65536][obj % 65536])
        let w: u32 = self.c.variant_of(self.c.p.nss[obj / 65536][obj % 65536], self.c.p.nsl[obj / 65536][obj % 65536], self.c.p.nss[n / 65536][n % 65536], self.c.p.nsl[n / 65536][n % 65536])
        let ety: u32 = self.c.nty[n / 65536][n % 65536]
        let m: u32 = self.nbn
        self.nb_sb(self.c.p.nss[obj / 65536][obj % 65536], self.c.p.nsl[obj / 65536][obj % 65536])
        self.nb_b(46)
        self.nb_sb(self.c.p.nss[n / 65536][n % 65536], self.c.p.nsl[n / 65536][n % 65536])
        self.dedup(m)
        self.e_alloca_n(ety)
        self.xb3[f] = self.rra
        self.xc3[f] = self.rrb
        self.xd3[f] = ety
        self.set1rr()
        self.e_gepc(ety, 0)
        self.set2rr()
        self.set1(2, 0, w - self.c.evs[ei])
        self.e_store(0)
        self.set1(1, self.xb3[f], self.xc3[f])
        self.e_gepc(ety, self.slot_of(ety, w))
        self.xe3[f] = self.rra
        self.xa3[f] = self.c.wpl[w]
        self.xp3[f] = 9
        self.xpush2(self.c.p.nns[obj / 65536][obj % 65536])
    }

    # Тег встроенного enum-варианта.
    func builtin_vtag(var self, va: u32, vl: u32) -> u32
        requires true
        ensures result <= 2
    {
        if self.c.span_is(va, vl, "Eof") or self.c.span_is(va, vl, "Empty") {
            return 0
        }
        if self.c.span_is(va, vl, "Fail") or self.c.span_is(va, vl, "BadChar") {
            return 1
        }
        return 2
    }

    func xmem(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let obj: u32 = self.c.p.nfc[n / 65536][n % 65536]
        if self.xp3[f] == 0 {
            if self.c.p.nk[obj / 65536][obj % 65536] == 37 {
                if self.c.is_enum_name(self.c.p.nss[obj / 65536][obj % 65536], self.c.p.nsl[obj / 65536][obj % 65536]) {
                    self.xmem_enum(n, obj)
                    self.nx3 = self.nx3 - 1
                    return
                }
            }
            self.xp3[f] = 1
            self.xpush2(obj)
            return
        }
        let st2: u32 = self.ert
        let si: u32 = self.c.find_struct(self.c.ys[st2], self.c.yl[st2])
        let g: u32 = self.c.field_of(si, self.c.p.nss[n / 65536][n % 65536], self.c.p.nsl[n / 65536][n % 65536])
        self.set1er()
        self.e_gepc(st2, g - self.c.sgs[si])
        let ft: u32 = self.c.gty[g]
        if self.is_agg(ft) {
            self.serrr(ft)
        } else {
            self.set1rr()
            self.e_load(ft)
            self.serrr(ft)
        }
        self.nx3 = self.nx3 - 1
    }

    # Литерал варианта без нагрузки: E.V.
    func xmem_enum(var self, n: u32, obj: u32)
        requires n < 131072 and obj < 131072
        ensures true
    {
        let ety: u32 = self.c.nty[n / 65536][n % 65536]
        let ei: u32 = self.c.find_enum(self.c.p.nss[obj / 65536][obj % 65536], self.c.p.nsl[obj / 65536][obj % 65536])
        if ei == 4294967295 {
            self.ser(2, 0, self.builtin_vtag(self.c.p.nss[n / 65536][n % 65536], self.c.p.nsl[n / 65536][n % 65536]))
            self.ert = ety
            return
        }
        let w: u32 = self.c.variant_of(self.c.p.nss[obj / 65536][obj % 65536], self.c.p.nsl[obj / 65536][obj % 65536], self.c.p.nss[n / 65536][n % 65536], self.c.p.nsl[n / 65536][n % 65536])
        let tag: u32 = w - self.c.evs[ei]
        if self.enum_pay(ety) {
            # вариант без нагрузки внутри enum с нагрузкой — агрегат с тегом
            let m: u32 = self.nbn
            self.nb_sb(self.c.p.nss[obj / 65536][obj % 65536], self.c.p.nsl[obj / 65536][obj % 65536])
            self.nb_b(46)
            self.nb_sb(self.c.p.nss[n / 65536][n % 65536], self.c.p.nsl[n / 65536][n % 65536])
            self.dedup(m)
            self.e_alloca_n(ety)
            let os: u32 = self.rra
            let ol: u32 = self.rrb
            self.set1rr()
            self.e_gepc(ety, 0)
            self.set2rr()
            self.set1(2, 0, tag)
            self.e_store(0)
            self.ser(1, os, ol)
            self.ert = ety
        } else {
            self.ser(2, 0, tag)
            self.ert = ety
        }
    }

    # er — индексное значение: u8 расширяется до i32.
    func widen(var self)
        requires true
        ensures true
    {
        if self.c.yk[self.ert] == 2 {
            self.set1er()
            self.e_cvt(0, 2, 0)
            self.serrr(0)
        }
    }

    # Указатель на элемент с проверкой границ. База — (bk,ba,bb) типа bt,
    # индекс — er (уже i32). Результат — rr.
    func idx_gep(var self, n: u32, bk: u32, ba: u32, bb: u32, bt: u32)
        requires n < 131072 and bt < 512
        ensures true
    {
        let ik: u32 = self.erk
        let ia: u32 = self.era
        let ib: u32 = self.erb
        var zk: u32 = 2
        var za: u32 = 0
        var zb: u32 = 0
        if self.c.yk[bt] == 7 {
            zb = self.c.yb[bt]
        } else {
            self.set1(bk, ba, bb)
            self.e_gepc(bt, 0)
            self.set1rr()
            self.e_load(0)
            zk = self.rrk
            za = self.rra
            zb = self.rrb
        }
        self.set1(ik, ia, ib)
        self.set2(2, 0, 0)
        self.e_icmp(3, 0)
        let lk2: u32 = self.rrk
        let la2: u32 = self.rra
        let lb2: u32 = self.rrb
        self.set1(ik, ia, ib)
        self.set2(zk, za, zb)
        self.e_icmp(6, 0)
        self.set2rr()
        self.set1(lk2, la2, lb2)
        self.e_bin(9, 3)
        self.set1rr()
        self.trap_if(self.c.p.nl[n / 65536][n % 65536], self.c.p.nc[n / 65536][n % 65536], 4, 0, 0)
        self.set1(bk, ba, bb)
        self.set2(ik, ia, ib)
        if self.c.yk[bt] == 7 {
            self.e_gepi(bt)
        } else {
            self.e_geps(bt)
        }
    }

    func xidx(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
    {
        let ph: u32 = self.xp3[f]
        if ph == 0 {
            self.xp3[f] = 1
            self.xpush2(self.c.p.nfc[n / 65536][n % 65536])
        } elif ph == 1 {
            self.xa3[f] = self.erk
            self.xb3[f] = self.era
            self.xc3[f] = self.erb
            self.xd3[f] = self.ert
            self.xp3[f] = 2
            self.xpush2(self.c.p.nns[self.c.p.nfc[n / 65536][n % 65536] / 65536][self.c.p.nfc[n / 65536][n % 65536] % 65536])
        } else {
            self.widen()
            let bt: u32 = self.xd3[f]
            self.idx_gep(n, self.xa3[f], self.xb3[f], self.xc3[f], bt)
            var et: u32 = 4
            if self.c.yk[bt] == 7 {
                et = self.c.ya[bt]
            }
            if not self.is_agg(et) {
                self.set1rr()
                self.e_load(et)
            }
            self.serrr(et)
            self.nx3 = self.nx3 - 1
        }
    }

    func xslit(var self, f: u32, n: u32)
        requires f < 64 and n < 131072
        ensures true
