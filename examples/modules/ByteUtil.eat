# Модуль: утилиты классификации байтов (без main).
# Собирается вместе с главным файлом:
#   python -m eatc run examples/modules/ByteUtil.eat examples/modules/Main.eat

func is_digit(c: char) -> bool
    requires true
    ensures result == (u8(c) >= 48 and u8(c) <= 57)
{
    return u8(c) >= 48 and u8(c) <= 57
}

func digit_value(c: char) -> u8
    requires u8(c) >= 48 and u8(c) <= 57
    ensures result <= 9
{
    return u8(c) - 48
}
