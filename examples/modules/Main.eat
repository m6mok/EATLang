# Главный модуль: использует библиотеку lib/ (lib/Ascii.eat, lib/Num.eat).
# Программа = упорядоченный список файлов, пространство имён единое:
#   eatc run selfhost/Rt.eat lib/Ascii.eat lib/Num.eat examples/modules/Main.eat

func main() {
    let c: char = '7'
    if is_digit(u8(c)) {
        print("цифра {c} = {digit_value(u8(c))}")
    } else {
        print("{c} — не цифра")
    }
    print("clamp(300, 0, 255) = {clamp(300, 0, 255)}")
}
