# Демонстрация extern: логика на EATLang, драйверы — на C за границей.
# Один исходник собирается и на хост (host_driver.c — заглушка), и на
# МК (mcu_driver.c поверх шима платы): вывод байт-в-байт одинаков.

extern func led_set(on: bool)
    requires true

extern func delay_ms(ms: u32)
    requires ms <= 1000

extern func button_pressed() -> bool
    ensures true

func main() {
    let presses: u32 = 0
    for i in 0..8 {
        led_set(i % 2 == 0)
        if button_pressed() {
            presses = presses + 1
        }
        delay_ms(100)
    }
    led_set(false)
    print("нажатий за 8 тактов: {presses}")
    # u64 на 32-битном МК: деление/умножение/сдвиги опускаются в
    # вызовы __aeabi_* — их закрывает libclang_rt.builtins.a (Makefile)
    const ticks: u64 = 0x123456789ABCDEF + u64(presses)
    const div: u64 = ticks / (u64(presses) + 3)
    const rem: u64 = ticks % 1000000007
    const sh: u64 = ticks >> u64(presses + 1)
    const prod: u64 = (ticks & 0xFFFFFFFF) * (u64(presses) + 2862933555)
    const neg: i64 = (0 - i64(ticks >> 8)) / 3
    print("u64: {div} {rem} {sh} {prod} {neg}")
}
