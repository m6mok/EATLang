# Цикл со статической границей.
#
# Правило 2 NASA: while в языке нет. Граница цикла — константа
# времени компиляции, число итераций известно до запуска.

func main() {
    let count: u32 = 3
    for _ in 0..3 {
        print("Countdown: {count}")
        count = count - 1
    }
    print("Go!")
}
